{#--------------------------------
  Text Macro
--------------------------------#}
{% macro text(property, args = {}) %}
	{# Override args with static values #}
	{% set args =  args | merge({
		field : "text",
		type  : "text",
	}) %}
    {{ _self.input(property, args) }}
{% endmacro %}


{#--------------------------------#}
{# Text Forms                     #}
{#--------------------------------#}
{% macro textForm(id, args = {}, collection = "text") %}

	{{ _self.start(collection, { id:id }) }}

		{{ _self.id('id', { value:id, class: "hide" }) }}

		{% if args.field == 'textarea' %}
			{{ _self.textarea('text', args) }}
		{% else %}
			{{ _self.text('text', args) }}
		{% endif %}

	{{ _self.end() }}
{% endmacro %}