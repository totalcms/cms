{#--------------------------------
  URL Macro
--------------------------------#}
{% macro url(property, args = {}) %}
	{# Override args with static values #}
	{% set args =  args | merge({
		field : "url",
		type  : "url",
	}) %}
    {{ _self.input(property, args) }}
{% endmacro %}

{% macro urlForm(id, args = {}, collection = "url") %}
	{{ _self.start(collection, { id:id }) }}
		{{ _self.id('id', { value:id, class: "hide" }) }}
		{{ _self.url('url', args) }}
	{{ _self.end(args.save, args.delete) }}
{% endmacro %}

