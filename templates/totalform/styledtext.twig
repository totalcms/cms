{#--------------------------------
  Styled Text Macro
--------------------------------#}
{% macro styledtext(name, args = {}) %}
	{# Override args with static values #}
	{% set args =  args | merge({
		field  : "styledtext",
	}) %}
    {{ _self.textarea(name, args) }}
{% endmacro %}

{% macro styledtextForm(id, args = {}, collection = "styledtext") %}
	{{ _self.start(collection, { id:id }) }}
		{{ _self.id('id', { value:id, class: "hide" }) }}
		{{ _self.styledtext('styledtext', args) }}
	{{ _self.end() }}
{% endmacro %}
