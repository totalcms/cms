{#
    Select Field Macro
    name        = name of the field
    type        = type of the field data from Total CMS: text, number, date, etc
    class       = classes added to the field
    value       = value of the field
    label       = label of the field
    placeholder = placeholder of the field
    help        = help text of the field
    icon        = show icon
    required    = required field
    options     = array of options
    multiple    = enable multiple select
    rows        = number of rows for multi-select
#}
{% macro select(name, options = [], args = {}) %}
    {% set uuid       = uniqid() %}
    {% set collection = args.collection|default(totalcms.getData("collection")) %}
    {% set object     = args.object|default(totalcms.getData("object")) %}

	{# args priority: args, formProps, defaults #}
	{% set props = totalcms.formProps(name, collection, object.id|default("")) %}
	{% set args = {
		field       : "select",
		class       : "",
		value       : "",
		label       : "",
		placeholder : "",
		help        : false,
		icon        : true,
		required    : false,
	} | merge(props) | merge(args) %}

    {{ _self.fieldstart(args.field, uuid, args) }}
    <select
        id="field-{{ uuid }}"
        name="{{ name }}"
		{% if object %}
			value="{{ attribute(object, name)|e }}"
		{% else %}
        	{% if args.value %}value="{{ args.value|e }}"{% endif %}
		{% endif %}
        {% if args.help %}aria-describedby="help-{{ uuid }}"{% endif %}
        {% if args.multiple %}multiple size="{{ args.rows }}"{% endif %}
        {% if args.required %}required{% endif %}
    >
		{% if args.placeholder %}
		<option value="">{{ args.placeholder }}</option>
		{% endif %}

		{% set value = object ? attribute(object, name) : args.value %}

		{% for option in options %}
		<option value="{{ option.value|e }}" {%if option.value == value %}selected{% endif %}>{{ option.label|e }}</option>
		{% endfor %}
    </select>
    {{ _self.fieldend(uuid, args) }}

{% endmacro %}

{% macro selectmultiple(name, options = [], args = {}) %}
    {% set uuid       = uniqid() %}
    {% set collection = args.collection|default(totalcms.getData("collection")) %}
    {% set object     = args.object|default(totalcms.getData("object")) %}

	{# args priority: args, formProps, defaults #}
	{% set props = totalcms.formProps(name, collection, object.id|default("")) %}
	{% set args = {
		field       : "select",
		class       : "",
		label       : "",
		placeholder : "",
		value       : [],
		help        : false,
		icon        : true,
		required    : false,
		rows        : 10,
	} | merge(props) | merge(args) %}

    {{ _self.fieldstart(args.field, uuid, args) }}
    <select multiple
        id="field-{{ uuid }}"
        name="{{ name }}"
        size="{{ args.rows }}"
        {% if args.help %}aria-describedby="help-{{ uuid }}"{% endif %}
        {% if args.required %}required{% endif %}
    >
		{% if args.placeholder %}
		<option disabled>{{ args.placeholder|e }}</option>
		{% endif %}

		{# Get the default selected value #}
		{% set value = object ? attribute(object, name) : args.value %}

        {% for option in options %}
        <option value="{{ option.value|e }}" {% if option.value in values %}selected{% endif %}>{{ option.label|e }}</option>
        {% endfor %}
    </select>
    {{ _self.fieldend(uuid, args) }}
{% endmacro %}