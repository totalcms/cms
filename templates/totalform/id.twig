{#--------------------------------
  ID Macro
--------------------------------#}
{% macro id(property = "id", args = {}) %}
	{# Override args with static values #}
	{% set args =  args | merge({
		field    : "id",
		type     : "text",
		required : true,
		options  : {},
	}) %}

	{# Merge autogen into the options to make the interface more user friendly #}
	{% if args.autogen %}
		{% set options = args.options|merge({'autogen': args.autogen}) %}
		{% set args = args|merge({'options': options}) %}
	{% endif %}

    {{ _self.input(property, args) }}
{% endmacro %}