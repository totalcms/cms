{#--------------------------------
  Password Macro
--------------------------------#}
{% macro password(name, args = {}) %}
	{# Defaults #}
	{% set args = {
		minlength : 6,
	} | merge(args) %}

	{# Override args with static values #}
	{% set args =  args | merge({
		field     : "password",
		type      : "password",
	}) %}

    {{ _self.input(name, args) }}
{% endmacro %}
