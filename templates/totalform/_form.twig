{# Styles: help-box, help-label, help-tooltip #}
{#---------------------------------------------#}

{#--------------------------------
  Form Macros
--------------------------------#}
{% macro start(collection, args = {}) %}
	{% set args = {
		method : 'put',
		class  : '',
		id     : '',
	} | merge(args) %}

	{# Store the collection for this form so that other macros and get it #}
	{{ totalcms.storeData("collection", collection) }}

	{%set id = args.id|default(getParams.id) %}
	{%set method = args.method %}

	{% if id %}
		{# force method to be PUT you cannot use POST on an existing object #}
		{% if method == 'post' %}
			{%set method = 'put' %}
		{% endif %}
		{{ totalcms.storeData("object", totalcms.object(collection, id)) }}
		<form class="totalform {{args.class}}" data-collection="{{collection}}" data-id="{{id}}" data-method="{{method}}"
			data-api="{{totalcms.api}}/collections/{{collection}}/{{id}}">
	{% else %}
		<form class="totalform {{args.class}}" data-collection="{{collection}}" data-method="{{method}}"
			data-api="{{totalcms.api}}/collections/{{collection}}">
	{% endif %}
{% endmacro %}

{% macro end() %}
	{{ totalcms.clearStorage() }}
	{{ _self.saveButton() }}
	</form>
{% endmacro %}

