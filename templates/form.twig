{% import "form-macros.twig" as form %}

{% set object = {} %}
{% if getParams.id %}
	{% set object = totalcms.object(collection, getParams.id) %}
{% endif %}

{{ form.start('blog', { method: 'post', object: object }) }}

    {{ form.id('id', {
		object : object
	}) }}
    {{ form.input('title') }}
    {{ form.textarea('summary') }}
    {{ form.styledtext('content') }}
    {{ form.image('image') }}
    {{ form.gallery('gallery') }}
    {{ form.list('tags') }}
    {{ form.select('author') }}

{{ form.end() }}

