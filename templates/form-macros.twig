{#--------------------------------#}
{# Template Macros               #}
{#--------------------------------#}

{#
    Input Field Macro
    name        = name of the field
    type        = type of the field data from Total CMS: text, number, date, etc
    input       = type of the input
    class       = classes added to the field
    value       = value of the field
    label       = label of the field
    placeholder = placeholder of the field
    help        = help text of the field
#}
{% macro input(name, type = "text", input = "text", class="", value = "", label = "", placeholder = "", help = "", icon = true) %}

    {% set uuid = uniqid() %}

    {# Help Trigger classes: help-on-focus, help-on-hover #}
    {# Help Style classes: help-box, help-label, help-tooltip #}
    <div class="form-field {{ type }}-field {{ class }}">

        {% if label %}
        <label for="input-{{uuid}}">{{ label }}</label>
        {% endif %}

        <div class="form-group">
            <input
                id="input-{{uuid}}"
                type="{{ input }}"
                name="{{ name }}"
                {% if value %}value="{{ value }}"{% endif %}
                {% if placeholder %}placeholder="{{ placeholder }}"{% endif %}
                {% if help %}aria-describedby="help-{{ uuid }}"{% endif %}
            >
            {% if icon %}<div class="form-group-icon"></div>{% endif %}
        </div>
        {% if help %}
        <p class="help" id="help-{{uuid}}">{{ help }}</p>
        {% endif %}
    </div>

{% endmacro %}

{# Textarea Field #}
{% macro textarea(name, value, rows = 10, cols = 40) %}
    <textarea name="{{ name }}" rows="{{ rows }}" cols="{{ cols }}">{{ value|e }}</textarea>
{% endmacro %}

{# Hidden Field #}
{% macro hidden(name, value) %}

    <div class="form-field">
        <input type="hidden" name="{{ name }}" value="{{ value }}">
    </div>

{% endmacro %}

