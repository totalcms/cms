{% macro start(collection, args = {}) %}
	{% set args = {
		method : 'post',
		class  : '',
		id     : '',
	} | merge(args) %}

	{# Store the collection for this form so that other macros and get it #}
	{{ totalcms.storeData("collection", collection) }}

	{%set id = args.id|default(getParams.id) %}

	{% if id %}
		{{ totalcms.storeData("object", totalcms.object(collection, id)) }}
		<form class="totalform {{args.class}}" data-method="{{args.method}}"
			data-api="{{totalcms.api}}/collection/{{collection}}/{{id}}">
	{% else %}
		<form class="totalform {{args.class}}" data-method="{{args.method}}"
			data-api="{{totalcms.api}}/collection/{{collection}}">
	{% endif %}
{% endmacro %}

{% macro end() %}
	{{ totalcms.clearStorage() }}
	</form>
{% endmacro %}


{% macro fieldstart(field, uuid, args = {}) %}
	{% set args = {
		class : '',
		label : false,
	} | merge(args) %}

    <div class="form-field {{ field }}-field {{ args.class }}">

        {% if args.label %}
        <label for="field-{{ uuid }}">{{ args.label }}</label>
        {% endif %}

        <div class="form-group">
{% endmacro %}

{% macro fieldend(uuid, args = {}) %}
	{% set args = {
		icon : false,
		help : false,
	} | merge(args) %}

            {% if args.icon %}<div class="form-group-icon"></div>{% endif %}
        </div>
        {% if args.help %}
        <p class="help" id="help-{{uuid}}">{{ args.help }}</p>
        {% endif %}
    </div>
{% endmacro %}

{#
    Input Field Macro
    name        = name of the field
    field        = type of the field data from Total CMS: text, number, date, etc
    type       = type of the input
    class       = classes added to the field
    value       = value of the field
    label       = label of the field
    placeholder = placeholder of the field
    help        = help text of the field
    icon        = show icon
    required    = required field
    min         = minimum value
    max         = maximum value
    step        = step value
#}
{% macro input(name, args = {}) %}
    {% set uuid       = uniqid() %}
    {% set collection = args.collection|default(totalcms.getData("collection")) %}
    {% set object     = args.object|default(totalcms.getData("object")) %}

	{# args priority: args, formProps, defaults #}
	{% set props = totalcms.formProps(name, collection, object.id|default("")) %}
	{% set args  = {
		field       : "text",
		type        : "text",
		class       : "",
		value       : "",
		label       : "",
		placeholder : "",
		help        : false,
		icon        : true,
		required    : false,
		min         : false,
		max         : false,
		step        : false,
	} | merge(props) | merge(args) %}

    {{ _self.fieldstart(args.field, uuid, args) }}
    <input
        id="field-{{ uuid }}"
        type="{{ args.type }}"
        name="{{ name }}"
        {% if args.min %}min="{{ args.min }}"{% endif %}
        {% if args.max %}max="{{ args.max }}"{% endif %}
        {% if args.step %}step="{{ args.step }}"{% endif %}
        {% if args.placeholder %}placeholder="{{ args.placeholder|e }}"{% endif %}
        {% if args.help %}aria-describedby="help-{{ uuid }}"{% endif %}
        {% if args.required %}required{% endif %}
		value="{{ object ? attribute(object, name) : args.value|e }}"
    >
    {{ _self.fieldend(uuid, args) }}
{% endmacro %}

{#
    Textarea Field Macro
    name        = name of the field
    type        = type of the field data from Total CMS: text, number, date, etc
    class       = classes added to the field
    value       = value of the field
    label       = label of the field
    placeholder = placeholder of the field
    help        = help text of the field
    icon        = show icon
    required    = required field
    rows        = number of rows
#}
{% macro textarea(name, args = {}) %}
    {% set uuid       = uniqid() %}
    {% set collection = args.collection|default(totalcms.getData("collection")) %}
    {% set object     = args.object|default(totalcms.getData("object")) %}

	{# args priority: args, formProps, defaults #}
	{% set props = totalcms.formProps(name, collection, object.id|default("")) %}
	{% set args = {
		field       : "text",
		class       : "",
		value       : "",
		label       : "",
		placeholder : "",
		help        : false,
		icon        : true,
		required    : false,
		rows        : 10,
	} | merge(props) | merge(args) %}

    {{ _self.fieldstart(args.field, uuid, args) }}
    <textarea
        id="field-{{ uuid }}"
        name="{{ name }}"
        rows="{{ args.rows }}"
        {% if args.placeholder %}placeholder="{{ args.placeholder }}"{% endif %}
        {% if args.help %}aria-describedby="help-{{ uuid }}"{% endif %}
        {% if args.required %}required{% endif %}
    >{{ object ? attribute(object, name) : args.value }}</textarea>
    {{ _self.fieldend(uuid, args) }}

{% endmacro %}

{#
    Select Field Macro
    name        = name of the field
    type        = type of the field data from Total CMS: text, number, date, etc
    class       = classes added to the field
    value       = value of the field
    label       = label of the field
    placeholder = placeholder of the field
    help        = help text of the field
    icon        = show icon
    required    = required field
    options     = array of options
    multiple    = enable multiple select
    rows        = number of rows for multi-select
#}
{% macro select(name, options = [], args = {}) %}
    {% set uuid       = uniqid() %}
    {% set collection = args.collection|default(totalcms.getData("collection")) %}
    {% set object     = args.object|default(totalcms.getData("object")) %}

	{# args priority: args, formProps, defaults #}
	{% set props = totalcms.formProps(name, collection, object.id|default("")) %}
	{% set args = {
		field       : "select",
		class       : "",
		value       : "",
		label       : "",
		placeholder : "",
		help        : false,
		icon        : true,
		required    : false,
	} | merge(props) | merge(args) %}

    {{ _self.fieldstart(args.field, uuid, args) }}
    <select
        id="field-{{ uuid }}"
        name="{{ name }}"
		{% if object %}
			value="{{ attribute(object, name)|e }}"
		{% else %}
        	{% if args.value %}value="{{ args.value|e }}"{% endif %}
		{% endif %}
        {% if args.help %}aria-describedby="help-{{ uuid }}"{% endif %}
        {% if args.multiple %}multiple size="{{ args.rows }}"{% endif %}
        {% if args.required %}required{% endif %}
    >
		{% if args.placeholder %}
		<option value="">{{ args.placeholder }}</option>
		{% endif %}

		{% set value = object ? attribute(object, name) : args.value %}

		{% for option in options %}
		<option value="{{ option.value|e }}" {%if option.value == value %}selected{% endif %}>{{ option.label|e }}</option>
		{% endfor %}
    </select>
    {{ _self.fieldend(uuid, args) }}

{% endmacro %}

{% macro selectmultiple(name, options = [], args = {}) %}
    {% set uuid       = uniqid() %}
    {% set collection = args.collection|default(totalcms.getData("collection")) %}
    {% set object     = args.object|default(totalcms.getData("object")) %}

	{# args priority: args, formProps, defaults #}
	{% set props = totalcms.formProps(name, collection, object.id|default("")) %}
	{% set args = {
		field       : "select",
		class       : "",
		label       : "",
		placeholder : "",
		value       : [],
		help        : false,
		icon        : true,
		required    : false,
		rows        : 10,
	} | merge(props) | merge(args) %}

    {{ _self.fieldstart(args.field, uuid, args) }}
    <select multiple
        id="field-{{ uuid }}"
        name="{{ name }}"
        size="{{ args.rows }}"
        {% if args.help %}aria-describedby="help-{{ uuid }}"{% endif %}
        {% if args.required %}required{% endif %}
    >
		{% if args.placeholder %}
		<option disabled>{{ args.placeholder|e }}</option>
		{% endif %}

		{# Get the default selected value #}
		{% set value = object ? attribute(object, name) : args.value %}

        {% for option in options %}
        <option value="{{ option.value|e }}" {% if option.value in values %}selected{% endif %}>{{ option.label|e }}</option>
        {% endfor %}
    </select>
    {{ _self.fieldend(uuid, args) }}
{% endmacro %}


{# Hidden Field #}
{% macro hidden(name, args = {}) %}
    {% set object = args.object|default(totalcms.getData("object")) %}

	{% set args = {
		value  : "",
	} | merge(args) %}

    <div class="form-field hidden-field">
        <input type="hidden" name="{{ name }}" value="{{ object ? attribute(object, name) : args.value|e }}">
    </div>

{% endmacro %}


