{#--------------------------------
  Checkbox Macro
--------------------------------#}
{% macro checkbox(name, args = {}) %}
	{% set args = {
		class       : "",
		label       : "",
		help        : false,
		required    : false,
	} | merge(args) %}

    {% set uuid = uniqid() %}
    {% set type = "check" %}
    {% set input = "checkbox" %}

    <div class="form-field {{ type }}-field {{ args.class }}">
        <input
            id="field-{{ uuid }}"
            name="{{ name }}"
            type="{{ input }}"
            {% if args.help %}aria-describedby="help-{{ uuid }}"{% endif %}
            {% if args.required %}required{% endif %}
        >
        <label for="field-{{ uuid }}">{{ args.label }}</label>
        {% if args.help %}
        <p class="help" id="help-{{uuid}}">{{ args.help }}</p>
        {% endif %}
    </div>

{% endmacro %}

{#--------------------------------
  Toggle Macro
--------------------------------#}
{% macro toggle(name, args = {}) %}
	{% set args = {
		class       : "",
		label       : "",
		help        : false,
		required    : false,
	} | merge(args) %}

    {% set uuid = uniqid() %}
    {% set type = "toggle" %}
    {% set input = "checkbox" %}

    <div class="form-field {{ type }}-field {{ args.class }}">
        {% if args.label %}
        <label for="field-{{ uuid }}">{{ args.label }}</label>
        {% endif %}
        <div class="switch">
            <input
                id="field-{{ uuid }}"
                name="{{ name }}"
                type="{{ input }}"
                {% if args.help %}aria-describedby="help-{{ uuid }}"{% endif %}
                {% if args.required %}required{% endif %}
            >
            <label for="field-{{ uuid }}" aria-hidden="true"></label>
        </div>
        {% if args.help %}
        <p class="help" id="help-{{uuid}}">{{ args.help }}</p>
        {% endif %}
    </div>

{% endmacro %}

{#--------------------------------
  Radio Macro
--------------------------------#}
{% macro radio(name, options = [], args = {}) %}
	{% set args = {
		class       : "",
		label       : "",
		help        : false,
		required    : false,
	} | merge(args) %}

    {% set uuid = uniqid() %}

    <div class="form-field radio-field {{ class }}">

        {% if args.label %}
        <label>{{ args.label }}</label>
        {% endif %}

        {% for option in options %}
        <div class="radio">
            <input
                id="field-{{ uuid }}-{{ loop.index }}"
                name="{{ name }}"
                type="radio"
                value="{{ option.value }}"
                {% if args.help %}aria-describedby="help-{{ uuid }}"{% endif %}
                {% if args.required %}required{% endif %}
                {% if option.selected %}checked{% endif %}
            >
            <label for="field-{{ uuid }}-{{ loop.index }}" class="radio-label">{{ option.label }}</label>
        </div>
        {% endfor %}

        {% if args.help %}
        <p class="help" id="help-{{uuid}}">{{ args.help }}</p>
        {% endif %}
    </div>

{% endmacro %}

