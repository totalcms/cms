{% macro start(collection, args = {}) %}
	{% set args = {
		method : 'post',
		id     : '',
	} | merge(args) %}

	{% if args.id %}
		<form class="totalform" data-method="{{args.method}}"
			data-api="{{totalcms.api}}/collection/{{collection}}/{{args.id}}">
	{% else %}
		<form class="totalform" data-method="{{args.method}}"
			data-api="{{totalcms.api}}/collection/{{collection}}">
	{% endif %}
{% endmacro %}

{% macro end() %}
	</form>
{% endmacro %}


{% macro fieldstart(type, args = {}) %}
	{% set args = {
		class : '',
		label : false,
		uuid  : '',
	} | merge(args) %}

    <div class="form-field {{ type }}-field {{ args.class }}">

        {% if args.label %}
        <label for="field-{{ args.uuid }}">{{ args.label }}</label>
        {% endif %}

        <div class="form-group">
{% endmacro %}

{% macro fieldend(args = {}) %}
	{% set args = {
		icon : false,
		help : false,
		uuid : '',
	} | merge(args) %}

            {% if args.icon %}<div class="form-group-icon"></div>{% endif %}
        </div>
        {% if args.help %}
        <p class="help" id="help-{{args.uuid}}">{{ args.help }}</p>
        {% endif %}
    </div>
{% endmacro %}

{#
    Input Field Macro
    name        = name of the field
    type        = type of the field data from Total CMS: text, number, date, etc
    input       = type of the input
    class       = classes added to the field
    value       = value of the field
    label       = label of the field
    placeholder = placeholder of the field
    help        = help text of the field
    icon        = show icon
    required    = required field
    min         = minimum value
    max         = maximum value
    step        = step value
#}
{% macro input(name, args = {}) %}
	{% set args = {
		type        : "text",
		input       : "text",
		class       : "",
		value       : "",
		label       : "",
		placeholder : "",
		object      : false,
		help        : false,
		icon        : true,
		required    : false,
		min         : false,
		max         : false,
		step        : false,
	} | merge(args) %}

    {% set uuid = uniqid() %}

    {{ _self.fieldstart(args.type, {class: args.class, label: args.label, uuid: uuid}) }}
    <input
        id="field-{{ uuid }}"
        type="{{ args.input }}"
        name="{{ name }}"
        {% if args.min %}min="{{ args.min }}"{% endif %}
        {% if args.max %}max="{{ args.max }}"{% endif %}
        {% if args.step %}step="{{ args.step }}"{% endif %}
        {% if args.placeholder %}placeholder="{{ args.placeholder|e }}"{% endif %}
        {% if args.help %}aria-describedby="help-{{ uuid }}"{% endif %}
        {% if args.required %}required{% endif %}
		{% if args.object %}
			value="{{ attribute(args.object, name)|e }}"
		{% else %}
        	{% if args.value %}value="{{ args.value|e }}"{% endif %}
		{% endif %}
    >
    {% if args.input == "range" %}
	<div id="value-{{ uuid }}" class="range-value">{{ args.value }}</div>
    {% endif %}
    {{ _self.fieldend({ help:args.help, icon:args.icon, uuid:uuid }) }}
{% endmacro %}

{#
    Textarea Field Macro
    name        = name of the field
    type        = type of the field data from Total CMS: text, number, date, etc
    class       = classes added to the field
    value       = value of the field
    label       = label of the field
    placeholder = placeholder of the field
    help        = help text of the field
    icon        = show icon
    required    = required field
    rows        = number of rows
#}
{% macro textarea(name, args = {}) %}
	{% set args = {
		type        : "text",
		class       : "",
		value       : "",
		label       : "",
		placeholder : "",
		object      : false,
		help        : false,
		icon        : true,
		required    : false,
		rows        : 10,
	} | merge(args) %}

    {% set uuid = uniqid() %}

    {{ _self.fieldstart(args.type, {class: args.class, label: args.label, uuid: uuid}) }}
    <textarea
        id="field-{{ uuid }}"
        name="{{ name }}"
        rows="{{ args.rows }}"
        {% if args.placeholder %}placeholder="{{ args.placeholder }}"{% endif %}
        {% if args.help %}aria-describedby="help-{{ uuid }}"{% endif %}
        {% if args.required %}required{% endif %}
    >{% if args.object %}{{ attribute(args.object, name) }}{% else %}{{ args.value }}{% endif %}</textarea>
    {{ _self.fieldend({ help:args.help, icon:args.icon, uuid:uuid }) }}

{% endmacro %}

{#
    Select Field Macro
    name        = name of the field
    type        = type of the field data from Total CMS: text, number, date, etc
    class       = classes added to the field
    value       = value of the field
    label       = label of the field
    placeholder = placeholder of the field
    help        = help text of the field
    icon        = show icon
    required    = required field
    options     = array of options
    multiple    = enable multiple select
    rows        = number of rows for multi-select
#}
{% macro select(name, options = [], args = {}) %}
	{% set args = {
		type        : "select",
		class       : "",
		value       : "",
		label       : "",
		placeholder : "",
		object      : false,
		help        : false,
		icon        : true,
		required    : false,
		multiple    : false,
		rows        : 10,
	} | merge(args) %}

    {% set uuid = uniqid() %}

    {{ _self.fieldstart(args.type, {class: args.class, label: args.label, uuid: uuid}) }}
    <select
        id="field-{{ uuid }}"
        name="{{ name }}"
		{% if args.object %}
			value="{{ attribute(args.object, name)|e }}"
		{% else %}
        	{% if args.value %}value="{{ args.value|e }}"{% endif %}
		{% endif %}
        {% if args.help %}aria-describedby="help-{{ uuid }}"{% endif %}
        {% if args.multiple %}multiple size="{{ args.rows }}"{% endif %}
        {% if args.required %}required{% endif %}
    >
        {# select and select-mulitple have different ways of supporting placeholders #}
        {% if args.multiple %}
            {% if args.placeholder %}
            <option disabled>{{ args.placeholder|e }}</option>
            {% endif %}
        {% else %}
            {% if args.placeholder %}
            {# <option {% if not args.value %}selected{% endif %} value="">{{ args.placeholder }}</option> #}
            <option value="">{{ args.placeholder }}</option>
            {% endif %}
        {% endif %}

        {% for option in options %}
        <option value="{{ option.value|e }}" {%if option.value == args.value %}selected{% endif %}>{{ option.label|e }}</option>
        {% endfor %}
    </select>
    {{ _self.fieldend({ help:args.help, icon:args.icon, uuid:uuid }) }}

{% endmacro %}

{# Hidden Field #}
{% macro hidden(name, args = {}) %}
	{% set args = {
		value  : "",
		object : false,
	} | merge(args) %}

    <div class="form-field hidden-field">
        <input type="hidden" name="{{ name }}"
			{% if args.object %}
				value="{{ attribute(args.object, name)|e }}"
			{% else %}
        		{% if args.value %}value="{{ args.value|e }}"{% endif %}
			{% endif %}
		>
    </div>

{% endmacro %}


