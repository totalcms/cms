{#--------------------------------#}
{% macro textForm(collection, id, args = {}) %}
	{% set object = totalcms.object(collection, id) %}
	{% set args   = args | merge({object : object}) %}

	{{ _self.start(collection, { method: 'post', id: id }) }}

		{{ _self.hidden('id', id) }}
		{% if args.input == 'textarea' %}
			{{ _self.textarea('text', args) }}
		{% else %}
			{{ _self.text('text', args) }}
		{% endif %}

	{{ _self.end() }}
{% endmacro %}
