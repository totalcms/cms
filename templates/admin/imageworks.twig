{% extends "admin-layout.twig" %}

{% macro input(name, field, label, help, value, list) %}
    {% set uuid = uniqid() %}
    <div class="form-field {{ field }}-field help-box help-on-hover help-on-focus" data-type="{{ field }}">
	    <label for="field-{{ uuid }}">{{ label }}</label>
        <div class="form-group">
			<input
				id="field-{{uuid}}"
				type="{{field}}"
				name="{{name}}"
				value="{{ value|e }}"
				aria-describedby="help-{{uuid}}"
				{% if list %}list="{{list}}"{% endif %}
			>
            <div class="form-group-icon"></div>
        </div>
        <p class="help" id="help-{{uuid}}">{{ help|raw }}</p>
    </div>
{% endmacro %}

{% macro select(name, label, help, value, options) %}
    {% set uuid = uniqid() %}
    <div class="form-field select-field help-box help-on-hover help-on-focus" data-type="select">
	    <label for="field-{{ uuid }}">{{ label }}</label>
        <div class="form-group">
			<select id="field-{{uuid}}" name="{{name}}" value="{{value|e}}" aria-describedby="help-{{uuid}}">
				<option value="" disabled>None</option>

				{% for option in options %}
				<option value="{{ option.value|e }}" {%if option.value == value %}selected{% endif %}>{{ option.label|e }}</option>
				{% endfor %}
			</select>
            <div class="form-group-icon"></div>
        </div>
        <p class="help" id="help-{{uuid}}">{{ help|raw }}</p>
    </div>
{% endmacro %}

{% block head %}
	<link rel="stylesheet" href="{{ totalcms.assetsDir }}/imageworks-builder.css"/>
{% endblock %}

{% block content %}

	{% set id         = getParams.id  %}
	{% set collection = getParams.collection | default("image") %}
	{% set property   = getParams.property | default("image") %}
	{% set values    = { w : 600, h : 400 } | merge(getParams) %}
	{% set help       = {
			w         : "Sets the width of the image, in pixels.",
			h         : "Sets the height of the image, in pixels.",
			dpr       : "The device pixel ratio is used to easily convert between CSS pixels and device pixels. " ~
				        "This makes it possible to display images at the correct pixel density on retina devices. " ~
				        "The maximum value that can be set for dpr is 8.",
			q         : "Defines the quality of the image. Use values between 0 and 100. Defaults to 90. " ~
					    "Only relevant if the format is set to jpg, pjpg, webp or avif.",
			fm        : "Encodes the image to a specific format. Accepts jpg, pjpg (progressive jpeg), " ~
					    "png, gif, webp or avif. Defaults to jpg.",
			fit       : "How the image is fitted to its target dimensions. " ~
				        "See the Fit Options Docs for more information.",
			bri       : "Adjusts the image brightness. Use values between -100 and +100, where 0 represents no change.",
			con       : "Adjusts the image contrast. Use values between -100 and +100, where 0 represents no change.",
			gam       : "Adjusts the image gamma. Use values between 0.1 and 9.99.",
			sharp     : "Sharpen the image. Use values between 0 and 100.",
			blur      : "Adds a blur effect to the image. Use values between 0 and 100.",
			pixel     : "Applies a pixelation effect to the image. Use values between 0 and 1000.",
			filt      : "Applies a filter effect to the image. Accepts greyscale or sepia.",
			mark      : "Adds a watermark to the image. The value should be the name of the image added to the " ~
				    	"configured watermarks gallery.",
			markw     : "Sets the width of the watermark in pixels or using relative dimensions. " ~
					    "For relative dimensions, 5w represents 5% of the width of the image.",
			markh     : "Sets the height of the watermark in pixels or using relative dimensions. " ~
					    "For relative dimensions, 5h represents 5% of the height of the image.",
			markfit   : "How the watermark is fitted to its target dimensions. " ~
				      	"See the Fit Options Docs for more information.",
			markpad   : "Sets the padding around the watermark in pixels or using relative dimensions. " ~
					   	"For relative dimensions, 5w represents 5% of the width of the image.",
			markalpha : "Sets the alpha of the watermark. Use values between 0 and 100.",
			markpos   : "Sets the position of the watermark. Accepts top-left, top-right, bottom-left, bottom-right, " ~
					  	"top-center, bottom-center, left-center, right-center, center.",
			bg        : "Sets the background color of the image. Accepts hex values (without hashtag) or named colors.",
			border    : "Sets the border of the image. Accepts width, color, and method. " ~
					  	"Width is in pixels, color is a hex value (without hashtag) or named color," ~
					  	" and method is overlay, shrink or expand.",
			flip      : "Flips the image. Accepts v, h and both.",
			"or" 	  : "Rotates the image. Accepts auto, 0, 90, 180 or 270. Default is auto. " ~
					  	"The auto option uses Exif data to automatically orient images correctly.",
		}
	%}

	<section class="image-preview">
    	<h1>Total CMS Image Builder</h1>
		<img src="{{ totalcms.image(id, values, collection, property) }}" oncontextmenu="return false;" draggable="false" />
		<button>Preview Image</button>
	</section>

	<form class="totalform">

		<input type="hidden" name="id" value="{{ id }}">
		<input type="hidden" name="collection" value="{{ collection }}">
		<input type="hidden" name="property" value="{{ property }}">

		<details class="cms-accordion">
			<summary>Sizing &amp; Effects</summary>
			<div>
				<section>
					{{ _self.input("w", "number", "Width", help.w, values.w) }}
					{{ _self.input("h", "number", "Height", help.h, values.h) }}
					{{ _self.input("dpr", "number", "Pixel Density", help.dpr, values.dpr) }}
					{{ _self.input("q", "number", "Quality", help.q, values.q) }}
					{{ _self.select("fm", "Format", help.fm, values.fm) }}
					{{ _self.input("fit", "text", "Fit and Crop", help.fit, values.fit, "fit-options") }}
					<button class='open-fit-docs'>Fit Options Docs</button>
				</section>
				<section>
					{{ _self.input("bri", "number", "Brightness", help.bri, values.bri) }}
					{{ _self.input("con", "number", "Contrast", help.con, values.con) }}
					{{ _self.input("sharp", "number", "Sharpen", help.sharp, values.sharp) }}
					{{ _self.input("gam", "number", "Gamma", help.gam, values.gam) }}
					{{ _self.input("blur", "number", "Blur", help.blur, values.blur) }}
					{{ _self.input("pixel", "number", "Pixelate", help.pixel, values.pixel) }}
					{{ _self.select("filt", "Filter", "Filter the image") }}
				</section>
			</div>
		</details>

		<details class="cms-accordion">
			<summary>Watermark, Background &amp; Border</summary>
			<div>
				<section>
					{{ _self.input("mark", "text", "Watermark", help.mark, values.mark) }}
					{{ _self.input("markw", "number", "Width", help.markw, values.markw) }}
					{{ _self.input("markh", "number", "Height", help.fit, values.fit) }}
					{{ _self.input("markpad", "number", "Padding", help.fit, values.fit) }}
					{{ _self.input("markalpha", "number", "Alpha", help.fit, values.fit) }}
					{{ _self.select("markpos", "Position", "Crop the image") }}
					{{ _self.input("markfit", "text", "Fit and Crop", help.markfit, values.markfit, "fit-options") }}
					<button class='open-fit-docs'>Fit Options Docs</button>
				</section>
				<section>
					{{ _self.input("bg", "text", "Background", help.bg, values.bg) }}
					{{ _self.input("border", "text", "Border", help.border, values.border) }}
				</section>
			</div>
		</details>
	</form>

	<datalist id="fit-options">
		<option value="contain"></option>
		<option value="max"></option>
		<option value="fill"></option>
		<option value="fill-max"></option>
		<option value="stretch"></option>
		<option value="crop"></option>
		<option value="crop-top"></option>
		<option value="crop-bottom"></option>
		<option value="crop-left"></option>
		<option value="crop-right"></option>
		<option value="crop-top-left"></option>
		<option value="crop-top-right"></option>
		<option value="crop-bottom-left"></option>
		<option value="crop-bottom-right"></option>
		<option value="crop-50-50"></option>
		<option value="crop-25-75-1.5"></option>
		<option value="crop-focalpoint"></option>
		<option value="crop-focalpoint-1.5"></option>
	</datalist>

	<dialog id="fit-modal" class="cms-modal">
		<h3>Fit and Crop Options</h3>
		<dl class="option-docs">
			<dt>contain</dt>
			<dd>(<em>Default</em>) Resizes the image to fit within the width and height boundaries without
			cropping, distorting or altering the aspect ratio.</dd>

			<dt>max</dt>
			<dd>Resizes the image to fit within the width and height boundaries without cropping,
			distorting or altering the aspect ratio, and will also not increase the size of the
			image if it is smaller than the output size.</dd>

			<dt>fill</dt>
			<dd>Resizes the image to fit within the width and height boundaries without cropping
			or distorting the image, and the remaining space is filled with the background color.
			The resulting image will match the constraining dimensions.</dd>

			<dt>fill-max</dt>
			<dd>Resizes the image to fit within the width and height boundaries without cropping
			but upscaling the image if it's smaller. The finished image will have remaining space
			on either width or height (except if the aspect ratio of the new image is the same as
			the old image). The remaining space will be filled with the background color. The
			resulting image will match the constraining dimensions.</dd>

			<dt>stretch</dt>
			<dd>Stretches the image to fit the constraining dimensions exactly. The resulting image
			will fill the dimensions, and will not maintain the aspect ratio of the input image.</dd>

			<dt>crop</dt>
			<dd>Resizes the image to fill the width and height boundaries and crops any excess
			image data. The resulting image will match the width and height constraints without
			distorting the image. See the crop page for more information.</dd>

			<dt>crop-<code>position</code></dt>
			<dd>You can also set where the image is cropped by adding a crop position.
			Example: <code>crop-top-left</code></dd>

			<dt>crop-<code>x</code>-<code>y</code></dt>
			<dd>You can be more specific about the exact crop position using a focal point.
			This is defined using two offset percentages: <code>crop-40-60</code>.</dd>

			<dt>crop-<code>x</code>-<code>y</code>-<code>zoom</code></dt>
			<dd>You may also choose to zoom into your focal point by providing a third value: a float
			between 1 and 100. Each full step is the equivalent of a 100% zoom. (eg. x%-y%-2 is the
			equivalent of viewing the image at 200%). The suggested range is 1-10.</dd>

			<dt>crop-focalpoint</dt>
			<dd>Since every image is different, you can store the focal point of an image into the CMS.
			when using this option, the focal point stored within the CMS for the specified image will be used.
			This is the same as defining the focal points above. However, it is dynamic since the values are
			pulled from the CMS.</dd>

			<dt>crop-focalpoint-<code>zoom</code></dt>
			<dd>Just like the explicit option above, you can zoom into the focal point that is stored
			within the CMS.</dd>
		</dl>
		<button class="close">Close</button>
	</dialog>
{% endblock %}

{% block bodyBelow %}
	<script type="module" src="{{ totalcms.assetsDir }}/imageworks-builder.js"></script>
{% endblock %}