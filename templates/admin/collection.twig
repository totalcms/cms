{% extends "admin-dashboard.twig" %}

{% set collectionIndex %}
	<h1>Collection Help</h1>
	<p>Choose a collection to edit or create a new one.</p>
{% endset %}


{% block dashcontent %}

<aside class="dash-content-sidebar">
	<header>
		<input type="search" class="filter" placeholder="Filter collections" />
	</header>

	<nav class="links">
		<ul>
			{% for collection in sortByKey(cms.collections()) %}

				<li class="schema-{{collection.schema}}">
					<a {% if url.collection == collection.id %}class="active"{% endif %}
						href="/admin/collections/{{ collection.id }}"
						title="{{ collection.description }}">{{ collection.name }}</a>
				</li>

			{% endfor %}
		</ul>
	</nav>

	<footer>
		<a class="dash-button full transparent" href="/admin/collections/new" title="Create a new collection">+ New Collection</a>
	</footer>
</aside>

<main class="dash-main-content">
	{% if url.collection is empty %}

		{% include "admin/collection-index.twig" %}

	{% elseif url.collection == "new" %}

		{# New Collection Form #}
		<h1><a href="/admin/collections">collections</a> / <span>new</span></h1>
		{{ cms.form.collection({
			save        : "Save",
			helpStyle   : 'label',
			helpOnHover : true,
			newAction : {
				"action" : "redirect-object",
				"link"   : "/admin/collections/{id}/edit"
			},
		}) }}

	{% elseif url.id is empty %}

		{# Collection Object Table #}
		<header>
			<h1><a href="/admin/collections">collections</a> / <a href="/admin/collections/{{ url.collection }}">{{ url.collection }}</a> / <span>objects</span></h1>
			<a class="dash-button transparent" href="/admin/collections/{{ url.collection }}/edit" title="Edit Collection">Edit Collection</a>
			<a class="dash-button" href="/admin/collections/{{ url.collection }}/add" title="Add new object to collection">+ New Object</a>
		</header>

		{% set objects = cms.objects(url.collection) %}
		{% if objects|length > 0 %}

			{{ cms.form.collectionTable(url.collection) }}

		{% else %}

			<p>No objects in this collection yet.</p>

		{% endif %}

	{% elseif url.id == "edit" %}

		{# Edit Collection #}
		<h1><a href="/admin/collections">collections</a> / <span>{{ url.collection }}</span></h1>
		{{ cms.form.collection({
			id          : url.collection,
			save        : "Save",
			delete      : "Delete",
			helpStyle   : 'label',
			helpOnHover : true,
			deleteAction : {
				"action" : "redirect",
				"link"   : "/admin/collections"
			},
		}) }}

	{% elseif url.id == "add" %}

		{# New Object Form #}
		<h1><a href="/admin/collections">collections</a> / <a href="/admin/collections/{{ url.collection }}">{{ url.collection }}</a> / <span>new object</span></h1>
		{% set form = cms.form.builder(url.collection, {
			save        : "Save",
			helpStyle   : 'label',
			helpOnHover : true,
			newAction : {
				"action" : "redirect-object",
				"link"   : "/admin/collections/#{url.collection}/{id}"
			},
		}) %}
		{{ form.autoBuild() }}

	{% else %}

		{# Edit Object Form #}
		<h1><a href="/admin/collections">collections</a> / <a href="/admin/collections/{{ url.collection }}">{{ url.collection }}</a> / <span>{{ url.id }}</span></h1>
		{% set form = cms.form.builder(url.collection, {
			id          : url.id,
			save        : "Save",
			delete      : "Delete",
			helpStyle   : 'label',
			helpOnHover : true,
		}) %}
		{{ form.autoBuild() }}

	{% endif %}
</main>

{% endblock %}
