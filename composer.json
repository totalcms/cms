{
  "name": "joeworkman/totalcms",
  "type": "project",
  "description": "Total CMS",
  "keywords": [
    "total-cms",
    "dynamics",
    "cms"
  ],
  "license": "Commercial",
  "require": {
    "php": "^8",
    "cakephp/chronos": "^2.2",
    "cakephp/validation": "^4.2",
    "cocur/slugify": "^4.0",
    "embed/embed": "^4.3",
    "fig/http-message-util": "^1.1",
    "glenscott/url-normalizer": "^1.4",
    "guzzlehttp/guzzle": "^7",
    "justinrainbow/json-schema": "^5.2",
    "ksubileau/color-thief-php": "^2.0",
    "league/csv": "^9.6",
    "league/flysystem": "^3.2",
    "league/fractal": "^0.20.1",
    "league/uri-parser": "^1.4",
    "michelf/php-markdown": "^1.7",
    "monolog/monolog": "^3.2",
    "nyholm/psr7": "^1.4",
    "nyholm/psr7-server": "^1.0",
    "opis/json-schema": "^2.1",
    "php-di/php-di": "^6.0",
    "selective/basepath": "^2",
    "selective/validation": "^2.0",
    "slim/php-view": "^3.1",
    "slim/slim": "^4",
    "ssnepenthe/color-utils": "^0.4.2",
    "symfony/polyfill-uuid": "^1.23",
    "symfony/property-access": "^6.1",
    "symfony/serializer": "^6.1",
    "tightenco/collect": "^9.16",
    "twig/twig": "^3.4"
  },
  "require-dev": {
    "friendsofphp/php-cs-fixer": "^3.0",
    "mikey179/vfsstream": "^1.6",
    "overtrue/phplint": "^5.3",
    "phpstan/phpstan": "^1.8",
    "phpunit/phpunit": "^9.0",
    "selective/test-traits": "^2.0",
    "squizlabs/php_codesniffer": "^3.5",
    "symfony/var-dumper": "^6.1"
  },
  "config": {
    "process-timeout": 0,
    "sort-packages": true
  },
  "autoload": {
    "psr-4": {
      "App\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "App\\Test\\": "tests/"
    }
  },
  "scripts": {
    "build": "artifact build --name=dynamics",
    "cs:check": "php-cs-fixer fix --dry-run --format=txt --verbose --diff --config=.cs.php",
    "cs:fix": "php-cs-fixer fix --config=.cs.php",
    "lint": "phplint ./ --exclude=vendor --no-interaction --no-cache",
    "phoenix": "phoenix",
    "stan": "phpstan analyse -c phpstan.neon --no-progress --ansi",
    "schema:dump": "php bin/console.php schema-dump",
    "sniffer:check": "phpcs --standard=phpcs.xml",
    "sniffer:fix": "phpcbf --standard=phpcs.xml",
    "test": "phpunit --configuration phpunit.xml --do-not-cache-result --colors=always",
    "test:all": [
      "@lint",
      "@cs:check",
      "@sniffer:check",
      "@stan",
      "@test"
    ],
    "test:coverage": "php -d xdebug.mode=coverage -r \"require 'vendor/bin/phpunit';\" -- --configuration phpunit.xml --do-not-cache-result --colors=always --coverage-clover build/logs/clover.xml --coverage-html build/coverage"
  }
}
