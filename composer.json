{
  "name": "joeworkman/totalcms",
  "type": "project",
  "version": "3.0.9",
  "description": "Total CMS",
  "keywords": [
    "total-cms",
    "dynamics",
    "cms"
  ],
  "license": "Commercial",
  "repositories": [
	{ "type": "vcs", "url": "https://github.com/joeworkman-forks/slim-test" },
	{ "type": "vcs", "url": "https://github.com/joeworkman-forks/pest-plugin-slim" }
  ],
  "require": {
    "php": ">=8.2",
    "bacon/bacon-qr-code": "^3.0",
    "cakephp/chronos": "^3.0",
    "cakephp/validation": "^5.0",
    "cocur/slugify": "^4.0",
    "embed/embed": "^4.3",
    "erusev/parsedown": "^1.7",
    "erusev/parsedown-extra": "^0.8.1",
    "fakerphp/faker": "^1.23",
    "fig/http-message-util": "^1.1",
    "froala/wysiwyg-editor-php-sdk": "^4.0",
    "glenscott/url-normalizer": "^1.4",
    "guzzlehttp/guzzle": "^7",
    "halaxa/json-machine": "^1.1",
    "illuminate/collections": "^10.48",
    "khanzadimahdi/uploadmanager": "^1.0",
    "ksubileau/color-thief-php": "^2.0",
    "league/csv": "^9.6",
    "league/flysystem": "^3.2",
    "league/fractal": "^0.20.1",
    "league/glide": "^2.2",
    "league/uri": "^7.4",
    "lychee-org/php-exif": "^1.0",
    "matthieumastadenis/couleur": "^0.1.2",
    "middlewares/trailing-slash": "^2.0",
    "monolog/monolog": "^3.2",
    "nyholm/psr7": "^1.4",
    "nyholm/psr7-server": "^1.0",
    "odan/session": "^6.1",
    "opis/json-schema": "^2.3",
    "php-di/php-di": "^7.0",
    "selective/basepath": "^2",
    "selective/validation": "^2.0",
    "sentry/sentry": "^4.8",
    "slim/php-view": "^3.1",
    "slim/psr7": "^1.5",
    "slim/slim": "^4",
    "slim/twig-view": "^3.3",
    "ssnepenthe/color-utils": "^0.4.2",
    "symfony/polyfill-uuid": "^1.23",
    "symfony/property-access": "^7.1",
    "symfony/serializer": "^7.1",
    "twig/extra-bundle": "^3.6",
    "twig/twig": "^3.10",
    "webuni/front-matter": "^2.0"
  },
  "require-dev": {
    "friendsofphp/php-cs-fixer": "^3.0",
    "mikey179/vfsstream": "^1.6",
    "nekofar/pest-plugin-slim": "dev-develop",
    "nekofar/slim-test": "dev-develop",
    "overtrue/phplint": "^9.0",
    "pestphp/pest": "^2.16",
    "pestphp/pest-plugin-arch": "^2.3",
    "pestphp/pest-plugin-faker": "^2.0",
    "pestphp/pest-plugin-type-coverage": "^2.2",
    "phpmd/phpmd": "^2.12",
    "phpstan/phpstan": "^1.8",
    "phpunit/phpunit": "^10.5",
    "selective/test-traits": "^4.1",
    "spatie/pest-plugin-snapshots": "^2.0",
    "squizlabs/php_codesniffer": "^3.5",
    "symfony/var-dumper": "^7.1"
  },
  "config": {
    "process-timeout": 0,
    "sort-packages": true,
    "allow-plugins": {
      "pestphp/pest-plugin": true
    }
  },
  "autoload": {
    "psr-4": {
      "TotalCMS\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "TotalCMS\\Test\\": "tests/"
    }
  },
  "scripts": {
    "esbuild": "yarn build",
    "build": "artifact build --name=totalcms",
    "cs:check": "php-cs-fixer fix --dry-run --format=txt --verbose --diff --config=.php-cs-fixer.php",
    "cs:fix": "php-cs-fixer fix --config=.php-cs-fixer.php",
    "lint": "phplint ./ --exclude=vendor --no-interaction --no-cache",
    "stan": "phpstan analyse -c phpstan.neon --no-progress --ansi --memory-limit 1G",
    "md:src": "phpmd src ansi phpmd.xml",
    "md:config": "phpmd config ansi phpmd.xml",
    "md:tests": "phpmd tests ansi phpmd.xml",
    "schema:dump": "php bin/console.php schema-dump",
    "sniffer:check": "phpcs --standard=phpcs.xml",
    "sniffer:fix": "phpcbf --standard=phpcs.xml",
    "test": "pest --display-notices --display-warnings --display-errors --display-deprecations",
    "test:coverage": "pest --type-coverage",
    "test:updatesnaps": "pest --update-snapshots",
    "md": [
      "@md:src",
      "@md:config",
      "@md:tests"
    ],
    "test:all": [
      "@lint",
      "@cs:check",
      "@stan",
      "@md",
      "@test",
      "@test:coverage"
    ],
    "test:build": [
      "@cs:check",
      "@stan",
      "@test"
    ]
  }
}
