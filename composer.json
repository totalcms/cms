{
  "name": "joeworkman/totalcms",
  "type": "project",
  "description": "Total CMS",
  "keywords": [
    "total-cms",
    "dynamics",
    "cms"
  ],
  "license": "Commercial",
  "require": {
    "php": "^8",
    "cakephp/chronos": "^2.2",
    "cocur/slugify": "^4.0",
    "glenscott/url-normalizer": "^1.4",
    "guzzlehttp/guzzle": "^7",
    "justinrainbow/json-schema": "^5.2",
    "ksubileau/color-thief-php": "^1.3",
    "league/csv": "^9.6",
    "league/flysystem": "^2",
    "league/fractal": "^0.19.2",
    "league/uri-parser": "^1.4",
    "michelf/php-markdown": "^1.7",
    "monolog/monolog": "^2.0",
    "nyholm/psr7": "^1.4",
    "nyholm/psr7-server": "^1.0",
    "opis/json-schema": "^2.1",
    "php-di/php-di": "^6.0",
    "selective/array-reader": "^1.1",
    "selective/basepath": "^2",
    "selective/config": "^1.1",
    "selective/validation": "^1.1",
    "slim/slim": "^4",
    "ssnepenthe/color-utils": "^0.4.2"
  },
  "require-dev": {
    "friendsofphp/php-cs-fixer": "^3.0",
    "overtrue/phplint": "^3",
    "phpstan/phpstan": "0.*",
    "phpunit/phpunit": "^9.0",
    "squizlabs/php_codesniffer": "^3.5",
    "symfony/var-dumper": "^5.1"
  },
  "config": {
    "process-timeout": 0,
    "sort-packages": true
  },
  "autoload": {
    "psr-4": {
      "App\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "App\\Test\\": "tests/"
    }
  },
  "scripts": {
    "build": "artifact build --name=dynamics",
    "check-all": [
      "@lint",
      "@cs:check",
      "@sniffer:check",
      "@phpstan",
      "@test:coverage"
    ],
    "cs:check": "php-cs-fixer fix --dry-run --format=txt --verbose --diff --config=.cs.php",
    "cs:fix": "php-cs-fixer fix --config=.cs.php",
    "lint": "phplint ./ --exclude=vendor --no-interaction --no-cache",
    "migrate": "phinx migrate -c config/phinx.php --ansi",
    "phpstan": "phpstan analyse src tests --level=max -c phpstan.neon --no-progress --ansi",
    "sniffer:check": "phpcs --standard=phpcs.xml",
    "sniffer:fix": "phpcbf --standard=phpcs.xml",
    "start": "php -S localhost:8080 -t public",
    "test": "phpunit --configuration phpunit.xml --do-not-cache-result --colors=always",
    "test:coverage": "phpunit --colors=always --do-not-cache-result --configuration phpunit.xml --coverage-clover build/logs/clover.xml --coverage-html build/coverage",
    "watch": "npx webpack --watch"
  }
}
