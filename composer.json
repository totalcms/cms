{
  "name": "joeworkman/totalcms",
  "type": "project",
  "description": "Total CMS",
  "keywords": [
    "total-cms",
    "dynamics",
    "cms"
  ],
  "license": "Commercial",
  "require": {
    "php": "^8",
    "cocur/slugify": "^4.0",
    "dusank/knapsack": "^10.0",
    "ellipsesynergie/api-response": "^0.16.0",
    "embed/embed": "^4.3",
    "glenscott/url-normalizer": "^1.4",
    "guzzlehttp/guzzle": "^7",
    "imagine/imagine": "^1.2",
    "justinrainbow/json-schema": "^5.2",
    "ksubileau/color-thief-php": "^1.3",
    "laminas/laminas-feed": "^2.12",
    "league/csv": "^9.6",
    "league/factory-muffin": "^3.2",
    "league/factory-muffin-faker": "^2.2",
    "league/flysystem": "^2",
    "league/fractal": "^0.19.2",
    "league/glide": "^2",
    "league/uri-parser": "^1.4",
    "mibe/feedwriter": "^1.1",
    "michelf/php-markdown": "^1.7",
    "monolog/monolog": "^2.0",
    "nesbot/carbon": "^2.34",
    "opis/json-schema": "^2.1",
    "php-di/php-di": "^6.0",
    "phpmailer/phpmailer": "^6.1",
    "selective/array-reader": "^1.1",
    "selective/basepath": "^2",
    "selective/config": "^1.1",
    "selective/samesite-cookie": "^0.3.0",
    "selective/validation": "^1.1",
    "slim/http": "^1",
    "slim/psr7": "^1",
    "slim/slim": "^4",
    "slim/twig-view": "^3",
    "ssnepenthe/color-utils": "^0.4.2",
    "symfony/http-foundation": "^5.0",
    "symfony/property-access": "^5.0",
    "symfony/serializer": "^5.0",
    "symfony/yaml": "^5.0",
    "thepixeldeveloper/sitemap": "^5",
    "tightenco/collect": "^8",
    "tuupola/http-factory": "^1.1",
    "twig/twig": "^3.0",
    "webmozart/assert": "^1.8"
  },
  "require-dev": {
    "friendsofphp/php-cs-fixer": "^3.0",
    "league/color-extractor": "^0.3.2",
    "mexitek/phpcolors": "dev-master",
    "overtrue/phplint": "^3",
    "php-parallel-lint/php-console-color": "^1.0",
    "php-parallel-lint/php-console-highlighter": "0.*",
    "php-parallel-lint/php-parallel-lint": "^1.1",
    "phpstan/phpstan": "0.*",
    "phpstan/phpstan-webmozart-assert": "^0.12.4",
    "phpunit/phpunit": "^9.0",
    "squizlabs/php_codesniffer": "^3.5",
    "symfony/var-dumper": "^5.1"
  },
  "config": {
    "process-timeout": 0,
    "sort-packages": true
  },
  "autoload": {
    "psr-4": {
      "App\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "App\\Test\\": "tests/"
    }
  },
  "scripts": {
    "build": "artifact build --name=dynamics",
    "check-all": [
      "@lint",
      "@cs:check",
      "@sniffer:check",
      "@phpstan",
      "@test:coverage"
    ],
    "cs:check": "php-cs-fixer fix --dry-run --format=txt --verbose --diff --config=.cs.php",
    "cs:fix": "php-cs-fixer fix --config=.cs.php",
    "lint": "phplint ./ --exclude=vendor --no-interaction --no-cache",
    "migrate": "phinx migrate -c config/phinx.php --ansi",
    "phpstan": "phpstan analyse src tests --level=max -c phpstan.neon --no-progress --ansi",
    "sniffer:check": "phpcs --standard=phpcs.xml",
    "sniffer:fix": "phpcbf --standard=phpcs.xml",
    "start": "php -S localhost:8080 -t public",
    "test": "phpunit --configuration phpunit.xml --do-not-cache-result --colors=always",
    "test:coverage": "phpunit --colors=always --do-not-cache-result --configuration phpunit.xml --coverage-clover build/logs/clover.xml --coverage-html build/coverage",
    "watch": "npx webpack --watch"
  }
}
