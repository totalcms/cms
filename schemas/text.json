{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://www.totalcms.co/schemas/text.json",
    "description": "A schema for a Total CMS Text object",
    "type": "object",
    "properties": {
        "id": {
            "$ref"  : "https://www.totalcms.co/schemas/properties/slug.json",
            "label" : "Text ID",
            "help"  : "A unique ID for this text. No spaces or special characters.",
            "field" : "slug"
        },
        "text": {
            "type"  : "string",
            "label" : "Text",
            "help"  : "Edit the text here.",
            "field" : "textarea"
        }
    },
    "required": [
        "id",
        "text"
    ],
    "index": [
        "id"
    ],
    "form": {
        "id": {
            "label" : "Text ID",
            "help"  : "A unique ID for this text. No spaces or special characters.",
            "type"  : "slug"
        },
        "text": {
            "label"   : "Text",
            "help"    : "Edit the text here.",
            "type"    : "textarea",
            "default" : "This is the default text."
        }
    }
}
