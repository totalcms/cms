{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://www.totalcms.co/schemas/number.json",
    "description": "A schema for a Total CMS Number object",
    "type": "object",
    "properties": {
        "id": {
            "$ref": "https://www.totalcms.co/schemas/properties/slug.json",
            "label" : "Number ID",
            "help"  : "A unique ID for this number. No spaces or special characters.",
            "field" : "slug"
        },
        "number": {
            "type"     : "number"
        }
    },
    "required": [
        "id",
        "number"
    ],
    "index": [
        "id"
    ]
}
