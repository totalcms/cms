{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://www.totalcms.co/schemas/schema.json#",
  "description": "A schema for a Total CMS schema file",
  "properties": {
    "$id": {
      "type": "string",
      "format": "uri"
    },
    "$schema": {
      "type": "string",
      "format": "uri"
    },
    "properties": {
      "type": "object"
    },
    "description": {
      "type": "string"
    },
    "type": {
      "type": "string"
    },
    "required": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "index": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "index": [],
  "type": "object",
  "required": [
    "$id",
    "description",
    "index",
    "properties",
    "required",
    "type"
  ]
}
