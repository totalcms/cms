{
	"$schema"     : "https://json-schema.org/draft/2020-12/schema",
	"$id"         : "https://www.totalcms.co/schemas/schema.json",
	"id"          : "schema",
	"type"        : "object",
	"description" : "A schema for a Total CMS schema file",
	"properties"  : {
		"$id": {
			"type"   : "string",
			"format" : "uri"
		},
		"$schema": {
			"type"   : "string",
			"format" : "uri"
		},
		"properties": {
			"$ref" : "https://www.totalcms.co/schemas/properties/properties.json"
		},
		"description": {
			"type" : "string"
		},
		"type": {
			"type" : "string"
		},
		"required": {
			"type"     : "array",
			"minItems" : 1,
			"items"    : {
				"type" : "string"
			}
		},
		"index": {
			"type"     : "array",
			"minItems" : 1,
			"items"    : {
				"type" : "string"
			}
		}
	},
	"required": [
		"$schema",
		"$id",
		"type",
		"description",
		"properties",
		"required",
		"index"
	],
	"index" : [
		"id"
	]
}