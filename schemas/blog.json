{
	"$schema"     : "https://json-schema.org/draft/2020-12/schema",
	"$id"         : "https://www.totalcms.co/schemas/blog.json",
	"id"          : "blog",
	"type"        : "object",
	"description" : "A schema for a Total CMS Blog object",
	"properties"  : {
		"id": {
			"$ref"     : "https://www.totalcms.co/schemas/properties/slug.json",
			"label"    : "Blog Post ID",
			"help"     : "A unique ID for this post. No spaces or special characters.",
			"field"    : "id",
			"factory"  : "slug",
			"settings" : { "autogen" : "${title}" }
		},
		"content": {
			"type"    : "string",
			"label"   : "Content",
			"help"    : "Main blog post content",
			"field"   : "textarea",
			"factory" : "paragraph",
			"default" : ""
		},
		"labels": {
			"$ref"    : "https://www.totalcms.co/schemas/properties/list.json",
			"label"   : "Labels",
			"help"    : "A list of labels for this post",
			"field"   : "list",
			"factory" : "tags",
			"settings": { "propertyOptions" : true },
			"default" : []
		},
		"extra": {
			"type"    : "string",
			"label"   : "Extra Content",
			"help"    : "Extra content area for this post",
			"field"   : "textarea",
			"default" : ""
		},
		"title": {
			"type"    : "string",
			"label"   : "Title",
			"help"    : "Blog Post title",
			"field"   : "text",
			"factory" : "catchPhrase"
		},
		"tags": {
			"$ref"    : "https://www.totalcms.co/schemas/properties/list.json",
			"label"   : "Tags",
			"help"    : "A list of tags for this post",
			"field"   : "list",
			"factory" : "tags",
			"default" : []
		},
		"summary": {
			"type"    : "string",
			"label"   : "Summary",
			"help"    : "Blog Post summary",
			"field"   : "textarea",
			"factory" : "paragraph",
			"default" : ""
		},
		"image": {
			"$ref"    : "https://www.totalcms.co/schemas/properties/image.json",
			"label"   : "Image",
			"help"    : "Main image for this post",
			"field"   : "image",
			"factory" : "imageShapes(1920,1080)",
			"default" : {}
		},
		"archived": {
			"type"    : "boolean",
			"label"   : "Archived",
			"help"    : "Mark this post as archived",
			"field"   : "checkbox",
			"default" : false
		},
		"media": {
			"$ref"    : "https://www.totalcms.co/schemas/properties/url.json",
			"label"   : "Media",
			"help"    : "Media URL for this post",
			"field"   : "text",
			"default" : ""
		},
		"updated": {
			"$ref"    : "https://www.totalcms.co/schemas/properties/date.json",
			"label"   : "Updated Date",
			"help"    : "Blog Post updated date",
			"field"   : "hidden",
			"factory" : "iso8601",
			"default" : "onUpdate"
		},
		"date": {
			"$ref"    : "https://www.totalcms.co/schemas/properties/date.json",
			"label"   : "Date",
			"help"    : "Blog Post date",
			"field"   : "date",
			"factory" : "iso8601"
		},
		"created": {
			"$ref"    : "https://www.totalcms.co/schemas/properties/date.json",
			"label"   : "Creation Date",
			"help"    : "Blog Post creation date",
			"field"   : "hidden",
			"factory" : "iso8601",
			"default" : "onCreate"
		},
		"extra2": {
			"type"    : "string",
			"label"   : "Extra Content 2",
			"help"    : "Extra content area for this post",
			"field"   : "textarea",
			"default" : ""
		},
		"draft": {
			"type"    : "boolean",
			"label"   : "Draft",
			"help"    : "Mark this post as a draft",
			"field"   : "checkbox",
			"default" : false
		},
		"genre": {
			"type"    : "string",
			"label"   : "Genre",
			"help"    : "Genre for this post",
			"field"   : "text",
			"default" : ""
		},
		"gallery": {
			"$ref"    : "https://www.totalcms.co/schemas/properties/gallery.json",
			"label"   : "Gallery",
			"help"    : "Gallery of images for this post",
			"field"   : "gallery",
			"default" : []
		},
		"featured": {
			"type"    : "boolean",
			"label"   : "Featured",
			"help"    : "Mark this post as featured",
			"field"   : "checkbox",
			"factory" : "numberBetween(0,1)",
			"default" : false
		},
		"categories": {
			"$ref"    : "https://www.totalcms.co/schemas/properties/list.json",
			"label"   : "Categories",
			"help"    : "A list of categories for this post",
			"field"   : "list",
			"factory" : "tags",
			"default" : []
		},
		"author": {
			"type"    : "string",
			"label"   : "Author",
			"help"    : "Author for this post",
			"field"   : "text",
			"factory" : "name",
			"default" : ""
		}
	},
	"required": [
		"archived",
		"author",
		"categories",
		"content",
		"date",
		"draft",
		"extra",
		"extra2",
		"featured",
		"gallery",
		"genre",
		"id",
		"image",
		"labels",
		"media",
		"summary",
		"tags",
		"title",
		"updated",
		"created"
	],
	"index": [
		"archived",
		"author",
		"categories",
		"date",
		"draft",
		"featured",
		"genre",
		"id",
		"image",
		"labels",
		"summary",
		"tags",
		"title",
		"updated",
		"created"
	]
}