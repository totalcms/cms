{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "description": "Image object with supplemental data about the image",
  "properties": {
    "rating": {
      "$comment": "The rating of the image",
      "$ref": "https://www.totalcms.co/schemas/properties/rating.json"
    },
    "uploadDate": {
      "$comment": "The date the image was uploaded",
      "$ref": "https://www.totalcms.co/schemas/properties/date.json"
    },
    "featured": {
      "default": false,
      "$comment": "Set the image as featured",
      "type": "boolean"
    },
    "exif": {
      "type": "object",
      "$comment": "The EXIF data extracted from the image",
      "properties": {
        "author": {
          "type": "string"
        },
        "copyright": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "aperture": {
          "type": "number"
        },
        "altitude": {
          "type": "number"
        },
        "longitude": {
          "type": "number"
        },
        "latitude": {
          "type": "number"
        },
        "title": {
          "type": "string"
        },
        "date": {
          "$ref": "https://www.totalcms.co/schemas/properties/date.json"
        },
        "shutterSpeed": {
          "type": "string"
        },
        "make": {
          "type": "string"
        },
        "camera": {
          "type": "string"
        },
        "lens": {
          "type": "string"
        },
        "focalLength": {
          "type": "number"
        },
		"iso": {
          "type": "number"
        }
      }
    },
    "alt": {
      "type": "string",
      "$comment": "The alt text to be used for the image"
    },
    "name": {
      "type": "string",
      "$comment": "The name of the image"
    },
    "width": {
      "type": "integer"
    },
    "height": {
      "type": "integer"
    },
    "link": {
      "$comment": "A URL to be associated with this image",
      "$ref": "https://www.totalcms.co/schemas/properties/url.json"
    },
    "focalpoint": {
      "type": "object",
      "properties": {
        "x": {
          "minimum": 0,
          "default": 50,
          "type": "integer",
          "maximum": 100
        },
        "y": {
          "minimum": 0,
          "default": 50,
          "type": "integer",
          "maximum": 100
        }
      },
      "$comment": "The focal point of the image. This is used while cropping the image so that the focal point is captured in the center"
    },
    "mime": {
      "type": "string",
      "$comment": "The type of image: jpg, png, webp, gif",
      "enum": [
        "image/gif",
        "image/jpeg",
        "image/pjpeg",
        "image/png",
        "image/webp",
        "image/avif",
        ""
      ]
    },
    "size": {
      "minimum": 0,
      "$comment": "The filesize of the file in bytes",
      "type": "integer"
    },
    "tags": {
      "$comment": "Tags associated with the image",
      "$ref": "https://www.totalcms.co/schemas/properties/list.json"
    },
    "palette": {
		"$comment": "The color palette extracted from the image. Two palettes are stored with a max of 6 hexidecimal color strings for primary and secondary colors",
      	"type": "array",
	  	"maxContains": 5,
	  	"items": {
			"pattern": "^#([0-9a-fA-F]{3}|[0-9a-fA-F]{6})$"
	  	}
    }
  },
  "required": [
    "alt",
    "exif",
    "featured",
    "focalpoint",
    "link",
    "tags"
  ],
  "type": "object",
  "examples": [
    {
      "rating": {
        "counts": [
          "0",
          "0",
          "2",
          "5",
          "3"
        ],
        "max": 5,
        "total": 10,
        "rating": 4.5
      },
      "uploadDate": "2018-08-02T08:59:28+00:00",
      "featured": false,
      "alt": "Alt Text",
      "exif": {
        "rating": "",
        "iso": "",
        "caption": "",
        "aperture": "",
        "longitude": 0,
        "width": 512,
        "latitude": 0,
        "exposureBias": "",
        "title": "",
        "date": "",
        "shutterSpeed": "",
        "height": 512,
        "make": "",
        "model": "",
        "copyright": "",
        "focalLength": ""
      },
      "focalpoint": {
        "y": 75,
        "x": 25
      },
      "link": "https://example.com/page/",
      "type": "jpg",
      "tags": [
        "tag1",
        "tag2"
      ],
      "palette": [
          "1e140e",
          "7d3012",
          "8f9217",
          "c3bc25",
          "c61d1d",
          "e68685"
      ]
    }
  ],
  "$id": "https://www.totalcms.co/schemas/properties/image.json"
}