{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "description": "File object with supplemental data about the file",
  "properties": {
    "tags": {
      "$comment": "Tags associated with the file",
      "$ref": "https://www.totalcms.co/schemas/properties/list.json"
    },
    "password": {
      "$comment": "If the file is set to be protected, what is the passphrase in order to access it",
      "$ref": "https://www.totalcms.co/schemas/properties/password.json"
    },
    "protected": {
      "default": false,
      "$comment": "Flag to enable password protection on the file",
      "type": "boolean"
    },
    "mime": {
      "type": "string",
      "$comment": "The file mime type"
    },
    "comments": {
      "type": "string",
      "$comment": "Comments for this file"
    },
    "size": {
      "minimum": 0,
      "$comment": "The filesize of the file in bytes",
      "type": "integer"
    },
    "label": {
      "type": "string",
      "$comment": "A user defined label/comment about this file"
    },
    "name": {
      "type": "string",
      "$comment": "The name of the file including the extension"
    },
    "uploadDate": {
      "$comment": "The date the file was uploaded",
      "$ref": "https://www.totalcms.co/schemas/properties/date.json"
    }
  },
  "type": "object",
  "required": [
    "mime",
    "name",
    "label",
    "protected",
    "size",
    "tags"
  ],
  "examples": [
    {
      "uploadDate": "2018-08-02T08:59:28+00:00",
      "password": "password",
      "protected": false,
      "mime": "zip",
      "size": 1234556,
      "label": "My File",
      "tags": [
        "tag1",
        "tag2"
      ],
      "name": "file.zip"
    }
  ],
  "$id": "https://www.totalcms.co/schemas/properties/file.json"
}