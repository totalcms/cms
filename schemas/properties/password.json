{
	"$schema" : "https://json-schema.org/draft/2020-12/schema",
	"$id"     : "https://www.totalcms.co/schemas/properties/password.json",
	"anyOf"   : [
		{
			"pattern"     : "^\\S*$",
			"description" : "An encrypted password hash. The password sent with the request will be encrypted and stored in this field.",
			"type"        : "string",
			"examples"    : [
				"$2y$10$.vGA1O9wmRjrwAVXD98HNOgsNpDczlqm3Jq7KnEd1rVAGv3Fykk1a"
			]
		},
		{
			"$ref" : "https://www.totalcms.co/schemas/properties/empty.json"
		}
	]
}