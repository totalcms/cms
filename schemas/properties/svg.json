				"<svg height=\"100\" width=\"100\"><circle cx=\"50\" cy=\"50\" r=\"40\" fill=\"red\"/></svg>"
			]
		},
		{
			"$ref" : "https://www.totalcms.co/schemas/properties/empty.json"
		}
	]
}