{
	"$schema" : "https://json-schema.org/draft/2020-12/schema",
	"$id"     : "https://www.totalcms.co/schemas/properties/svg.json",
	"anyOf"   : [
		{
			"pattern"     : "^\\s*<svg",
			"type"        : "string",
			"description" : "A field for storing SVG images",
