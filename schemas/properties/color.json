{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "description": "Colors are stored in hsla(). If the alpha channel is not supplied, it will default to 1",
  "properties": {
    "s": {
      "$comment": "The saturation channel. Float value 0-100",
      "minimum": 0,
      "type": "number",
      "maximum": 100
    },
    "l": {
      "$comment": "The lightness channel. Float value 0-100",
      "minimum": 0,
      "type": "number",
      "maximum": 100
    },
    "a": {
      "$comment": "The alpha channel. Float value 0-1",
      "minimum": 0,
      "default": 1,
      "type": "number",
      "maximum": 1
    },
    "h": {
      "$comment": "The hue channel. Float value 0-360",
      "minimum": 0,
      "type": "number",
      "maximum": 360
    }
  },
  "type": "object",
  "required": [
    "h",
    "s",
    "l",
    "a"
  ],
  "examples": [
    {
      "l": 360,
      "s": 79,
      "a": 1,
      "h": 36
    }
  ],
  "$id": "https://www.totalcms.co/schemas/properties/color.json#"
}