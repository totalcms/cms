    "updates": [
        {
            "version": "1.0.0",
            "date": "2017-03-02T00:00:00+00:00",
            "notes": "<ul><li>Initial Public Release<\/li><\/ul>"
        },
        {
            "version": "1.1.0",
            "date": "2017-04-20T00:00:00+00:00",
            "notes": "<ul><li>New Agent Preview stack now allows you to centrally manage preview settings for all Agent and Agent Query stacks. You can add multiple preview stacks to the page if you need to control multiple Agent Query stacks. There are still local override options inside each stack as well.<\/li><\/ul>"
        },
        {
            "version": "1.2.0",
            "date": "2017-04-26T00:00:00+00:00",
            "notes": "<ul><li>New Agent Redirect stack allows you to redirect to a URL based on the visitor\u2019s device<\/li><\/ul>"
        },
        {
            "version": "1.3.0",
            "date": "2017-09-05T00:00:00+00:00",
            "notes": "<ul><li>New Agent Lang stack makes it super easy to localize your website. Create custom content for each language defined.<\/li><li>New Compatibility Mode for the Agent and Agent URL stack. It is possible that some stacks may break (usually because of JS errors) when Agent hides them from the page. Compatibility mode should resolve this. However, it does mean that all content will be downlaoded to the device. Agent will properly set the visibility on the content to ensure that the correct data is in fact displayed. If one of our stacks needs to be placed into compatibility mode, please let us know so that we can try to get this fixed in an update.<\/li><\/ul>"
        },
        {
            "version": "1.3.1",
            "date": "2017-09-06T00:00:00+00:00",
            "notes": "<ul><li>Dumb dev mistake in last build. Oops.<\/li><li>Agent Preview now works on all Agent stacks at once. Not one at a time.<\/li><\/ul>"
        },
        {
            "version": "1.3.2",
            "date": "2017-09-08T00:00:00+00:00",
            "notes": "<ul><li>Agent Land now has every language code that you could imagine inside the language options<\/li><\/ul>"
        },
        {
            "version": "1.3.3",
            "date": "2017-09-10T00:00:00+00:00",
            "notes": "<ul><li>Added Luxembourgish (lu) to Agent Lang<\/li><\/ul>"
        },
        {
            "version": "1.3.4",
            "date": "2018-08-30T00:00:00+00:00",
            "notes": "<ul><li>Fix for checking for multiple updates<\/li><\/ul>"
        }
    ]
