<nav style="background: #f8f9fa; padding: 1rem;">
	<div class="container" style="display: flex; justify-content: space-between; align-items: center;">
		<a href="/" style="font-weight: 700; text-decoration: none; color: #333;">{{ cms.config('domain') }}</a>
		<ul style="list-style: none; display: flex; gap: 1.5rem;">
			{% set pages = cms.collection.objects('builder-pages', {sort: 'sort:asc'}) %}
			{% for page in pages %}
				{% if not page.draft %}
				<li><a href="{{ page.route }}" style="text-decoration: none; color: #555;">{{ page.title }}</a></li>
				{% endif %}
			{% endfor %}
		</ul>
	</div>
</nav>
