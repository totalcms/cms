{% extends 'layouts/default.twig' %}

{% block title %}Contact — {{ cms.config('domain') }}{% endblock %}
{% block description %}Get in touch to discuss your next project.{% endblock %}

{% block content %}
<section class="section">
	<div class="container" style="max-width: 640px;">
		<h1>Let's Talk</h1>
		<p>Have a project in mind? I would love to hear about it. Drop me a message and I will get back to you soon.</p>

		<form style="margin-top: 2rem; display: flex; flex-direction: column; gap: 1.25rem;">
			<label>
				<span style="display: block; margin-bottom: 0.25rem; font-weight: 500; color: #333;">Name</span>
				<input type="text" name="name" required style="width: 100%; padding: 0.625rem; border: 1px solid #d1d5db; border-radius: 6px; font-size: 1rem;">
			</label>
			<label>
				<span style="display: block; margin-bottom: 0.25rem; font-weight: 500; color: #333;">Email</span>
				<input type="email" name="email" required style="width: 100%; padding: 0.625rem; border: 1px solid #d1d5db; border-radius: 6px; font-size: 1rem;">
			</label>
			<label>
				<span style="display: block; margin-bottom: 0.25rem; font-weight: 500; color: #333;">Tell me about your project</span>
				<textarea name="message" rows="6" required style="width: 100%; padding: 0.625rem; border: 1px solid #d1d5db; border-radius: 6px; font-size: 1rem;"></textarea>
			</label>
			<button type="submit" style="padding: 0.75rem 2rem; background: #111; color: #fff; border: none; border-radius: 6px; cursor: pointer; font-size: 1rem; align-self: flex-start;">Send Message</button>
		</form>
	</div>
</section>
{% endblock %}
