<nav style="padding: 1.5rem 0;">
	<div class="container" style="display: flex; justify-content: space-between; align-items: center;">
		<a href="/" style="font-weight: 800; font-size: 1.25rem; text-decoration: none; color: #111; letter-spacing: -0.02em;">{{ cms.config('domain') }}</a>
		<ul style="list-style: none; display: flex; gap: 2rem;">
			{% set pages = cms.collection.objects('builder-pages', {sort: 'sort:asc'}) %}
			{% for page in pages %}
				{% if not page.draft %}
				<li><a href="{{ page.route }}" style="text-decoration: none; color: #555; font-weight: 500;">{{ page.title }}</a></li>
				{% endif %}
			{% endfor %}
		</ul>
	</div>
</nav>
