{% extends 'layouts/default.twig' %}

{% block title %}Contact — {{ cms.config('domain') }}{% endblock %}
{% block description %}Get in touch with us.{% endblock %}

{% block content %}
<section class="section">
	<div class="container" style="max-width: 640px;">
		<h1>Contact Us</h1>
		<p>Have a question or want to work together? We would love to hear from you.</p>

		<form style="margin-top: 2rem; display: flex; flex-direction: column; gap: 1rem;">
			<label>
				<span style="display: block; margin-bottom: 0.25rem; font-weight: 500;">Name</span>
				<input type="text" name="name" required style="width: 100%; padding: 0.5rem; border: 1px solid #d1d5db; border-radius: 4px;">
			</label>
			<label>
				<span style="display: block; margin-bottom: 0.25rem; font-weight: 500;">Email</span>
				<input type="email" name="email" required style="width: 100%; padding: 0.5rem; border: 1px solid #d1d5db; border-radius: 4px;">
			</label>
			<label>
				<span style="display: block; margin-bottom: 0.25rem; font-weight: 500;">Message</span>
				<textarea name="message" rows="5" required style="width: 100%; padding: 0.5rem; border: 1px solid #d1d5db; border-radius: 4px;"></textarea>
			</label>
			<button type="submit" style="padding: 0.75rem 1.5rem; background: #2563eb; color: #fff; border: none; border-radius: 4px; cursor: pointer; font-size: 1rem;">Send Message</button>
		</form>
	</div>
</section>
{% endblock %}
