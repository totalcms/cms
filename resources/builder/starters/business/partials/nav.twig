		<a href="/" style="font-weight: 700; font-size: 1.25rem; text-decoration: none; color: #111;">{{ cms.config('domain') }}</a>
		<ul style="list-style: none; display: flex; gap: 2rem;">
			{% for p in cms.builder.nav() %}
