<nav style="background: #fff; border-bottom: 1px solid #e5e7eb; padding: 1rem 0;">
	<div class="container" style="display: flex; justify-content: space-between; align-items: center;">
		<a href="/" style="font-weight: 700; font-size: 1.25rem; text-decoration: none; color: #111;">{{ cms.config('domain') }}</a>
		<ul style="list-style: none; display: flex; gap: 2rem;">
			{% set pages = cms.collection.objects('builder-pages', {sort: 'sort:asc'}) %}
			{% for page in pages %}
				{% if not page.draft %}
				<li><a href="{{ page.path == '' ? '/' : '/' ~ page.path }}" style="text-decoration: none; color: #555; font-weight: 500;">{{ page.title }}</a></li>
				{% endif %}
			{% endfor %}
		</ul>
	</div>
</nav>
