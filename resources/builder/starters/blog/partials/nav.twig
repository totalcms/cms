<nav style="border-bottom: 1px solid #e5e7eb; padding: 1rem 0;">
	<div class="container" style="display: flex; justify-content: space-between; align-items: center;">
		<a href="/" style="font-weight: 700; font-size: 1.25rem; text-decoration: none; color: #111; font-family: system-ui, sans-serif;">{{ cms.config('domain') }}</a>
		<ul style="list-style: none; display: flex; gap: 1.5rem; font-family: system-ui, sans-serif;">
			{% for p in cms.builder.nav() %}
				<li><a href="{{ p.route }}" style="text-decoration: none; color: #555;">{{ p.title }}</a></li>
			{% endfor %}
		</ul>
	</div>
</nav>
