{% extends 'layouts/' ~ page.layout ~ '.twig' %}

{% set post = cms.collection.object('blog', params.id) %}

{% block title %}{{ post.title ?? 'Post Not Found' }} — {{ cms.config('domain') }}{% endblock %}
{% block description %}{{ post.summary | default('') | striptags | slice(0, 160) }}{% endblock %}

{% block content %}
<section class="section">
	{% if post %}
		<article>
			<header style="margin-bottom: 2rem;">
				<h1>{{ post.title }}</h1>
				<p class="post-meta">
					{{ post.date | date('F j, Y') }}
					{% if post.author %} &middot; {{ post.author }}{% endif %}
				</p>
			</header>

			{% if post.content %}
				<div>{{ post.content | raw }}</div>
			{% endif %}

			<footer style="margin-top: 3rem; padding-top: 1.5rem; border-top: 1px solid #e5e7eb;">
				<a href="/blog">&larr; Back to all posts</a>
			</footer>
		</article>
	{% else %}
		<h1>Post Not Found</h1>
		<p>The blog post <code>{{ params.id }}</code> could not be found.</p>
		<p><a href="/blog">&larr; Back to all posts</a></p>
	{% endif %}
</section>
{% endblock %}
