{
	"$schema": "https://json-schema.org/draft/2020-12/schema",
	"$id": "https://www.totalcms.co/schemas/builder-page.json",
	"id": "builder-page",
	"type": "object",
	"description": "A schema for a Site Builder page",
	"formgrid": "draft .\ntitle title\ndescription description\n---Navigation---\nnav .\nroute .\nsort parent\n---Page Templates---\ntemplate layout\n---Sitemap---\nsitemap .\nchangeFrequency priority\n---\nid id\nupdated created",
	"properties": {
		"id": {
			"$ref"     : "https://www.totalcms.co/schemas/properties/slug.json",
			"label"    : "Page ID",
			"help"     : "Unique identifier for this page.",
			"field"    : "id",
			"factory"  : "slug",
			"settings" : {
				"autogen": "${title}"
			}
		},
		"title": {
			"type"    : "string",
			"label"   : "Page Title",
			"help"    : "The page title, used in the title tag and navigation",
			"field"   : "text",
			"factory" : "catchPhrase"
		},
		"route": {
			"type"        : "string",
			"label"       : "URL Path",
			"help"        : "URL path for this page. Use {param} for dynamic segments (e.g. /products/{id}).",
			"field"       : "text",
			"default"     : "",
			"placeholder" : "/about"
		},
		"template": {
			"type"    : "string",
			"label"   : "Page Template",
			"help"    : "The page template to render. Multiple pages can share the same template.",
			"field"   : "text",
			"default" : "",
			"settings" : {
				"propertyOptions": "pages"
			}
		},
		"layout": {
			"type"    : "string",
			"label"   : "Layout",
			"help"    : "The layout template this page extends. Create layouts in the Builder under layouts/.",
			"field"   : "select",
			"default" : "default",
			"settings" : {
				"propertyOptions": "layouts",
				"sortOptions" : true
			}
		},
		"description": {
			"type"    : "string",
			"label"   : "Meta Description",
			"help"    : "SEO meta description for this page",
			"field"   : "textarea",
			"factory" : "catchPhrase"
		},
		"draft": {
			"type"    : "boolean",
			"label"   : "Draft",
			"help"    : "Draft pages are excluded from routing",
			"field"   : "toggle",
			"default" : false,
			"factory" : "boolean"
		},
		"nav": {
			"type"    : "boolean",
			"label"   : "Show in Nav",
			"help"    : "Include this page in navigation menus",
			"field"   : "toggle",
			"default" : true,
			"factory" : "boolean"
		},
		"sort": {
			"type"    : "number",
			"label"   : "Sort Order",
			"help"    : "Ordering for navigation menus. Lower numbers appear first.",
			"field"   : "number",
			"default" : 0
		},
		"parent": {
			"type"        : "string",
			"label"       : "Parent Page",
			"help"        : "Parent page ID for hierarchical navigation",
			"field"       : "select",
			"placeholder" : "Select a parent...",
			"default"     : "",
			"settings"    : {
				"relationalOptions" : {
					"collection" : "builder-pages",
					"format"     : "{title} ( {route} )",
					"value"      : "id"
				},
				"sortOptions" : true
			}
		},
		"sitemap": {
			"type"    : "boolean",
			"label"   : "Include in Sitemap",
			"help"    : "Include this page in the generated sitemap.xml",
			"field"   : "toggle",
			"default" : true,
			"factory" : "boolean"
		},
		"changeFrequency": {
			"type"        : "string",
			"label"       : "Change Frequency",
			"help"        : "How frequently the page is likely to change. Hint to crawlers — most search engines ignore this.",
			"field"       : "select",
			"placeholder" : "Not set",
			"default"     : "",
			"options"     : [
				"always",
				"hourly",
				"daily",
				"weekly",
				"monthly",
				"yearly",
				"never"
			],
			"settings"    : {
				"visibility" : {
					"watch"    : "sitemap",
					"value"    : "1",
					"operator" : "=="
				}
			}
		},
		"priority": {
			"type"        : "number",
			"label"       : "Priority",
			"help"        : "Priority of this page relative to other pages on the site (0.0 to 1.0). Leave blank to omit.",
			"field"       : "number",
			"placeholder" : "0.5",
			"default"     : 0,
			"settings"    : {
				"min"        : 0,
				"max"        : 1,
				"step"       : 0.1,
				"visibility" : {
					"watch"    : "sitemap",
					"value"    : "1",
					"operator" : "=="
				}
			}
		},
		"updated": {
			"$ref"     : "https://www.totalcms.co/schemas/properties/date.json",
			"label"    : "Updated Date",
			"help"     : "Last modified date",
			"field"    : "datetime",
			"factory"  : "iso8601",
			"settings" : {
				"onUpdate": true,
				"readonly": true
			}
		},
		"created": {
			"$ref"     : "https://www.totalcms.co/schemas/properties/date.json",
			"label"    : "Creation Date",
			"help"     : "Page creation date",
			"field"    : "datetime",
			"factory"  : "iso8601",
			"settings" : {
				"onCreate": true,
				"readonly": true
			}
		}
	},
	"required": [
		"id",
		"title",
		"updated",
		"created"
	],
	"index": [
		"id",
		"title",
		"route",
		"template",
		"layout",
		"draft",
		"nav",
		"sort",
		"parent",
		"sitemap",
		"changeFrequency",
		"priority",
		"updated",
		"created"
	]
}
