{
	"$schema"     : "https://json-schema.org/draft/2020-12/schema",
	"$id"         : "https://www.totalcms.co/schemas/schema.json",
	"id"          : "schema",
	"type"        : "object",
	"description" : "A schema for a Total CMS schema file",
	"properties"  : {
		"$id": {
			"type"   : "string",
			"format" : "uri",
			"field"  : "hidden"
		},
		"$schema": {
			"type"   : "string",
			"format" : "uri",
			"field"  : "hidden"
		},
		"type": {
			"type"  : "string",
			"field" : "hidden"
		},
		"id": {
			"$ref" : "https://www.totalcms.co/schemas/properties/slug.json",
			"label"       : "ID",
			"help"        : "The unique identifier for this schema.",
			"placeholder" : "myschema",
			"field"       : "id"
		},
		"description": {
			"type"        : "string",
			"label"       : "Description",
			"help"        : "A decription of the schema.",
			"placeholder" : "About your schema.",
			"field"       : "textarea"
		},
		"required": {
			"type"        : "array",
			"label"       : "Required Properties",
			"help"        : "A list of required properties.",
			"field"       : "list",
			"minItems"    : 1,
			"settings" : { "addChoices" : false },
			"items"       : {
				"type" : "string"
			}
		},
		"index": {
			"type"        : "array",
			"label"       : "Indexed Properties",
			"help"        : "A list of properties to index. These will be accessible in a Collection's Index.",
			"field"       : "list",
			"minItems" : 1,
			"settings" : { "addChoices" : false },
			"items"    : {
				"type" : "string"
			}
		},
		"properties": {
			"$ref"  : "https://www.totalcms.co/schemas/properties/properties.json",
			"help"  : "Define what properties are available in this schema.",
			"label" : "Schema Fields",
			"field" : "schemaProperties"
		}
	},
	"required": [
		"$schema",
		"$id",
		"type",
		"description",
		"properties",
		"required",
		"index"
	],
	"index" : [
		"id"
	]
}