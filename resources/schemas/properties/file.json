{
  "$id"         : "https://www.totalcms.co/schemas/properties/file.json",
  "$schema"     : "https://json-schema.org/draft/2020-12/schema",
  "description" : "File object with supplemental data about the file",
  "type"        : "object",
  "properties"  : {
    "name": {
      "type"     : "string",
      "$comment" : "The name of the file that will be used for the download"
    },
    "comments": {
      "type"     : "string",
      "$comment" : "Comments for this file"
    },
    "tags": {
      "default"  : [],
      "$comment" : "Tags associated with the file",
      "$ref"     : "https://www.totalcms.co/schemas/properties/list.json"
    },
    "password": {
      "$comment" : "If the file is set to be protected, what is the passphrase in order to access it",
      "$ref"     : "https://www.totalcms.co/schemas/properties/password.json"
    },
    "protected": {
      "default"  : true,
      "$comment" : "Flag to enable group authentication on the file set in the collection",
      "type"     : "boolean"
    },
    "filename": {
      "type"     : "string",
      "$comment" : "The name of the original file including the extension"
    },
    "mime": {
      "type"     : "string",
      "$comment" : "The file mime type"
    },
    "size": {
      "minimum"  : 0,
      "$comment" : "The filesize of the file in bytes",
      "type"     : "integer"
    },
    "count": {
      "minimum"  : 0,
      "$comment" : "The number of times a file has been downloaded",
      "type"     : "integer"
    },
    "uploadDate": {
      "$comment" : "The date the file was uploaded",
      "$ref"     : "https://www.totalcms.co/schemas/properties/date.json"
    }
  },
  "required": [
    "mime",
    "filename",
    "name",
    "size",
    "uploadDate"
  ],
  "examples": [
    {
      "name"       : "file.zip",
      "filename"   : "originalfile.zip",
      "uploadDate" : "2018-08-02T08:59:28+00:00",
      "password"   : "password",
      "protected"  : false,
      "mime"       : "application/zip",
      "size"       : 1234556,
      "comments"   : "This is My File",
      "tags"       : [
        "tag1",
        "tag2"
      ]
    }
  ]
}