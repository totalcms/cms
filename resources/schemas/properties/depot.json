{
    "$schema"     : "https://json-schema.org/draft/2020-12/schema",
	"$id"         : "https://www.totalcms.co/schemas/properties/depot.json",
	"description" : "Depot is an array of file objects",
    "type"        : "object",
    "properties"  : {
		"password": {
			"$comment" : "If the file is set to be protected, what is the passphrase in order to access it",
			"$ref"     : "https://www.totalcms.co/schemas/properties/password.json"
		},
		"protected": {
			"default"  : true,
			"$comment" : "Flag to enable group authentication on the file set in the collection",
			"type"     : "boolean"
		},
        "files": {
			"type"        : "array",
			"description" : "Array of file objects",
			"default"     : [],
			"items"       : {
				"anyOf": [
					{
						"$ref": "https://www.totalcms.co/schemas/properties/file.json"
					},
					{
						"$ref": "https://www.totalcms.co/schemas/properties/folder.json"
					}
				]
			}
		}
    },
    "required": [
        "files"
    ]
}
