{
	"$schema" : "https://json-schema.org/draft/2020-12/schema",
	"$id"     : "https://www.totalcms.co/schemas/properties/time.json",
	"anyOf"   : [
		{
			"pattern"     : "^([01]?[0-9]|2[0-3]):[0-5][0-9]$",
			"description" : "A time field should be in 24-hour format.",
			"type"        : "string",
			"examples"    : [
			  "23:59",
			  "00:00",
			  "12:34"
			]
		},
		{
			"$ref" : "https://www.totalcms.co/schemas/properties/empty.json"
		}
	]
}