{
	"$schema": "http://json-schema.org/draft-07/schema#",
	"type": "object",
	"title": "Total CMS Jumpstart Definition",
	"description": "Schema for defining jumpstart content generation in Total CMS",
	"properties": {
		"version": {
			"type": "string",
			"description": "Version of the content definition format",
			"pattern": "^\\d+\\.\\d+\\.\\d+$"
		},
		"name": {
			"type": "string",
			"description": "Name of the content generation template"
		},
		"description": {
			"type": "string",
			"description": "Description of what this template creates"
		},
		"schemas": {
			"type": "array",
			"description": "Custom schemas to create",
			"items": {
				"type": "object",
				"properties": {
					"id": {
						"type": "string",
						"description": "Unique identifier for the schema"
					},
					"name": {
						"type": "string",
						"description": "Display name for the schema"
					},
					"description": {
						"type": "string"
					},
					"fields": {
						"type": "array",
						"description": "Field definitions for the schema",
						"items": {
							"type": "object",
							"properties": {
								"name": {
									"type": "string"
								},
								"type": {
									"type": "string",
									"enum": ["text", "textarea", "number", "select", "checkbox", "date", "image", "file", "markdown", "code", "color", "email", "url", "toggle", "multiselect", "json", "array", "object"]
								},
								"label": {
									"type": "string"
								},
								"required": {
									"type": "boolean",
									"default": false
								},
								"default": {},
								"options": {
									"type": "object",
									"description": "Field-specific options"
								}
							},
							"required": ["name", "type"]
						}
					}
				},
				"required": ["id", "name", "fields"]
			}
		},
		"collections": {
			"type": "object",
			"description": "Collections to create (both default and custom)",
			"properties": {
				"reserved": {
					"type": "array",
					"description": "Default collections to create",
					"items": {
						"type": "string",
						"enum": ["blog", "image", "gallery", "text", "feed", "form", "file", "depot", "toggle", "navigation", "snippet", "template"]
					}
				},
				"custom": {
					"type": "array",
					"description": "Custom collections to create",
					"items": {
						"type": "object",
						"properties": {
							"id": {
								"type": "string",
								"description": "Collection identifier"
							},
							"name": {
								"type": "string",
								"description": "Display name"
							},
							"schemaId": {
								"type": "string",
								"description": "ID of the custom schema to use"
							},
							"settings": {
								"type": "object",
								"description": "Collection-specific settings"
							}
						},
						"required": ["id", "name", "schemaId"]
					}
				}
			}
		},
		"objects": {
			"type": "array",
			"description": "Specific objects to create with defined content",
			"items": {
				"type": "object",
				"properties": {
					"collection": {
						"type": "string",
						"description": "Target collection ID"
					},
					"id": {
						"type": "string",
						"description": "Specific ID for the object"
					},
					"data": {
						"type": "object",
						"description": "Object data (for image/gallery fields, use factory rule strings)"
					}
				},
				"required": ["collection", "id", "data"]
			}
		},
		"factory": {
			"type": "array",
			"description": "Bulk content generation using factory importer",
			"items": {
				"type": "object",
				"properties": {
					"collection": {
						"type": "string",
						"description": "Target collection ID"
					},
					"id": {
						"type": "string",
						"description": "Specific ID for a single object (if provided, count is ignored and set to 1)"
					},
					"count": {
						"type": "integer",
						"description": "Number of objects to generate (ignored if id is provided)",
						"minimum": 1
					},
					"data": {
						"type": "object",
						"description": "Property names mapped to factory rules (overrides schema defaults)",
						"additionalProperties": {
							"type": "string"
						}
					}
				},
				"required": ["collection"],
				"oneOf": [
					{
						"required": ["count"],
						"not": {
							"required": ["id"]
						}
					},
					{
						"required": ["id"],
						"not": {
							"required": ["count"]
						}
					}
				]
			}
		}
	},
	"required": ["version", "name"]
}