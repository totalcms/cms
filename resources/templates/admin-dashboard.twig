<!doctype html>
<html lang="en">
<head>
	<meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
	<meta name="robots" content="noindex, nofollow">
	<title>{{ cms.config('dashboard', 'title') ?? 'Total CMS Admin' }}</title>

	{# Apply theme immediately to prevent flash of wrong theme #}
	<script>
		(function() {
			const saved = localStorage.getItem('totalcms-theme');
			const theme = ['auto', 'light', 'dark'].includes(saved) ? saved : 'auto';
			const html  = document.documentElement;

			html.classList.remove('theme-light', 'theme-dark', 'theme-auto');
			html.classList.add('theme-' + theme);

			switch (theme) {
				case 'light':
					html.style.colorScheme = 'light';
					break;
				case 'dark':
					html.style.colorScheme = 'dark';
					break;
				case 'auto':
				default:
					html.style.colorScheme = 'light dark';
					break;
			}
		})();
	</script>

	{% include 'partials/sentry.twig' %}

	<script src="{{ cms.api }}/assets/htmx.min.js?v={{ cms.version }}"></script>
	<meta name="csrf-token" content="{{ csrf_token() }}">

    <base href="{{ cms.api }}/admin/">
	<link rel="modulepreload" href="{{ cms.api }}/assets/admin.js?v={{ cms.version }}"/>
	<link rel="modulepreload" href="{{ cms.api }}/assets/content.js?v={{ cms.version }}"/>
	<link rel="stylesheet" href="{{ cms.api }}/assets/content-bundled.css?v={{ cms.version }}"/>
	<link rel="stylesheet" href="{{ cms.api }}/assets/icons.css?v={{ cms.version }}"/>
	<link rel="stylesheet" href="{{ cms.api }}/assets/admin.css?v={{ cms.version }}"/>
	<link rel="stylesheet" href="{{ cms.api }}/assets/dashboard.css?v={{ cms.version }}"/>

	{% set accentColor = cms.config('dashboard', 'accent') %}
	{% if accentColor %}
	<style>:root{--totalform-accent:{{ accentColor | hexToColor | oklch(100, false) }};}</style>
	{% endif %}

	{% block head %}{% endblock %}
	{{ cms.extensionAssets() }}
	{% if cms.edition.can('whitelabel_templates') %}
		{{ include('whitelabel/admin-head.twig', ignore_missing = true) }}
	{% endif %}
</head>
<body{% if cms.config('dashboard', 'fullWidthForms') %} class="full-width-forms"{% endif %}>

    {% block content %}

    <div class="admin-dashboard">
        <button class="mobile-menu-toggle" aria-label="Toggle menu"></button>
        <div class="mobile-overlay"></div>

        <aside class="dash-sidebar">
            <nav>
                <ul class="menu">
                    <li class="menu-item">
						{{ include(cms.edition.can('whitelabel_templates')
							? ['whitelabel/admin-logo.twig', 'admin-logo-default.twig']
							: ['admin-logo-default.twig']
						, ignore_missing = true) }}
                    </li>
                    {% if cms.auth.canAccessCollectionsOperation('read') %}
                    <li class="menu-item{% if url.page == 'collections' %} active{% endif %}">
                        <a class="collections" href="collections" title="{{ t('nav.collections') }}">{{ t('nav.collections') }}</a>
                    </li>
                    {% endif %}
                    {% if cms.auth.canAccessSchemasOperation('read') %}
                    <li class="menu-item{% if url.page == 'schemas' %} active{% endif %}">
                        <a class="schemas" href="schemas" title="{{ t('nav.schemas') }}">{{ t('nav.schemas') }}</a>
                    </li>
                    {% endif %}
                    {% if cms.auth.canAccessPlayground() %}
                    <li class="menu-item{% if url.page == 'playground' %} active{% endif %}">
                        <a class="playground" href="playground" title="{{ t('nav.playground') }}">{{ t('nav.playground') }}</a>
                    </li>
                    {% endif %}
                    {% if cms.auth.canAccessMailer() and cms.edition.can('mailer_actions') %}
                    <li class="menu-item{% if url.page == 'mailer' %} active{% endif %}">
                        <a class="mailer" href="mailer" title="{{ t('nav.mailer') }}">{{ t('nav.mailer') }}</a>
                    </li>
                    {% endif %}
                    {% if cms.auth.canAccessTemplates() and cms.edition.can('templates') %}
                    <li class="menu-item{% if url.page == 'templates' %} active{% endif %}">
                        <a class="templates" href="templates" title="{{ t('nav.templates') }}">{{ t('nav.templates') }}</a>
                    </li>
                    {% endif %}
                    {% if cms.auth.canAccessDataViews() and cms.edition.can('data_views') %}
                    <li class="menu-item{% if url.page == 'dataviews' %} active{% endif %}">
                        <a class="dataviews" href="dataviews" title="{{ t('nav.dataviews') }}">{{ t('nav.dataviews') }}</a>
                    </li>
                    {% endif %}
                    {% if extensionNavItems is defined and extensionNavItems is iterable %}
						{% for item in extensionNavItems %}
							{% if item.permission == 'any' or (item.permission == 'admin' and cms.auth.isAdmin()) %}
							<li class="menu-item{% if url.path ends with item.slug %} active{% endif %}">
								<a class="ext-nav" href="{{ item.url }}" title="{{ item.label }}"
									{% if item.icon %} style="--ext-icon: url('data:image/svg+xml,{{ item.icon|url_encode }}')"{% endif %}
								>{{ item.label }}</a>
							</li>
							{% endif %}
						{% endfor %}
                    {% endif %}
                    {% if cms.auth.canAccessUtils() %}
                    <li class="menu-item{% if url.page == 'utils' %} active{% endif %}">
                        <a class="utils" href="utils" title="{{ t('nav.utils') }}">{{ t('nav.utils') }}</a>
                    </li>
                    {% endif %}
                    {% if cms.auth.isAdmin() %}
                    <li class="menu-item{% if url.page == 'extensions' %} active{% endif %}">
                        <a class="extensions" href="extensions" title="{{ t('nav.extensions') }}">{{ t('nav.extensions') }}</a>
                    </li>
                    <li class="menu-item{% if url.page == 'settings' %} active{% endif %}">
                        <a class="settings" href="settings" title="{{ t('nav.settings') }}">{{ t('nav.settings') }}</a>
                    </li>
                    {% endif %}
                    {% if cms.auth.canAccessDocs() %}
                    <li class="menu-item{% if url.page == 'docs' %} active{% endif %}">
                        <a class="docs" href="docs" title="{{ t('nav.docs') }}">{{ t('nav.docs') }}</a>
                    </li>
                    {% endif %}
                </ul>
            </nav>

            {% set licenseStatus = cms.license.getSidebarStatus() %}
            {% if licenseStatus.showIcon and cms.auth.isAdmin() %}
            <a href="utils/license-manager"
				class="license-status license-{{ licenseStatus.severity }}"
				title="{{ licenseStatus.tooltip }}">{{ t('nav.license_status') }}</a>
            {% endif %}

            <div class="user-profile" >
                {% if cms.auth.userLoggedIn %}
                <button popovertarget="user-actions">
                    {% set user = cms.auth.userData %}
                    <img src="{{ cms.media.imagePath(user.id, {w:96,h:96,fm:"jpg",fit:"crop-focalpoint"}, {collection: user.collection}) }}"
                        alt="Profile Image for {{ user.name }}" onerror="this.remove();"/>
                </button>
                <nav popover id="user-actions">
                    <ul>
                        <li class="theme-selector">
                            <label>{{ t('user.theme') }}</label>
                            <div class="theme-buttons" role="radiogroup" aria-label="{{ t('user.theme') }}">
                                <button type="button" data-theme="auto" aria-label="{{ t('user.theme_auto') }}" title="{{ t('user.theme_auto') }}">
                                    <span class="icon-auto"></span>
                                </button>
                                <button type="button" data-theme="light" aria-label="{{ t('user.theme_light') }}" title="{{ t('user.theme_light') }}">
                                    <span class="icon-sun"></span>
                                </button>
                                <button type="button" data-theme="dark" aria-label="{{ t('user.theme_dark') }}" title="{{ t('user.theme_dark') }}">
                                    <span class="icon-moon"></span>
                                </button>
                            </div>
                        </li>
                        <li class="profile"><a href="javascript:void(0)" style="cursor:default">{{ user.name }}</a></li>
                        <li class="edit"><a href="profile">{{ t('user.edit_profile') }}</a></li>
                        <li class="logout"><a href="../logout">{{ t('user.logout') }}</a></li>
                    </ul>
                </nav>
                {% elseif cms.env == 'dev' %}
                {# Show default profile in dev mode for styling verification #}
                <button popovertarget="user-actions"></button>
                <nav popover id="user-actions">
                    <ul>
                        <li class="theme-selector">
                            <label>{{ t('user.theme') }}</label>
                            <div class="theme-buttons" role="radiogroup" aria-label="{{ t('user.theme') }}">
                                <button type="button" data-theme="auto" aria-label="{{ t('user.theme_auto') }}" title="{{ t('user.theme_auto') }}">
                                    <span class="icon-auto"></span>
                                </button>
                                <button type="button" data-theme="light" aria-label="{{ t('user.theme_light') }}" title="{{ t('user.theme_light') }}">
                                    <span class="icon-sun"></span>
                                </button>
                                <button type="button" data-theme="dark" aria-label="{{ t('user.theme_dark') }}" title="{{ t('user.theme_dark') }}">
                                    <span class="icon-moon"></span>
                                </button>
                            </div>
                        </li>
                        <li class="profile"><a href="javascript:void(0)" style="cursor:default">{{ t('user.dev_user') }}</a></li>
                        <li class="edit"><a href="profile">{{ t('user.edit_profile') }}</a></li>
                        <li class="logout"><a href="../logout">{{ t('user.logout') }}</a></li>
                    </ul>
                </nav>
                {% endif %}
            </div>
        </aside>
        <section class="dash-content">

        	{% block dashcontent %}{% endblock %}

        </section>
    </div>

    {% endblock %}

	<script>window.TCMS_TRANSLATIONS = {{ cms.locale.jsTranslations()|json_encode|raw }};</script>
	<script>window.TCMS_CONFIG = {
		confirmCountdown: {{ cms.config('dashboard', 'confirmCountdown')|json_encode|raw }}
	};</script>
	<script type="module" src="{{ cms.api }}/assets/content.js?v={{ cms.version }}"></script>
	<script type="module" src="{{ cms.api }}/assets/admin.js?v={{ cms.version }}"></script>

	{% block bodyBelow %}{% endblock %}
	{% if cms.edition.can('whitelabel_templates') %}
		{{ include('whitelabel/admin-body-below.twig', ignore_missing = true) }}
	{% endif %}
</body>
</html>
