{% if cms.config('sentry') %}
<script src="https://js.sentry-cdn.com/ebe837e74d2740037be208a5d11fe257.min.js" crossorigin="anonymous"></script>
<script>
	Sentry.onLoad(function() {
		Sentry.init({
			release: "totalcms@{{ cms.version.number }}",
			tracesSampleRate: 0,
			profilesSampleRate: 0,
			beforeSend(event, hint) {
				const error = hint.originalException;

				// Get message from originalException or from the event's exception values
				const message = (error && error.message)
					|| (event.exception && event.exception.values && event.exception.values[0] && event.exception.values[0].value)
					|| '';

				// Ignore errors from known corrupted installations
				const ignoredDomains = ['komiksdiner'];
				if (ignoredDomains.some(domain => window.location.hostname.includes(domain))) return null;

				// Ignore cross-origin "Script error." (no details available due to browser security)
				if (message === 'Script error.' || message === 'Script error' || message.includes("message `Script error.`")) return null;

				// Ignore generic unhandled promise rejections with no details (not actionable)
				if (message.includes('CustomEvent') && message.includes('unhandledrejection')) return null;

				// Ignore browser extension errors
				if (message.includes('runtime.sendMessage')) return null;
				if (event.exception && event.exception.values) {
					var frames = event.exception.values.flatMap(function(v) {
						return (v.stacktrace && v.stacktrace.frames) || [];
					});
					var isExtension = frames.some(function(f) {
						return f.filename && (
							f.filename.includes('safariextension') ||
							f.filename.includes('chrome-extension://') ||
							f.filename.includes('moz-extension://')
						);
					});
					if (isExtension) return null;
				}

				// Ignore JSON parse errors (user input issues)
				if (error && error.name === 'SyntaxError' && (
					message.includes('JSON') ||
					message.includes('Unexpected token') ||
					message.includes('Expected') ||
					message.includes('Unterminated')
				)) return null;

				// Ignore pattern matching errors (validation)
				if (message.includes('did not match the expected pattern')) return null;

				// Ignore server validation errors shown in UI
				if (message.includes('400 Bad Request')) return null;

				// Ignore benign ResizeObserver loop errors (browser limitation, not a real bug)
				if (message.includes('ResizeObserver loop')) return null;

				// Ignore clipboard API errors (unavailable in non-secure HTTP contexts)
				if (message.includes('navigator.clipboard')) return null;

				// Ignore auth errors (session expired, user needs to re-login)
				if (message === 'Authentication required') return null;

				// Ignore race condition errors when elements are removed during async operations
				// (e.g., image onload firing after element was removed from DOM)
				if (error && error.name === 'TypeError' && message.includes("Cannot read properties of null (reading 'classList')")) return null;

				// Ignore SyntaxError (corrupted files or unsupported browsers)
				if (error && error.name === 'SyntaxError') return null;

				// Ignore "not found" errors from third-party feature/plugin systems
				if (message.includes('was not found')) return null;

				// Ignore ProseMirror/Tiptap internal errors (not actionable)
				if (message.includes('Applying a mismatched transaction')) return null;
				if (message.includes('outside of fragment')) return null;

				// Ignore CodeMirror closetag addon bug: accesses context.length before null-checking context.
				// CodeMirror 5 is abandoned upstream so no fix is coming.
				if (event.exception && event.exception.values) {
					var cmFrames = event.exception.values.flatMap(function(v) {
						return (v.stacktrace && v.stacktrace.frames) || [];
					});
					var isClosetagBug = cmFrames.some(function(f) {
						return f.filename && f.filename.includes('codemirror/addon/edit/closetag');
					});
					if (isClosetagBug) return null;
				}

				// Ignore SortableJS touch-drag race: setInterval fires after dragEl was
				// detached (e.g., by HTMX swap), so dragEl.parentNode is null.
				if (event.exception && event.exception.values) {
					var sortableFrames = event.exception.values.flatMap(function(v) {
						return (v.stacktrace && v.stacktrace.frames) || [];
					});
					var isSortableRace = sortableFrames.some(function(f) {
						return f.filename && f.filename.includes('sortablejs');
					}) && /parentNode/.test(message);
					if (isSortableRace) return null;
				}

				return event;
			}
		});
		if (typeof Sentry.setTag === 'function') {
			Sentry.setTag('build', '{{ cms.version.build }}');
		}
	});
</script>
{% endif %}
