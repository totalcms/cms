{% extends "admin-dashboard.twig" %}

{% block head %}
<link rel="stylesheet" href="{{ cms.api }}/assets/highlight.css?v={{ cms.version }}">
<script type="module" src="{{ cms.api }}/assets/docs-highlight.js?v={{ cms.version }}"></script>
{% endblock %}

{# Menu is loaded by AdminDocsAction from resources/docs/menu.php and supplied
   as the `menu` template variable. Two shapes per top-level group:
     - Flat:   { title, sub: [{title, path}, ...] }
     - Nested: { title, groups: [{title, sub: [{title, path}, ...]}, ...] }
   See resources/docs/menu.php for the source data. #}

{# Flatten menu into an ordered list of leaf pages for prev/next + related lookups #}
{% set flatPages = [] %}
{% for item in menu %}
	{% for sub in (item.sub ?? []) %}
		{% set flatPages = flatPages|merge([sub]) %}
	{% endfor %}
	{% for grp in (item.groups ?? []) %}
		{% for sub in grp.sub %}
			{% set flatPages = flatPages|merge([sub]) %}
		{% endfor %}
	{% endfor %}
{% endfor %}

{# Find which top-level group + subgroup contain the current page #}
{% set currentGroupTitle = null %}
{% set currentSubgroupTitle = null %}
{% for item in menu %}
	{% if item.sub is defined and page in item.sub|column('path') %}
		{% set currentGroupTitle = item.title %}
	{% endif %}
	{% for grp in (item.groups ?? []) %}
		{% if page in grp.sub|column('path') %}
			{% set currentGroupTitle = item.title %}
			{% set currentSubgroupTitle = grp.title %}
		{% endif %}
	{% endfor %}
{% endfor %}

{# Find current index in flatPages and the leaf title (for prev/next + breadcrumb) #}
{% set currentIndex = -1 %}
{% set currentTitle = title ?? page %}
{% for p in flatPages %}
	{% if p.path == page %}
		{% set currentIndex = loop.index0 %}
		{% set currentTitle = p.title %}
	{% endif %}
{% endfor %}

{% block dashcontent %}

<aside class="dash-content-sidebar">
	<header>
		<input type="search" class="filter" placeholder="{{ t('docs.filter') }}" />
	</header>

	<nav class="links docs">
		{% for item in menu %}
			{# Determine whether this top-level group should be open #}
			{% set groupOpen = false %}
			{% if item.sub is defined and page in item.sub|column('path') %}
				{% set groupOpen = true %}
			{% endif %}
			{% for grp in (item.groups ?? []) %}
				{% if page in grp.sub|column('path') %}
					{% set groupOpen = true %}
				{% endif %}
			{% endfor %}

			<details id="category-{{ item.title | slug }}"{% if groupOpen %} open{% endif %}>
				<summary>{{ item.title }}</summary>

				{# Top-level leaves render first (used for "Overview" entries on nested groups) #}
				{% if item.sub is defined and item.sub|length > 0 %}
					<ul>
						{% for sub in item.sub %}
						<li><a {% if page == sub.path %}class="active"{% endif %}
								href="docs/{{ sub.path }}"
								{% if sub.target is defined %}target="{{ sub.target }}"{% endif %}
							>{{ sub.title }}</a></li>
						{% endfor %}
					</ul>
				{% endif %}

				{% if item.groups is defined %}
					<div class="docs-subgroups">
						{% for grp in item.groups %}
							{% set subOpen = page in grp.sub|column('path') %}
							<details class="docs-subgroup"{% if subOpen %} open{% endif %}>
								<summary>{{ grp.title }}</summary>
								<ul>
									{% for sub in grp.sub %}
									<li><a {% if page == sub.path %}class="active"{% endif %}
											href="docs/{{ sub.path }}"
											{% if sub.target is defined %}target="{{ sub.target }}"{% endif %}
										>{{ sub.title }}</a></li>
									{% endfor %}
								</ul>
							</details>
						{% endfor %}
					</div>
				{% endif %}
			</details>
		{% endfor %}
	</nav>

	<footer>
	</footer>
	<script>document.querySelector('.docs a.active')?.scrollIntoView({ block: 'center' });</script>
</aside>
{% include "admin/sidebar-details.twig" %}

<main class="dash-main-content doc-content">

	{% if page != 'index' and currentGroupTitle %}
	<nav class="doc-breadcrumb" aria-label="Breadcrumb">
		<a href="docs">Docs</a>
		<span class="doc-breadcrumb-sep">›</span>
		<span>{{ currentGroupTitle }}</span>
		{% if currentSubgroupTitle %}
		<span class="doc-breadcrumb-sep">›</span>
		<span>{{ currentSubgroupTitle }}</span>
		{% endif %}
		<span class="doc-breadcrumb-sep">›</span>
		<span class="doc-breadcrumb-current">{{ currentTitle }}</span>
	</nav>
	{% endif %}

	{{ content }}

	{% if related is defined and related is iterable and related|length > 0 %}
	<aside class="doc-related" aria-labelledby="doc-related-heading">
		<h3 id="doc-related-heading">Related pages</h3>
		<ul>
			{% for relPath in related %}
				{% set relMatch = flatPages|filter(p => p.path == relPath)|first %}
				{% set relTitle = relMatch.title ?? relPath %}
				{% set relGroup = null %}
				{% for item in menu %}
					{% if item.sub is defined and relPath in item.sub|column('path') %}
						{% set relGroup = item.title %}
					{% endif %}
					{% for grp in (item.groups ?? []) %}
						{% if relPath in grp.sub|column('path') %}
							{% set relGroup = item.title %}
						{% endif %}
					{% endfor %}
				{% endfor %}
				<li>
					<a href="docs/{{ relPath }}">{{ relTitle }}</a>
					{% if relGroup %}<span class="doc-related-group">— {{ relGroup }}</span>{% endif %}
				</li>
			{% endfor %}
		</ul>
	</aside>
	{% endif %}

	{% if currentIndex >= 0 %}
	<nav class="doc-prev-next" aria-label="Page navigation">
		{% if currentIndex > 0 %}
			{% set prev = flatPages[currentIndex - 1] %}
			<a href="docs/{{ prev.path }}" class="doc-prev">
				<span class="doc-prev-next-label">← Previous</span>
				<span class="doc-prev-next-title">{{ prev.title }}</span>
			</a>
		{% else %}
			<span class="doc-prev-next-spacer"></span>
		{% endif %}
		{% if currentIndex < flatPages|length - 1 %}
			{% set next = flatPages[currentIndex + 1] %}
			<a href="docs/{{ next.path }}" class="doc-next">
				<span class="doc-prev-next-label">Next →</span>
				<span class="doc-prev-next-title">{{ next.title }}</span>
			</a>
		{% else %}
			<span class="doc-prev-next-spacer"></span>
		{% endif %}
	</nav>
	{% endif %}

	{% if page != 'index' %}
	<footer class="doc-footer">
		{% if updated is defined %}
		<span class="doc-updated">Last updated: {{ updated }}</span>
		{% endif %}
		<a class="doc-edit-link"
		   href="https://github.com/totalcms/totalcms/edit/develop/resources/docs/{{ page }}.md"
		   target="_blank" rel="noopener">Edit this page on GitHub</a>
	</footer>
	{% endif %}

</main>

{% if toc is defined and toc|length > 1 %}
<aside class="doc-toc" aria-label="On this page">
	<div class="doc-toc-inner">
		<h4>On this page</h4>
		<ul>
			{% for h in toc %}
			<li class="doc-toc-h{{ h.level }}">
				<a href="#{{ h.id }}" data-toc-target="{{ h.id }}">{{ h.text }}</a>
			</li>
			{% endfor %}
		</ul>
	</div>
</aside>
{% endif %}

{% endblock %}
