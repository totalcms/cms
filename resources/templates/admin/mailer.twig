{% extends "admin-dashboard.twig" %}

{% block dashcontent %}

<aside class="dash-content-sidebar">
	<header>
		<input type="search" class="filter" placeholder="Filter Mailers" autofocus />
	</header>

	<nav class="links" id="mailer-links">
		{% set mailers = cms.objects("mailer") %}
		{% if mailers|length == 0 %}
			<h3>Email Templates</h3>
			<ul>
				<li class="no-mailers">No email templates found</li>
			</ul>
		{% else %}
			{% set mailersByCategory = {} %}
			{% for mailer in mailers %}
				{% set category = mailer.category|default('Email Templates') %}
				{% set mailersByCategory = mailersByCategory|merge({(category): (mailersByCategory[category]|default([]))|merge([mailer])}) %}
			{% endfor %}

			{% for category, categoryMailers in mailersByCategory %}
				<h3>{{ category }}</h3>
				<ul>
					{% for mailer in sortByKey(categoryMailers) %}
					<li class="mailer-item">
						<a  {% if url.id == mailer.id %}class="active"{% endif %}
							href="mailer/{{ mailer.id }}"
							title="{{ mailer.description | escape }}">
							{{ mailer.name }}
						</a>
					</li>
					{% endfor %}
				</ul>
			{% endfor %}
		{% endif %}
	</nav>

	<footer>
		<a class="dash-button full transparent" href="mailer" title="Create a new email template">+ New Template</a>
	</footer>
</aside>

<main class="dash-main-content">

	<header>
		<h1><a href="mailer">mailer</a> / <span>{{ (url.id starts with '-' ? url.id|slice(1) : url.id) | default('new') }}</span></h1>
		<button class="dash-action-dots" title="Mailer Actions" popovertarget="mailer-actions"></button>
		<nav popover id="mailer-actions">
			<ul>
				<li class="export"><a href="mailer/-export">Export</a></li>
				<li class="import"><a href="mailer/-import">Import</a></li>
			</ul>
		</nav>
	</header>

{% if url.id == '-export' %}

	{% include "admin/collection/export.twig" %}

{% elseif url.id == '-import' %}

	{% include "admin/collection/import.twig" %}

{% else %}
	<section class="dash-content-section">
		<p>Create and manage email templates for your forms. Email fields support Twig templating with access to form data via <code>{{ "{{ data.fieldName }}" }}</code>. For example, use <code>{{ "{{ data.email }}" }}</code> to insert the submitted email address into the template.</p>

		{{ cms.form.mailer(url.id|default(''), {
			deleteActions : [{
				"action" : "redirect",
				"link"   : "mailer"
			}],
			newActions   : [{
				"action" : "redirect-object",
				"link"   : "mailer/{id}"
			}],
		}) }}

		{% if url.id and url.id != '' %}
		<section class="mail-test-section">
			<h2>Test Email</h2>
			<p>Send a test email using this template. Enter test data in JSON format to test Twig variable substitution.</p>

			{% set testDataField %}
				<textarea name="testData" id="test-data" placeholder='{"email": "test@example.com", "name": "John Doe"}'>{"email": "test@example.com", "name": "Test User"}</textarea>
			{% endset %}

			{{ cms.form.simple('/action/email', testDataField, {
				class  : "test-email-form",
				method : "POST",
				label  : "Send Test Email",
				ajax   : false,
			}) }}

			<div id="test-result" class="test-result"></div>
		</section>
		{% endif %}

	</section>
{% endif %}

</main>

<style>
.inactive-badge {
	display: inline-block;
	padding: 0.125rem 0.375rem;
	font-size: 0.75rem;
	font-weight: 600;
	color: oklch(var(--totalform-text-color));
	background-color: oklch(var(--totalform-nearwhite));
	border: 1px solid oklch(var(--totalform-border-color));
	border-radius: var(--totalform-radius);
	text-transform: uppercase;
	letter-spacing: 0.025em;
}
.mail-test-section {
	margin-top: 3rem;
	padding-top: 2rem;
	border-top: 2px solid oklch(var(--totalform-border-color));
}
.mail-test-section h2 {
	margin-bottom: 0.5rem;
	color: oklch(var(--totalform-nearblack));
}
.mail-test-section p {
	margin-bottom: 1.5rem;
	color: oklch(var(--totalform-darkgray));
}
#test-data {
	width: 100%;
	min-height: 100px;
	padding: 0.75rem;
	font-family: 'Monaco', 'Menlo', 'Ubuntu Mono', monospace;
	font-size: 0.875rem;
	border: 1px solid oklch(var(--totalform-border-color));
	border-radius: var(--totalform-radius);
	background-color: oklch(var(--totalform-purewhite));
}
.test-result {
	margin-top: 1.5rem;
	padding: 1rem;
	border-radius: var(--totalform-radius);
	display: none;
}
.test-result.success {
	display: block;
	background-color: oklch(90% 0.05 145);
	border: 1px solid oklch(70% 0.1 145);
	color: oklch(30% 0.05 145);
}
.test-result.error {
	display: block;
	background-color: oklch(90% 0.05 30);
	border: 1px solid oklch(70% 0.1 30);
	color: oklch(30% 0.05 30);
}
</style>

<script>
// Replace POST in history to prevent resubmission warning on refresh
if (window.history.replaceState) {
    window.history.replaceState(null, null, window.location.pathname);
}

// Function to handle test email form submission
function setupTestEmailForm() {
	const testForm = document.querySelector('.test-email-form');
	if (!testForm) return;

	const mailerId = '{{ url.id }}';
	if (!mailerId) return;

	testForm.addEventListener('submit', async function(e) {
		e.preventDefault();

		const testDataTextarea = document.getElementById('test-data');
		const testResult = document.getElementById('test-result');
		const submitButton = this.querySelector('button[type="submit"]');

		if (!testDataTextarea || !testResult) return;

		// Parse test data
		let testData = {};
		try {
			testData = JSON.parse(testDataTextarea.value || '{}');
		} catch (error) {
			testResult.className = 'test-result error';
			testResult.textContent = 'Invalid JSON in test data: ' + error.message;
			return;
		}

		// Disable submit button during request
		const originalText = submitButton.textContent;
		submitButton.disabled = true;
		submitButton.textContent = 'Sending...';

		try {
			const response = await fetch('/action/email', {
				method: 'POST',
				headers: {
					'Content-Type': 'application/json',
				},
				body: JSON.stringify({
					mailerId: mailerId,
					data: testData
				})
			});

			const result = await response.json();

			if (result.success) {
				testResult.className = 'test-result success';
				testResult.textContent = 'Test email sent successfully! ' + (result.message || '');
			} else {
				testResult.className = 'test-result error';
				testResult.textContent = 'Failed to send test email: ' + (result.error || result.message || 'Unknown error');
			}
		} catch (error) {
			testResult.className = 'test-result error';
			testResult.textContent = 'Error sending test email: ' + error.message;
		} finally {
			submitButton.disabled = false;
			submitButton.textContent = originalText;
		}
	});
}
setupTestEmailForm();
</script>

{% endblock %}
