{% extends "admin-dashboard.twig" %}

{% block dashcontent %}

<aside class="dash-content-sidebar">
	<header>
		<input type="search" name="filter" class="filter" placeholder="{{ t('mailer.filter') }}" autofocus />
	</header>

	<nav class="links" id="mailer-links">
		{% set mailers = cms.collection.objects("mailer") %}
		{% if mailers|length == 0 %}
			<h3>{{ t('mailer.title') }}</h3>
			<ul>
				<li class="no-mailers">{{ t('mailer.empty') }}</li>
			</ul>
		{% else %}
			{% set mailersByCategory = {} %}
			{% for mailer in mailers %}
				{% set category = mailer.category|default('Email Templates') %}
				{% set mailersByCategory = mailersByCategory|merge({(category): (mailersByCategory[category]|default([]))|merge([mailer])}) %}
			{% endfor %}

			{% for category, categoryMailers in mailersByCategory %}
			<details id="category-{{ category | slug }}" open>
				<summary>{{ category }}</summary>
				<ul>
					{% for mailer in sortByKey(categoryMailers) %}
					<li class="mailer-item">
						<a  {% if url.id == mailer.id %}class="active"{% endif %}
							href="mailer/{{ mailer.id }}"
							title="{{ mailer.description | escape }}">
							{{ mailer.name }}
						</a>
					</li>
					{% endfor %}
				</ul>
			</details>
			{% endfor %}
		{% endif %}
	</nav>

	<footer>
		<a class="dash-button full transparent" href="mailer/new" title="{{ t('mailer.new_desc') }}">{{ t('mailer.new') }}</a>
	</footer>
</aside>
{% include "admin/sidebar-details.twig" %}

<main class="dash-main-content">

{% if url.id is empty %}

	{% include "admin/mailer/home.twig" %}

{% else %}

	<header>
		<h1><a href="mailer">mailer</a> / <span>{{ (url.id starts with '-' ? url.id|slice(1) : url.id) }}</span></h1>
		<button class="dash-action-dots" title="{{ t('mailer.actions') }}" popovertarget="mailer-actions"></button>
		<nav popover id="mailer-actions">
			<ul>
				{% if url.id and url.id != 'new' and url.id[:1] != '-' %}
				<li class="duplicate"><a href="#" onclick="duplicateObject(event)">{{ t('btn.duplicate') }}</a></li>
				{% endif %}
				<li class="export"><a href="mailer/-export">{{ t('btn.export') }}</a></li>
				<li class="import"><a href="mailer/-import">{{ t('btn.import') }}</a></li>
			</ul>
		</nav>
	</header>

{% if url.id == '-export' %}

	{% include "admin/collection/export.twig" %}

{% elseif url.id == '-import' %}

	{% include "admin/collection/import.twig" %}

{% else %}
	<section class="dash-content-section">

		{% set mailerOptions = {
			deleteActions : [{
				"action" : "redirect",
				"link"   : "mailer"
			}],
			newActions   : [{
				"action" : "redirect-object",
				"link"   : "mailer/{id}"
			}],
		} %}
		{% if duplicateData is defined %}
			{% set mailerOptions = mailerOptions|merge({ data: duplicateData }) %}
		{% endif %}
		{{ cms.form.mailer(url.id == 'new' ? '' : url.id, mailerOptions) }}

		{% if url.id and url.id != '' %}
		<section class="mail-test-section">
			<h2>{{ t('mailer.test_email') }}</h2>
			<p>Send a test email using this template. Enter test data in JSON format to test Twig variable substitution.</p>

			{% set testDataField %}
				<input type="hidden" name="mailerId" value="{{ url.id }}" />
				{{ cms.form.field("json", "data", {
					label       : t('mailer.test_data'),
					help        : t('mailer.test_data_help'),
					placeholder : '{"email": "test@example.com", "name": "John Doe"}',
					rows        : 6,
				}) }}
			{% endset %}

			{{ cms.form.simple('/action/mailer', testDataField, {
				class  : "test-email-form",
				method : "POST",
				label  : t('mailer.test_send'),
				ajax   : true,
			}) }}
		</section>
		{% endif %}

	</section>

<script>
function duplicateObject(event) {
	event.preventDefault();

	const tempForm               = document.createElement('form');
	      tempForm.method        = 'POST';
	      tempForm.action        = 'mailer/new';
	      tempForm.style.display = 'none';

	const input = document.createElement('input');
	input.type = 'hidden';
	input.name = 'duplicate';
	input.value = '{{ url.id }}';
	tempForm.appendChild(input);

	document.body.appendChild(tempForm);
	tempForm.submit();
}
</script>

{% endif %}

{% endif %}

</main>

<style>
.mail-test-section {
	margin-top: 3rem;
	padding-top: 2rem;
	border-top: 2px solid oklch(var(--totalform-border-color));
}
.mail-test-section h2 {
	margin-bottom: 0.5rem;
	color: oklch(var(--totalform-nearblack));
}
.mail-test-section p {
	margin-bottom: 1.5rem;
	color: oklch(var(--totalform-darkgray));
}
</style>
{% endblock %}
