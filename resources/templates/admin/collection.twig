{% extends "admin-dashboard.twig" %}

{% set collectionIndex %}
	<h1>Collection Help</h1>
	<p>Choose a collection to edit or create a new one.</p>
{% endset %}


{% macro collectionHeader(collection, page) %}
	{% set collectionData = cms.collection.get(collection) %}
	<header>
		{% if page %}
		<h1><a href="collections">collections</a> / <a href="collections/{{ collection }}">{{ collection }}</a> / <span>{{ page | lower }}</span></h1>
		{% else %}
		<h1><a href="collections">collections</a> / <a href="collections/{{ collection }}"><span>{{ collection }}</span></a></h1>
		{% endif %}
		<div class="actions">
			{% if cms.auth.canAccessCollectionsMetaOperation('read') %}
			<a class="dash-button transparent" href="collections/{{ collection }}/edit" title="Edit Collection">Edit Collection</a>
			{% endif %}
			{% set labelSingular = cms.collection.get(collection).labelSingular|default('object') %}
			{% if cms.auth.canAccessCollection(collection, 'create') %}
			<a class="dash-button" href="collections/{{ collection }}/add" title="Add new {{ labelSingular | lower }} to collection">+ New {{ labelSingular|title }}</a>
			{% endif %}
			<button class="dash-action-dots" title="Collection Actions" popovertarget="collection-actions"></button>
			<nav popover id="collection-actions">
				<ul>
					{% set collectionSchema = cms.collection.get(collection).schema %}
					{% if cms.auth.canAccessSchema(collectionSchema, 'read') %}
					<li class="schema"><a href="schemas/{{ collectionSchema }}">Edit Schema</a></li>
					{% endif %}
					{# Show object link only when editing an object (css in edit.twig) #}
					{% if collectionData.url and page %}
					<li class="object-link" style="display:none">
						<a href="{{ cms.collection.objectUrl(collection, page) }}" target="_blank">Preview</a>
					</li>
					{% endif %}
					{# Show duplicate link only when editing an object (css in edit.twig) #}
					{% if cms.auth.canAccessCollection(collection, 'create') %}
					<li class="duplicate" style="display:none"><a href="#" onclick="duplicateObject(event)">Duplicate</a></li>
					{% endif %}
					{# Show download zip only when editing an object (css in object.twig) #}
					<li class="object-download" style="display:none">
						<a href="{{ cms.api }}/export/collections/{{ collection }}/{{ page }}/zip">Download Zip</a>
					</li>
					<li class="export"><a href="collections/{{ collection }}/-export">Export</a></li>
					{% if cms.auth.canAccessCollection(collection, 'create') %}
					<li class="import"><a href="collections/{{ collection }}/-import">Import</a></li>
					<li class="factory"><a href="collections/{{ collection }}/-factory">Factory</a></li>
					{% endif %}
					<li class="sitemap"><a href="collections/{{ collection }}/-sitemap">Sitemap</a></li>
					<li class="feeds"><a href="collections/{{ collection }}/-feeds">Feeds</a></li>
					{% if cms.auth.canAccessCollection(collection, 'update') %}
					<li class="reindex">{{ cms.admin.quickActionButton('Rebuild Index', 'collections/' ~ url.collection ~ '/index', {method: 'put', reload: true}) }}</li>
					{% endif %}
				</ul>
			</nav>
		</div>
	</header>
{% endmacro %}

{% block dashcontent %}

<aside class="dash-content-sidebar">
	<header>
		<input type="search" name="filter" class="filter" placeholder="Filter Collections" autofocus />
	</header>

	<nav class="links" id="collection-links">
		{% for category, collections in cms.collection.byCategory() %}
			{% set collections = collections | filter(c => cms.auth.canAccessCollection(c.id, 'read') and c.id not in ['playground', 'mailer', 'dataviews']) %}
			{% if collections | length > 0 %}
			<details id="category-{{ category | slug }}" open>
				<summary>{{ category }}</summary>
				<ul>
				{% for collection in sortByKey(collections, "name") %}
					<li class="collection-{{collection.schema}}">
						<a {% if url.collection == collection.id %}class="active"{% endif %}
							href="collections/{{ collection.id }}"
							title="{{ collection.description }}">{{ collection.name }}</a>
					</li>
				{% endfor %}
				</ul>
			</details>
			{% endif %}
		{% endfor %}
	</nav>

	{% if cms.auth.isAdmin() %}
	<footer>
		<a class="dash-button full transparent" href="collections/new" title="Create a new collection">+ New Collection</a>
	</footer>
	{% endif %}
</aside>
{% include "admin/sidebar-details.twig" %}

<main class="dash-main-content">
	{% set collection = cms.collection.get(url.collection) %}
	{% set labelPlural = collection.labelPlural|default('objects') %}
	{% set labelSingular = collection.labelSingular|default('object') %}

	{% if url.collection is empty %}
		{% include "admin/collection/home.twig" %}

	{% elseif url.collection == "new" %}
		{% include "admin/collection/new.twig" %}

	{% elseif url.id is empty %}
		{{ _self.collectionHeader(url.collection, labelPlural) }}
		{% include "admin/collection/index.twig" %}

	{% elseif url.id == "add" %}
		{{ _self.collectionHeader(url.collection, "new " ~ labelSingular) }}
		{% include "admin/collection/add.twig" %}

	{% elseif url.id == "edit" %}
		{{ _self.collectionHeader(url.collection) }}
		{% include "admin/collection/edit.twig" %}

	{% elseif url.id in ["-factory", "-import", "-export", "-sitemap", "-feeds"] %}
		{% set pageName = url.id | replace({"-":""}) %}
		{{ _self.collectionHeader(url.collection, pageName) }}
		{% include "admin/collection/" ~ pageName ~ ".twig" %}

	{% else %}
		{{ _self.collectionHeader(url.collection, url.id) }}
		{% include "admin/collection/object.twig" %}

	{% endif %}
</main>

<script>
document.addEventListener("keydown", function (event) {
	// Check for Cmd+N (on Mac) or Ctrl+N (on Windows/Linux)
	if ((event.metaKey || event.ctrlKey) && event.key.toLowerCase() === "n") {
		event.preventDefault();
		window.location.href = "collections/{{ url.collection }}/add";
	}
	if (window.duplicateObject && (event.metaKey || event.ctrlKey) && event.key.toLowerCase() === "d") {
		event.preventDefault();
		duplicateObject(event);
	}
	if ((event.metaKey || event.ctrlKey) && event.key.toLowerCase() === 'p') {
		const objectLink = document.querySelector('#collection-actions .object-link');
		if (objectLink && window.getComputedStyle(objectLink).display !== 'none') {
			event.preventDefault();
			objectLink.querySelector('a').click();
		}
	}
});
</script>

{% endblock %}
