{% extends "admin-dashboard.twig" %}

{% block dashcontent %}

<main class="dash-main-content" style="max-width:100%;">
	<header>
		<h1>{{ t('nav.extensions') }}</h1>
	</header>

	<section class="dash-content-section">
		{% if extensions is empty %}
		<div class="dash-empty-state">
			<p>No extensions installed.</p>
			<p>Place extensions in <code>tcms-data/extensions/vendor/name/</code></p>
		</div>
		{% else %}
		<div class="dash-card-grid">
			{% for ext in extensions %}
			<article class="dash-card{% if ext.error %} error{% endif %}{% if ext.enabled %} accent{% endif %}">
				<header>
					<div>
						<h3>{{ ext.name }}</h3>
						{% if ext.description %}
						<p style="margin:0.25rem 0 0; color:oklch(var(--totalform-darkgray)); font-size:0.85rem;">{{ ext.description }}</p>
						{% endif %}
					</div>
					<span class="dash-badge muted sm">v{{ ext.version }}</span>
				</header>

				{% if ext.author.name is defined and ext.author.name %}
				<p style="margin:0; font-size:0.8rem; color:oklch(var(--totalform-darkgray));">By {{ ext.author.name }}</p>
				{% endif %}

				{% if ext.error %}
				<div style="background:oklch(var(--totalform-danger) / 0.1); color:oklch(var(--totalform-danger)); border:1px solid oklch(var(--totalform-danger) / 0.3); border-radius:var(--totalform-radius); padding:0.5rem 0.75rem; font-size:0.8rem;">
					{{ ext.error }}
				</div>
				{% endif %}

				{% if ext.incompatibility %}
				<div style="background:oklch(var(--totalform-warning) / 0.1); color:oklch(var(--totalform-warning)); border:1px solid oklch(var(--totalform-warning) / 0.3); border-radius:var(--totalform-radius); padding:0.5rem 0.75rem; font-size:0.8rem;">
					<strong>Cannot be enabled:</strong>
					<ul style="margin:0.25rem 0 0 1rem; padding:0;">
						{% for reason in ext.incompatibility %}
						<li>{{ reason }}</li>
						{% endfor %}
					</ul>
				</div>
				{% endif %}

				{% set visibleLinks = ext.links|filter(link => ext.enabled or link.url starts with 'http://' or link.url starts with 'https://') %}
				{% if visibleLinks|length > 0 %}
				<div class="dash-card-detail" style="grid-template-columns:auto 1fr;">
					<strong>Links:</strong>
					<div class="dash-badge-group">
						{% for link in visibleLinks %}
						{% set external = link.url starts with 'http://' or link.url starts with 'https://' %}
						<a class="dash-badge" href="{{ link.url }}"{% if external %} target="_blank" rel="noopener noreferrer"{% endif %}>{{ link.label }}</a>
						{% endfor %}
					</div>
				</div>
				{% endif %}

				{% if ext.capabilities %}
				<div class="dash-card-detail" style="grid-template-columns:auto 1fr;">
					<strong>Capabilities:</strong>
					<div class="dash-badge-group">
						{% for cap in ext.capabilities %}
						<span class="dash-badge">{{ cap }}</span>
						{% endfor %}
					</div>
				</div>
				{% endif %}

				<footer>
					{% if ext.enabled %}
					<span class="dash-status enabled">Enabled</span>
					<div style="display:flex; gap:0.5rem; align-items:center;">
						{% if ext.hasSettings %}
						<a href="extensions/{{ ext.id }}/settings" class="dash-card-action edit" title="Settings" style="--icon-edit: var(--icon-cog);"></a>
						{% endif %}
						<form method="post" action="{{ cms.dashboard }}/extensions/{{ ext.id }}/disable" style="margin:0;">
							<button type="submit" class="btn btn-sm">Disable</button>
						</form>
					</div>
					{% else %}
					<span class="dash-status disabled">Disabled</span>
					{% if ext.incompatibility %}
					<button type="button" class="btn btn-sm" disabled title="Cannot be enabled: {{ ext.incompatibility|join('; ') }}">Enable</button>
					{% else %}
					<form method="post" action="{{ cms.dashboard }}/extensions/{{ ext.id }}/enable" style="margin:0;">
						<button type="submit" class="btn btn-sm btn-primary">Enable</button>
					</form>
					{% endif %}
					{% endif %}
				</footer>
			</article>
			{% endfor %}
		</div>
		{% endif %}
	</section>
</main>

{% endblock %}
