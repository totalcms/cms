{#
	Quick Navigation Index
	Builds a JSON array of all navigable admin items for the quick-nav dialog.
	Included in admin-dashboard.twig so it's available on every admin page.
#}
{# Recursive macro — flattens the builder pages tree into quick-nav entries.
   Children get a leading "↳ " so the nesting is visible in the search results
   without requiring the dialog itself to render the tree. #}
{% macro builderPageItems(pages, indent) %}
{% for page in pages %}
{"label":"{{ (indent ~ (page.title|default(page.id))) | e('js') }}","section":"Builder Pages","path":"builder/page/{{ page.id | e('js') }}","keywords":"builder page {{ page.route|default('') | e('js') }}"},
{% if page.children is defined and page.children is not empty %}
{{ _self.builderPageItems(page.children, indent ~ '↳ ') }}
{% endif %}
{% endfor %}
{% endmacro %}
