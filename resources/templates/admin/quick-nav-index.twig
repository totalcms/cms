window.TCMS_QUICK_NAV = [
{# ── Top-level nav items ── #}
{% if cms.auth.canAccessCollectionsOperation('read') %}
{"label":"{{ t('nav.collections') }}","section":"Navigation","path":"collections","keywords":"nav"},
{% endif %}
{% if cms.auth.canAccessSchemasOperation('read') %}
{"label":"{{ t('nav.schemas') }}","section":"Navigation","path":"schemas","keywords":"nav"},
{% endif %}
