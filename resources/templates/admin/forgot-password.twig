{% extends "admin-layout.twig" %}

{% block title %}Forgot Password - Total CMS{% endblock %}

{% block content %}
<main class="login-layout admin-layout">

	<section class="login-above">
		{{ include(cms.edition.can('whitelabel_templates')
			? ['whitelabel/forgot-password-above.twig', 'forgot-password-above.twig', 'forgot-password-above-default.twig']
			: cms.edition.can('templates')
			? ['forgot-password-above.twig', 'forgot-password-above-default.twig']
			: ['forgot-password-above-default.twig']
		, ignore_missing = true) }}
	</section>

	<section class="login-form">
		{% set action = cms.api ~ '/forgot-password' %}
		{% if collection %}
			{% set action = cms.api ~ '/forgot-password/' ~ collection %}
		{% endif %}

		<form class="totalform" method="post" action="{{ action }}" data-disabled="true" style="position:relative;">
			{{ csrf_field() }}

			<div class="form-field email-field" data-type="email">
				<label for="field-email">Email</label>
				<div class="form-group">
					<input type="email"
						   id="field-email"
						   name="email"
						   placeholder="email@company.com"
						   aria-describedby="help-email"
						   value="{{ getData.email | default('') }}"
						   required
						   autofocus>
					<div class="form-group-icon"></div>
				</div>
				<p class="help cms-hide" id="help-email">Enter the email address associated with your account</p>
			</div>

			<button class="dash-button" type="submit">Send Reset Link</button>

			{% for message in flash.get('error') %}
				<p class="cms-twig-error" role="alert">
					{{ message }}
				</p>
			{% endfor %}

			<p style="position:absolute;bottom:0;right:0;">
				<a href="{{ cms.api }}/login{% if collection %}/{{ collection }}{% endif %}"
				   style="color: oklch(var(--totalform-accent)); text-decoration: none;">
					&larr; Back to Login
				</a>
			</p>
		</form>

		{% for message in flash.get('success') %}
			<p class="cms-twig-info" role="alert">
				{{ message }}
			</p>
		{% endfor %}
	</section>

	<section class="login-below">
		{% if cms.edition.can('whitelabel_templates') %}
			{{ include('whitelabel/forgot-password-below.twig', ignore_missing = true) }}
		{% endif %}
	</section>
</main>

<script>
document.addEventListener('DOMContentLoaded', function() {
	const form = document.querySelector('.totalform');
	if (form) {
		form.addEventListener('submit', function() {
			form.classList.add('processing');
		});
	}
});
</script>
{% endblock %}
