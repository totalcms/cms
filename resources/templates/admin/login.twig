{% extends "admin-layout.twig" %}

{% block title %}{{ cms.config('dashboard', 'title') ?? 'Login to Total CMS' }}{% endblock %}

{% block content %}
<main class="login-layout admin-layout">

	<section class="login-above">
		{{ include(cms.edition.can('whitelabel_standard')
			? ['whitelabel/login-above.twig', 'login-above-default.twig']
			: ['login-above-default.twig']
		, ignore_missing = true) }}
	</section>

	{% set authCollection = cms.collection.objects(cms.config('auth','collection')) %}
	{% if authCollection is empty %}
		<div class="cms-twig-info" role="alert" style="margin:0">
			<h4>{{ t('login.setup_first_user') }}</h4>
			<p>{{ t('login.setup_first_user_desc') }}</p>
		</div>
	{% endif %}

	{% set errorMessages = [] %}
	{% for message in flash.get('error') %}
		{% set errorMessages = errorMessages|merge([message]) %}
	{% endfor %}
	{% set formSettings = {
		collection    : collection ?? null,
		redirect      : getData.redirect ?? null,
		flashMessages : errorMessages,
		showPasskeys  : authCollection is not empty and cms.config('auth', 'usePasskeys') != false
	} %}

	{% if cms.edition.can('whitelabel_standard') %}
		{% set json = include('whitelabel/login-options.twig', ignore_missing = true) %}
		{% set decoded = (json|trim|length ? json_decode(json, true) : {}) %}
		{% set formSettings = formSettings|merge(decoded) %}
	{% endif %}

	{{ cms.form.loginForm(formSettings) }}

	{# Surface a "resend verification email" link only when login failed
	   specifically because the account isn't active yet. Set by
	   AuthLoginSubmitAction when LoginService throws AccountNotActiveException.
	   This keeps the link out of operator-only login pages and out of the
	   way for users who just typed the wrong password. #}
	{% if flash.has('account_not_active') %}
		{# Consume the flash so it doesn't persist. #}
		{% set _ = flash.get('account_not_active') %}
		<p class="login-resend-verification" style="text-align:center; margin-top:1rem; font-size:0.9em;">
			<a href="{{ cms.dashboard }}/resend-verification{% if collection %}/{{ collection }}{% endif %}"
			   style="color: oklch(var(--totalform-accent)); text-decoration: none;">
				{{ t('verify.resend_link') }} &rarr;
			</a>
		</p>
	{% endif %}

	<section class="login-below">
		{% if cms.edition.can('whitelabel_pro') %}
			{{ include('whitelabel/login-below.twig', ignore_missing = true) }}
		{% endif %}
	</section>
</main>
{% endblock %}
