<h1>Schema Help</h1>

<section class="dash-content-section">
	<h2>{{ t('schema.what_is') }}</h2>
	<p>{{ t('schema.what_is_desc') }}</p>

	<h2>{{ t('schema.builtin_title') }}</h2>
	<p>{{ t('schema.builtin_desc') }}</p>

	<h2>{{ t('schema.custom_title') }}</h2>
	<p>
	{{ t('schema.custom_desc') }} "<a href="schemas/new">{{ t('schema.new') }}</a>" {{ t('schema.custom_desc_end') }}
	</p>

	<a style="margin-top:3rem" class="dash-button transparent" href="schemas/-import">{{ t('schema.import_new') }}</a>

	{% set inaccessibleSchemas = cms.admin.inaccessibleSchemas() %}
	{% if inaccessibleSchemas|length > 0 %}
	<div class="edition-alert">
		<span class="icon-warn"></span>
		<div class="edition-alert-content">
			<strong>{{ t('schema.unavailable', {count: inaccessibleSchemas|length}) }}</strong>
			<p>{{ t('schema.unavailable_desc', {schemas: inaccessibleSchemas|join(', ')}) }}</p>
			<a href="utils/license-manager" class="dash-button">Upgrade to Regain Access</a>
		</div>
	</div>
	{% endif %}

</section>
