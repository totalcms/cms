<header>
	<h1><a href="schemas">schemas</a> / <span>{{ url.schema }}</span></h1>
	<button class="dash-action-dots" title="Schema Actions" popovertarget="schema-actions"></button>
	<nav popover id="schema-actions">
		<ul>
			{% if cms.auth.canAccessSchema(url.schema, 'create') %}
			<li class="duplicate"><a href="#" onclick="duplicateSchema(event)">{{ t('btn.duplicate') }}</a></li>
			{% endif %}
			<li class="export"><a href="{{ cms.api }}/export/schemas/{{ url.schema }}" download target="_blank">{{ t('btn.export') }}</a></li>
			{% if cms.auth.canAccessSchema(url.schema, 'create') %}
			<li class="import"><a href="schemas/-import">{{ t('btn.import') }}</a></li>
			{% endif %}
		</ul>
	</nav>
</header>

{{ cms.form.schema({
	id          : url.schema,
	save        : cms.auth.canAccessSchema(url.schema, 'update') ? "Save" : false,
	delete      : cms.auth.canAccessSchema(url.schema, 'delete') ? "Delete" : false,
	helpStyle   : 'label',
	helpOnFocus : true,
	deleteActions : [
		{
			"action" : "redirect",
			"link"   : "schemas"
		}
	],
	editActions : [
		{
			"action" : "refresh",
		}
	],
}) }}

{% set inheritedProps = cms.schema.inheritedProperties(url.schema) %}
{% if inheritedProps|length > 0 %}
<div class="schema-inherited-properties">
	<h3>{{ t('schema.inherited_title') }}</h3>
	<p>{{ t('schema.inherited_desc') }}</p>
	<div class="inherited-properties-list">
		{% for propName, prop in inheritedProps %}
			<div class="schema-field {{ prop.field }}-field {{ prop.type }}-type">
				<span class="property-name">{{ propName }}</span>
				<button type="button"
						class="button override"
						data-property-name="{{ propName }}"
						data-property-definition="{{ prop.definition|merge({type: prop.type, field: prop.field})|json_encode|e('html_attr') }}"
						title="{{ t('schema.override') }}"></button>
				<span class="property-source">{{ t('schema.inherited_from') }} <a href="schemas/{{ prop.source }}">{{ prop.source }}</a></span>
			</div>
		{% endfor %}
	</div>
</div>
{% endif %}

{% set isDeckCompatible = cms.schema.isDeckCompatible(url.schema) %}
{% set incompatibleTypes = cms.schema.deckIncompatibleTypes(url.schema) %}

<div class="schema-deck-compatibility">
	{% if isDeckCompatible %}
		<div class="deck-compatible-message">
			<span class="status-icon compatible">✓</span>
			<strong>{{ t('schema.deck_compatible') }}</strong> {{ t('schema.deck_compatible_desc') }}
		</div>
	{% else %}
		<div class="deck-incompatible-message">
			<span class="status-icon incompatible">⚠</span>
			<strong>{{ t('schema.deck_incompatible') }}</strong> {{ t('schema.deck_incompatible_desc') }}
			{% if incompatibleTypes|length > 0 %}
				<br><small>{{ t('schema.deck_incompatible_types', {'{types}': incompatibleTypes|join(', ')}) }}</small>
			{% endif %}
		</div>
	{% endif %}
</div>

<style>
.schema-inherited-properties {
	margin-top    : 2rem;
	max-width : 800px;
}

.schema-inherited-properties h3 {
	margin-block : 0 0.25rem;
	font-size    : 1.2rem;
}

.schema-inherited-properties p {
	font-size    : 0.875rem;
	margin-block : 0 1rem;
	color        : oklch(var(--totalform-darkgray));
}

.inherited-properties-list {
	display : grid;
	gap     : 0.5rem;
}
.inherited-properties-list .schema-field {
	grid-template-columns : 1fr auto auto;
	gap: 0.5rem;
}

.schema-deck-compatibility {
	margin-top    : 1rem;
	padding       : 0.75rem 1rem;
	border        : 1px solid oklch(var(--totalform-border-color));
	border-radius : var(--totalform-radius);
	background    : oklch(var(--totalform-nearwhite));
	align-self    : end;
}

.deck-compatible-message {
	color: oklch(var(--totalform-success));
}

.deck-incompatible-message {
	color: oklch(var(--totalform-warning, 0.6 0.19 23.85));
}

.status-icon.compatible {
	color: oklch(var(--totalform-success));
}

.status-icon.incompatible {
	color: oklch(var(--totalform-warning, 0.6 0.19 23.85));
}

.schema-deck-compatibility small {
	color: oklch(var(--totalform-darkgray));
	font-style: italic;
}
</style>

<script>
function duplicateSchema(event) {
	event.preventDefault();

	// Create a temporary form to POST the schema ID to /admin/schemas/new
	const tempForm               = document.createElement('form');
	      tempForm.method        = 'POST';
	      tempForm.action        = 'schemas/new';
	      tempForm.style.display = 'none';

	// Just send the schema ID - server will fetch and process the data
	const input = document.createElement('input');
	input.type = 'hidden';
	input.name = 'duplicate';
	input.value = '{{ url.schema }}';
	tempForm.appendChild(input);

	document.body.appendChild(tempForm);
	tempForm.submit();
}
</script>