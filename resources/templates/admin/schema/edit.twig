<header>
	<h1><a href="schemas">schemas</a> / <span>{{ url.schema }}</span></h1>
	<button class="dash-action-dots" title="Schema Actions" popovertarget="schema-actions"></button>
	<nav popover id="schema-actions">
		<ul>
			{% if cms.canAccessSchema(url.schema, 'create') %}
			<li class="duplicate"><a href="#" onclick="duplicateSchema(event)">Duplicate</a></li>
			{% endif %}
			<li class="export"><a href="{{ cms.api }}/export/schemas/{{ url.schema }}" download target="_blank">Export</a></li>
			{% if cms.canAccessSchema(url.schema, 'create') %}
			<li class="import"><a href="schemas/-import">Import</a></li>
			{% endif %}
		</ul>
	</nav>
</header>

{{ cms.form.schema({
	id          : url.schema,
	save        : cms.canAccessSchema(url.schema, 'update') ? "Save" : false,
	delete      : cms.canAccessSchema(url.schema, 'delete') ? "Delete" : false,
	helpStyle   : 'label',
	helpOnFocus : true,
	deleteActions : [
		{
			"action" : "redirect",
			"link"   : "schemas"
		}
	],
	editActions : [
		{
			"action" : "refresh",
		}
	],
}) }}

{% set inheritedProps = cms.getInheritedProperties(url.schema) %}
{% if inheritedProps|length > 0 %}
<div class="schema-inherited-properties">
	<h3>Inherited Properties (Read-Only)</h3>
	<p>The following properties are inherited from other schemas and cannot be modified directly.
		To change them, edit the source schema.</p>
	<div class="inherited-properties-list">
		{% for propName, prop in inheritedProps %}
			<div class="schema-field {{ prop.field }}-field {{ prop.type }}-type">
				<span class="property-name">{{ propName }}</span>
				<span class="property-source">from <a href="schemas/{{ prop.source }}">{{ prop.source }}</a></span>
			</div>
		{% endfor %}
	</div>
</div>
{% endif %}

{% set isDeckCompatible = cms.isDeckCompatible(url.schema) %}
{% set incompatibleTypes = cms.getDeckIncompatibleTypes(url.schema) %}

<div class="schema-deck-compatibility">
	{% if isDeckCompatible %}
		<div class="deck-compatible-message">
			<span class="status-icon compatible">✓</span>
			<strong>Deck Compatible:</strong> This schema can be used as a deck property type.
		</div>
	{% else %}
		<div class="deck-incompatible-message">
			<span class="status-icon incompatible">⚠</span>
			<strong>Deck Incompatible:</strong> This schema cannot be used as a deck property type.
			{% if incompatibleTypes|length > 0 %}
				<br><small>Incompatible property types: {{ incompatibleTypes|join(', ') }}</small>
			{% endif %}
		</div>
	{% endif %}
</div>

<style>
.schema-inherited-properties {
	margin-top    : 2rem;
	max-width : 800px;
}

.schema-inherited-properties h3 {
	margin-block : 0 0.25rem;
	font-size    : 1.2rem;
}

.schema-inherited-properties p {
	font-size    : 0.875rem;
	margin-block : 0 1rem;
	color        : oklch(var(--totalform-darkgray));
}

.inherited-properties-list {
	display : grid;
	gap     : 0.5rem;
}
.inherited-properties-list .schema-field {
	grid-template-columns : 1fr auto;
}

.schema-deck-compatibility {
	margin-top    : 1rem;
	padding       : 0.75rem 1rem;
	border        : 1px solid oklch(var(--totalform-border-color));
	border-radius : var(--totalform-radius);
	background    : oklch(var(--totalform-nearwhite));
	align-self    : end;
}

.deck-compatible-message {
	color: oklch(var(--totalform-success));
}

.deck-incompatible-message {
	color: oklch(var(--totalform-warning, 0.6 0.19 23.85));
}

.status-icon.compatible {
	color: oklch(var(--totalform-success));
}

.status-icon.incompatible {
	color: oklch(var(--totalform-warning, 0.6 0.19 23.85));
}

.schema-deck-compatibility small {
	color: oklch(var(--totalform-darkgray));
	font-style: italic;
}
</style>

<script>
function duplicateSchema(event) {
	event.preventDefault();
	// Get the current form data
	const form = document.querySelector('form[data-form="schema"]');
	if (!form || !form.totalform) {
		console.error('Schema form not found');
		return;
	}

	const formData = form.totalform.generateData();

	// Create a temporary form to POST the data to /admin/schemas/new
	const tempForm               = document.createElement('form');0
	      tempForm.method        = 'POST';
	      tempForm.action        = 'schemas/new';
	      tempForm.style.display = 'none';

	// Add form data as hidden inputs
	for (const [key, value] of Object.entries(formData)) {
		const input = document.createElement('input');
		input.type = 'hidden';
		input.name = key;
		input.value = typeof value === 'object' ? JSON.stringify(value) : value;
		tempForm.appendChild(input);
	}

	document.body.appendChild(tempForm);
	tempForm.submit();
}
</script>