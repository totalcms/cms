{% extends "admin-dashboard.twig" %}

{% set sections = {
	'installation': {
		'label': t('settings.installation'),
		'description': t('settings.installation_desc')
	},
	'general': {
		'label': t('settings.general'),
		'description': t('settings.general_desc')
	},
	'auth': {
		'label': t('settings.authentication'),
		'description': t('settings.authentication_desc')
	},
	'cache': {
		'label': t('settings.cache'),
		'description': t('settings.cache_desc')
	},
	'dashboard': {
		'label': t('settings.dashboard'),
		'description': t('settings.dashboard_desc')
	},
	'htmlclean': {
		'label': t('settings.html_sanitization'),
		'description': t('settings.html_sanitization_desc')
	},
	'imageworks': {
		'label': t('settings.imageworks'),
		'description': t('settings.imageworks_desc')
	},
	'mailer': {
		'label': t('settings.mailer'),
		'description': t('settings.mailer_desc')
	},
	'pushnotif': {
		'label': t('settings.pushnotif'),
		'description': t('settings.pushnotif_desc')
	},
	'presets': {
		'label': t('settings.presets'),
		'description': t('settings.presets_desc')
	},
	'smtp': {
		'label': t('settings.smtp'),
		'description': t('settings.smtp_desc')
	},
	'sync': {
		'label': t('settings.sync'),
		'description': t('settings.sync_desc')
	},
	'builder': {
		'label': 'Builder',
		'description': 'Site Builder stub generation settings'
	},
} %}

{% if cms.license.canSimulateEdition() %}
	{% set sections = sections|merge({
		'license': {
			'label': t('settings.license_simulator'),
			'description': t('settings.license_simulator_desc')
		}
	}) %}
{% endif %}

{% block dashcontent %}

<aside class="dash-content-sidebar">
	<header>
		<input type="search" name="filter" class="filter" placeholder="{{ t('settings.filter') }}" autofocus />
	</header>

	<nav class="links" id="settings-links">
		<ul>
			{% for sectionId, section in sections %}
			<li class="settings-{{ sectionId }}">
				<a {% if url.section == sectionId %}class="active"{% endif %}
					href="settings/{{ sectionId }}"
					title="{{ section.description }}">{{ section.label }}</a>
			</li>
			{% endfor %}
		</ul>
	</nav>
</aside>

<main class="dash-main-content">
	<header>
		<h1><a href="settings">settings</a> / <span>{{ sections[currentSection].label | lower }}</span></h1>
	</header>

	<section class="dash-content-section">
		{% if sections[currentSection].description %}
		<p>{{ sections[currentSection].description }}</p>
		{% endif %}

		{% if currentSection == 'presets' %}
		<div class="cms-info">
			<p><strong>Named presets</strong> &mdash; Reference a preset by name in a schema property's settings with <code>"preset": "my-preset-name"</code>. The preset's settings become the base, and any additional field settings override them.</p>
			<p><strong>Type defaults</strong> &mdash; Name a preset after a field type (e.g., <code>styledtext</code>, <code>image</code>) and it will automatically apply to every field of that type that has no settings defined at the schema, collection, or object level.</p>
		</div>
		{% endif %}

		{{ cms.form.settings(currentSection) }}

		{% if currentSection == 'smtp' %}
		<section class="dash-content-section" style="margin-top: 40px;">
			<h2>{{ t('settings.smtp_test_title') }}</h2>

			{% if testResult is defined %}
				{% if testResult.success %}
					<p class="cms-success" role="alert">{{ testResult.message }}</p>
				{% else %}
					<p class="cms-error" role="alert">{{ testResult.message }}</p>
				{% endif %}
			{% else %}
				<p>{{ t('settings.smtp_test_desc') }}</p>

				{{ cms.form.simple('settings/smtp?test=1', '
					<div class="field-wrapper field-email">
						<label for="test_email">' ~ t('settings.smtp_test_email') ~ '</label>
						<input type="email" id="test_email" name="test_email" placeholder="'~ t('settings.smtp_test_ph') ~'" required />
						<div class="help">'~ t('settings.smtp_test_help') ~'</div>
					</div>
				', {
					'method': 'POST',
					'label': t('settings.smtp_test_btn'),
					'buttonClass': 'cms-secondary',
					'ajax': false
				}) }}
			{% endif %}
		</section>
		{% endif %}

		{% if currentSection == 'pushnotif' %}
		<section class="dash-content-section" style="margin-top: 40px;">
			<h2>{{ t('settings.pushnotif_test_title') }}</h2>

			{% if testResult is defined %}
				{% if testResult.success %}
					<p class="cms-success" role="alert">{{ testResult.message }}</p>
				{% else %}
					<p class="cms-error" role="alert">{{ testResult.message }}</p>
				{% endif %}
			{% else %}
				<p>{{ t('settings.pushnotif_test_desc') }}</p>

				{{ cms.form.simple('settings/pushnotif?test=1', '
					<div class="field-wrapper field-text">
						<label for="test_message">' ~ t('settings.pushnotif_test_message') ~ '</label>
						<input type="text" id="test_message" name="test_message" placeholder="'~ t('settings.pushnotif_test_ph') ~'" />
						<div class="help">'~ t('settings.pushnotif_test_help') ~'</div>
					</div>
				', {
					'method': 'POST',
					'label': t('settings.pushnotif_test_btn'),
					'buttonClass': 'cms-secondary',
					'ajax': false
				}) }}
			{% endif %}
		</section>
		{% endif %}
	</section>
</main>

{% endblock %}
