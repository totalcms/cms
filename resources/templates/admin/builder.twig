{% extends "admin-dashboard.twig" %}

{% block dashcontent %}

<aside class="dash-content-sidebar">
	<header>
		<input type="search" name="filter" class="filter" placeholder="Filter templates..." autofocus />
	</header>

	<nav class="links" id="builder-links">
		{% set fileTree = cms.admin.builderFileTree() %}
		{% for category, templates in fileTree %}
		<details id="category-{{ category }}" {% if templates is not empty %}open{% endif %}>
			<summary>{{ category }}</summary>
			<ul>
			{% for template in templates %}
				<li class="builder-{{ category }}">
					<a {% if url.file == template.path %}class="active"{% endif %}
						href="builder/{{ template.path }}"
						title="{{ template.id }}">{{ template.id }}</a>
				</li>
			{% endfor %}
			{% if templates is empty %}
				<li class="empty">no {{ category }} yet</li>
			{% endif %}
			</ul>
		</details>
		{% endfor %}
	</nav>

	<footer>
		<a class="dash-button full transparent" href="builder/new" title="Create a new template">+ New Template</a>
	</footer>
</aside>
{% include "admin/sidebar-details.twig" %}

<main class="dash-main-content">

	{% if url.section == 'new' %}

		{% include "admin/builder/new.twig" %}

	{% elseif url.file is not empty %}

		{% include "admin/builder/editor.twig" %}

	{% else %}

		{% include "admin/builder/overview.twig" %}

	{% endif %}

	<section id="builder-notices"></section>
</main>

{% endblock %}
