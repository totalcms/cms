{% extends "admin-layout.twig" %}

{% block title %}{{ cms.config('dashboard', 'title') ?? 'Access Denied' }}{% endblock %}

{% block content %}
<main class="login-layout admin-layout">

	{% set referer = cms.sessionData('requestRefererUrl') ?? cms.config('auth', 'deniedDefaultRedirect') %}

	<section >
		<h1>Access Denied</h1>
		<p>You do not have permission to access this page.</p>
		<p><a href="{{ referer }}">Return to the previous page</a></p>

		{% for message in flash.get('error') %}
			<p class="cms-twig-error" role="alert">
				{{ message }}
			</p>
		{% endfor %}
	</section>

	<meta http-equiv="refresh" content="{{ cms.config('auth', 'deniedTimeout') }};url={{ referer }}">

</main>
{% endblock %}
