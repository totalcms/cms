{% extends "admin-layout.twig" %}

{% block title %}{{ cms.config('dashboard', 'title') ?? 'Reset Password - Total CMS' }}{% endblock %}

{% block content %}
<main class="login-layout admin-layout">

	<section class="login-above">
		{{ include(cms.edition.can('whitelabel_standard')
			? ['whitelabel/reset-password-above.twig', 'reset-password-above-default.twig']
			: ['reset-password-above-default.twig']
		, ignore_missing = true) }}
	</section>

	{% set formSettings = {} %}
	{% if cms.edition.can('whitelabel_standard') %}
		{% set json = include('whitelabel/reset-password-options.twig', ignore_missing = true) %}
		{% set decoded = (json|trim|length ? json_decode(json, true) : {}) %}
		{% set formSettings = formSettings|merge(decoded) %}
	{% endif %}

	{# TODO: Refactor to use cms.form.resetPasswordForm() method for consistency #}
	<section class="login-form">
		{% set action = cms.api ~ '/reset-password/' ~ token %}

		<form class="totalform" method="post" action="{{ action }}" data-disabled="true">
			{{ csrf_field() }}

			<input type="hidden" name="token" value="{{ token }}">
			{% if redirect %}<input type="hidden" name="redirect" value="{{ redirect }}">{% endif %}

			<div class="form-field password-field" data-type="password">
				<label for="field-password">{{ formSettings.passwordLabel | default(t('reset.new_password')) }}</label>
				<div class="form-group">
					<input type="password"
						   id="field-password"
						   name="password"
						   placeholder="{{ t('reset.new_password_ph') }}"
						   aria-describedby="help-password"
						   required
						   autofocus
						   minlength="4">
					<div class="form-group-icon"></div>
				</div>
				<p class="help cms-hide" id="help-password">{{ t('reset.password_help') }}</p>
			</div>

			<div class="form-field password-field" data-type="password">
				<label for="field-password-confirm">{{ formSettings.confirmPasswordLabel | default(t('reset.confirm_password')) }}</label>
				<div class="form-group">
					<input type="password"
						   id="field-password-confirm"
						   name="password_confirm"
						   placeholder="{{ t('reset.confirm_password_ph') }}"
						   aria-describedby="help-password-confirm"
						   required
						   minlength="4"
						   class="allow-enter">
					<div class="form-group-icon"></div>
				</div>
				<p class="help cms-hide" id="help-password-confirm">{{ t('reset.confirm_help') }}</p>
			</div>

			<button class="dash-button" type="submit">{{ formSettings.submitLabel | default(t('reset.submit')) }}</button>

		</form>

		{% for message in flash.get('error') %}
			<p class="cms-twig-error" role="alert">
				{{ message }}
			</p>
		{% endfor %}
	</section>

	<section class="login-below">
		{% if cms.edition.can('whitelabel_pro') %}
			{{ include('whitelabel/reset-password-below.twig', ignore_missing = true) }}
		{% endif %}
	</section>
</main>
{% endblock %}
