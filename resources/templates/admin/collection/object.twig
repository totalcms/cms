{# Edit Object Form #}
{% set canSave = cms.canAccessCollection(url.collection, url.id ? 'update' : 'create') %}
{% set canDelete = cms.canAccessCollection(url.collection, 'delete') %}

{# Default hardcoded options #}
{% set defaultOptions = {
	id          : url.id,
	save        : canSave ? "Save" : false,
	delete      : canDelete ? "Delete" : false,
	helpStyle   : 'label',
	helpOnFocus : true,
} %}

{# Default hardcoded actions #}
{% set defaultDeleteActions = [
	{
		"action" : "redirect",
		"link"   : "collections/#{url.collection}"
	}
] %}

{# Merge formSettings from collection, prepending formSettings actions #}
{% set formSettings = collection.formSettings ? collection.formSettings : {} %}
{% set finalOptions = defaultOptions|merge(formSettings) %}

{# Prepend formSettings actions to default actions #}
{% if formSettings.editActions is defined %}
	{% set finalOptions = finalOptions|merge({
		editActions: formSettings.editActions
	}) %}
{% endif %}

{% if formSettings.deleteActions is defined %}
	{% set finalOptions = finalOptions|merge({
		deleteActions: formSettings.deleteActions|merge(defaultDeleteActions)
	}) %}
{% else %}
	{% set finalOptions = finalOptions|merge({
		deleteActions: defaultDeleteActions
	}) %}
{% endif %}

{% set form = cms.form.builder(url.collection, finalOptions) %}
{{ form.autoBuild() }}

{% if url.id %}
<script>
function duplicateObject(event) {
	event.preventDefault();

	// Create a temporary form to POST the object ID to /admin/collections/{collection}/add
	const tempForm               = document.createElement('form');
	      tempForm.method        = 'POST';
	      tempForm.action        = 'collections/{{ url.collection }}/add';
	      tempForm.style.display = 'none';

	// Just send the object ID - server will fetch and filter the data
	const input = document.createElement('input');
	input.type = 'hidden';
	input.name = 'duplicate';
	input.value = '{{ url.id }}';
	tempForm.appendChild(input);

	document.body.appendChild(tempForm);
	tempForm.submit();
}
</script>
<style>
#collection-actions .duplicate {
	display: list-item !important;
}
</style>
{% endif %}
