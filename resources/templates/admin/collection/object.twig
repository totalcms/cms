{# Edit Object Form #}
{% set form = cms.form.builder(url.collection, {
	id           : url.id,
	save         : "Save",
	delete       : "Delete",
	helpStyle    : 'label',
	helpOnFocus  : true,
	deleteActions : [
		{
			"action" : "redirect",
			"link"   : "collections/#{url.collection}"
		}
	],
}) %}
{{ form.autoBuild() }}
