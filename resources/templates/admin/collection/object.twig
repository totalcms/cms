{# Edit Object Form #}
{% set canSave = cms.canAccessCollection(url.collection, url.id ? 'PUT' : 'POST') %}
{% set canDelete = cms.canAccessCollection(url.collection, 'DELETE') %}
{% set form = cms.form.builder(url.collection, {
	id           : url.id,
	save         : canSave ? "Save" : false,
	delete       : canDelete ? "Delete" : false,
	helpStyle    : 'label',
	helpOnFocus  : true,
	deleteActions : [
		{
			"action" : "redirect",
			"link"   : "collections/#{url.collection}"
		}
	],
}) %}
{{ form.autoBuild() }}
