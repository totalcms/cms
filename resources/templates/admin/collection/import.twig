<section style="display:grid;align-content:start;gap:3rem">

	<section class="import-queue">
		<h3 style="margin-bottom:1rem">{{ t('collection.import_queue_title', {'{collection}': url.collection | title}) }}</h3>
		{{ cms.form.jobqueueStats({
			collection : url.collection,
		}) }}
	</section>

	<p>{{ t('collection.import_note', {'{collection}': url.collection}) }}</p>

	<section class="import-forms">
		<details class="cms-accordion">
			<summary>{{ t('collection.import_csv_title', {'{collection}': url.collection | title}) }}</summary>
			<div class="content" style="margin-bottom:2rem">
				<p>{{ t('collection.import_csv_desc') }}</p>

				{{ cms.form.importCollection(url.collection, {
					input : 'csv'
				}) }}
			</div>
		</details>

		<details class="cms-accordion">
			<summary>{{ t('collection.import_json_title', {'{collection}': url.collection | title}) }}</summary>
			<div class="content" style="margin-bottom:2rem">
				<p>{{ t('collection.import_json_desc') }}</p>
				{{ cms.form.importCollection(url.collection, {
					input : 'json'
				}) }}
			</div>
		</details>

		<details class="cms-accordion">
			<summary>Import CSV into Deck</summary>
			<div class="content" style="margin-bottom:2rem">
				<p>Import CSV rows as deck items into an object. Each row becomes a deck item. CSV column headers should match deck schema field names.</p>
				{{ cms.form.importDeck(url.collection) }}
			</div>
		</details>

		<details class="cms-accordion">
			<summary>{{ t('collection.import_manage_title', {'{collection}': url.collection | title}) }}</summary>
			<div class="content" style="margin-bottom:2rem">
				<p>{{ t('collection.import_manage_desc') }}</p>

				{{ cms.form.clearqueue({
					collection : url.collection,
					label      : t('collection.clear_import_queue'),
				}) }}
			</div>
		</details>
	</section>

	<script>
	document.addEventListener("DOMContentLoaded", event => {
		const container = document.querySelector(".import-forms");
		if (container) {
			const accordion = new Details(container, {openFirst:true});
		}
	});
	</script>

</section>
