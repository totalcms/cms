<section style="display:grid;align-content:start;gap:3rem">

	<section class="import-queue">
		<h3 style="margin-bottom:1rem">Import Queue for {{ url.collection | title }}</h3>
		{{ cms.form.jobqueueStats({
			collection : url.collection,
		}) }}
	</section>

	<p><strong>Note:</strong> If you are importing a lot of new objects, you may want to enable the
	<code>Queue Rebuild Index on Save</code> option in your
	<a href="collections/{{ url.collection }}/edit">collection settings</a>. This process may take some time.
	You will also want to make sure that you have configured the cron job from the
	<a href="utils/jobqueue">Job Queue Manager</a>.</p>

	<section class="import-forms">
		<details class="cms-accordion">
			<summary>CSV Import into {{ url.collection | title }}</summary>
			<div class="content" style="margin-bottom:2rem">
				<p>Choose a CSV file where the first row contains the names of the object properties
				that you will be adding to each object imported.
				<a href="docs/import">See Import Docs</a>.</p>

				{{ cms.form.importCollection(url.collection, {
					input : 'csv'
				}) }}
			</div>
		</details>

		<details class="cms-accordion">
			<summary>JSON Import into {{ url.collection | title }}</summary>
			<div class="content" style="margin-bottom:2rem">
				<p>Choose a JSON file. The main stucture of the JSON document should be an array of objects.
				<a href="docs/import">See Import Docs</a>.</p>
				{{ cms.form.importCollection(url.collection, {
					input : 'json'
				}) }}
			</div>
		</details>

		<details class="cms-accordion">
			<summary>Manage Import Queue for {{ url.collection | title }}</summary>
			<div class="content" style="margin-bottom:2rem">
				<p>This will clear the all the pending import jobs for <em><u>just this collection</u></em>.
				This will not delete any items that have already been imported.</p>

				{{ cms.form.clearqueue({
					collection : url.collection,
					label      : 'Clear Import Queue',
				}) }}
			</div>
		</details>
	</section>

	<script>
	document.addEventListener("DOMContentLoaded", event => {
		const container = document.querySelector(".import-forms");
		if (container) {
			const accordion = new Details(container, {openFirst:true});
		}
	});
	</script>

</section>
