{# Collection Object Table #}
{% set objects = cms.objects(url.collection) %}
{% set collection = cms.collection(url.collection) %}

{# Performance warning for large collections without queue rebuild enabled #}
{% set performanceThreshold = 1500 %}
{% set actualObjectCount = objects | length %}
{# Debug output - remove after testing #}
{% if actualObjectCount >= performanceThreshold and not collection.queueRebuildOnSave %}
	<div class="performance-warning">
		<h4>⚠️ Performance Recommendation</h4>
		<p>This collection has <strong>{{ actualObjectCount | number_format }}</strong> objects. Consider enabling
		<strong>"Queue Rebuild on Save"</strong> in the
		<a href="collections/{{ url.collection }}/edit">collection settings</a> to prevent slow saves.</p>
	</div>
{% endif %}

{% if objects|length > 0 %}

	{{ cms.form.collectionTable(url.collection) }}

{% else %}

	{% set labelPlural = cms.collection(url.collection).labelPlural|default('objects') %}
	<p>No {{ labelPlural }} in this collection yet.</p>

{% endif %}
