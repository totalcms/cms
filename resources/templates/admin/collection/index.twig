{# Collection Object Table #}
{% set collection = cms.collection.get(url.collection) %}
{% set labelPlural = collection.labelPlural|default('objects') %}
{# Use totalObjects from collection metadata - avoids loading full index #}
{% set actualObjectCount = collection.totalObjects|default(0) %}

{# Performance warning for large collections without queue rebuild enabled #}
{% set performanceThreshold = 2500 %}

{% if actualObjectCount >= performanceThreshold and not collection.queueRebuildOnSave %}
	<div class="performance-warning">
		<div>
			<h4>{{ t('collection.perf_recommendation') }}</h4>
			<p>{{ t('collection.perf_message', {'{count}': actualObjectCount | number_format, '{label}': labelPlural | lower, '{collection}': url.collection}) }}</p>
		</div>
	</div>
{% endif %}

{% if actualObjectCount > 0 %}

	{{ cms.render.collectionTable(url.collection) }}

{% else %}

	<p>{{ t('collection.empty', {'{label}': labelPlural}) }}</p>

{% endif %}
