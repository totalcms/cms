<section class="dash-content-section">

	<h2>{{ t('collection.sitemap_title', {'{collection}': url.collection}) }}</h2>
	<p>{{ t('collection.sitemap_desc') }}</p>

	{% set collection = cms.collection.get(url.collection) %}
	{% set schema = cms.schema.get(collection.schema) %}
	{% set frequencies = {
		"always"  : t('sitemap.freq_always'),
		"hourly"  : t('sitemap.freq_hourly'),
		"daily"   : t('sitemap.freq_daily'),
		"weekly"  : t('sitemap.freq_weekly'),
		"monthly" : t('sitemap.freq_monthly'),
		"yearly"  : t('sitemap.freq_yearly'),
		"never"   : t('sitemap.freq_never'),
	 } %}

	<form id="sitemap-builder"
		class="totalform"
		method="POST"
		data-disabled>
		<div>
			<label for="date">{{ t('collection.sitemap_date_prop') }}</label>
			<select name="date">
				<option value="">{{ t('collection.sitemap_select_prop') }}</option>
				{% for property in schema.index %}
					<option value="{{ property }}"
						{% if postData.date == property %}selected{% endif %}>
						{{ property }}
					</option>
				{% endfor %}
			</select>
			<label for="include">{{ t('collection.sitemap_include') }}</label>
			<select name="include">
				<option value="">{{ t('collection.sitemap_select_prop') }}</option>
				{% for property in schema.index %}
					<option value="{{ property }}"
						{% if postData.include == property %}selected{% endif %}>
						{{ property }}
					</option>
				{% endfor %}
			</select>
			<label for="exclude">{{ t('collection.sitemap_exclude') }}</label>
			<select name="exclude">
				<option value="">{{ t('collection.sitemap_select_prop') }}</option>
				{% for property in schema.index %}
					<option value="{{ property }}"
						{% if postData.exclude == property %}selected{% endif %}>
						{{ property }}
					</option>
				{% endfor %}
			</select>
			<label for="frequency">{{ t('collection.sitemap_frequency') }}</label>
			<select name="frequency">
				<option value="">{{ t('collection.sitemap_select_freq') }}</option>
				{% for value, label in frequencies %}
					<option value="{{ value }}"
						{% if postData.frequency == value %}selected{% endif %}>
						{{ label }}
					</option>
				{% endfor %}
			</select>
			<label for="priority">{{ t('collection.sitemap_priority') }}</label>
			<input type="number" step="0.1" min="0" max="1" name="priority" value="{{ postData.priority }}" placeholder="1.0"/>

			<h4>{{ t('collection.sitemap_priority_examples') }}</h4>
			<ul>
				<li>{{ t('collection.sitemap_priority_10') }}</li>
				<li>{{ t('collection.sitemap_priority_08') }}</li>
				<li>{{ t('collection.sitemap_priority_05') }}</li>
				<li>{{ t('collection.sitemap_priority_03') }}</li>
				<li>{{ t('collection.sitemap_priority_01') }}</li>
			</ul>
		</div>
		<button class="cms-button" type="submit">{{ t('collection.sitemap_generate') }}</button>
	</form>

	{% set query = http_build_query(postData) %}
	{% if str_starts_with(cms.api, "http") %}
		{% set api = cms.api %}
	{% else %}
		{% set api = "https://" ~ cms.domain ~ cms.api %}
	{% endif %}

	{% set sitemapurl = api ~ "/sitemap/" ~ url.collection %}
	{% if query is not empty %}
		{% set sitemapurl = sitemapurl ~ "?" ~ query %}
	{% endif %}

	<h3>{{ t('collection.sitemap_url') }}</h3>
	<div>
		<pre><code>{{ sitemapurl }}</code></pre>
		<p style="margin-top:0;font-size:0.9em"><a href="{{ sitemapurl }}" target="_blank">{{ t('collection.sitemap_link') }} ↗</a></p>
	</div>

	{% if collection.url is empty %}
	<p class="cms-error">{{ t('collection.sitemap_no_url') }}</p>
	{% endif %}

</section>
