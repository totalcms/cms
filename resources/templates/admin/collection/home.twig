<h1>{{ t('collection.help_title') }}</h1>

<section class="dash-content-section">
	<section>
	<h2>{{ t('collection.what_is') }}</h2>
	<p>{{ t('collection.what_is_desc') }}</p>
	</section>

	<section>
	<h2>{{ t('collection.setup_default') }}</h2>
	<p>{{ t('collection.setup_default_desc') }}</p>
	</section>

	<a class="dash-button transparent" href="utils/project-setup">{{ t('collection.project_setup_tool') }}</a>

	{% set inaccessibleCollections = cms.admin.inaccessibleCollections() %}
	{% if inaccessibleCollections|length > 0 %}
	<div class="edition-alert">
		<span class="icon-warn"></span>
		<div class="edition-alert-content">
			<strong>{{ t('collection.unavailable', {'{count}': inaccessibleCollections|length}) }}</strong>
			<p>{{ t('collection.unavailable_desc') }}</p>
			<ul>
			{% for collection in inaccessibleCollections %}
				<li>{{ collection.label ?? collection.id }} <code>{{ collection.schema }}</code></li>
			{% endfor %}
			</ul>
			<a href="utils/license-manager" class="dash-button">{{ t('collection.upgrade') }}</a>
		</div>
	</div>
	{% endif %}
</section>
