{% extends "admin-layout.twig" %}

{% block title %}{{ cms.config('dashboard', 'title') ?? 'Download Authentication' }}{% endblock %}

{% block content %}
<main class="login-layout admin-layout">

	<section class="download-auth-above">
		{% if cms.edition.can('whitelabel_templates') %}
			{{ include('whitelabel/download-auth-above.twig', ignore_missing = true) }}
		{% endif %}
	</section>

	{% set formSettings = {} %}
	{% if cms.edition.can('templates') %}
		{% set json = include(cms.edition.can('whitelabel_templates')
			? ['whitelabel/download-auth-options.twig', 'download-auth-options.twig']
			: ['download-auth-options.twig']
		, ignore_missing = true) %}
		{% set decoded = (json|trim|length ? json_decode(json, true) : {}) %}
		{% set formSettings = formSettings|merge(decoded) %}
	{% endif %}

	{# TODO: Refactor to use cms.form.downloadAuthForm() method for consistency #}
	<section class="login-form">
		<form class="totalform" method="post" data-disabled="true">
			<div class="form-field password-field" data-type="password">
				<label for="field-66e386299dfa7">{{ formSettings.passwordLabel | default(t('download_auth.password_label')) }}</label>
				<div class="form-group">
					<input type="password" id="field-66e386299dfa7" name="password" placeholder="p@ssw0rd" aria-describedby="help-66e386299dfa7" required>
					<div class="form-group-icon"></div>
				</div>
				<p class="cms-hide help" id="help-66e386299dfa7">{{ t('download_auth.password_ph') }}</p>
			</div>

			<button class="dash-button" type="submit">{{ formSettings.submitLabel | default(t('download_auth.submit')) }}</button>
			{% for message in flash.get('error') %}
				<p class="cms-twig-error" role="alert">
					{{ message }}
				</p>
			{% endfor %}
		</form>
	</section>

	<section class="download-auth-below">
		{% if cms.edition.can('whitelabel_templates') %}
			{{ include('whitelabel/download-auth-below.twig', ignore_missing = true) }}
		{% endif %}
	</section>

</main>
{% endblock %}
