<h1>Server Checker</h1>

<section class="dash-content-section server-checker">

	{% if not cms.checker.bundleCheck %}
	<div class="bundle-error">
		<h2>Total CMS Installation Integrity Failed</h2>
		<p>Your Total CMS installation has been modified. For the safety of your website,
		the CMS has been disabled. Please reinstall Total CMS. All disabled functionality will
		be restored once the situation has been remedied.</p>
	</div>
	{% endif %}

	<h2>License Information</h2>
	<table class="admin-table">
		<thead>
			<tr><th>License Item</th><th>Value</th></tr>
		</thead>
		{% for key, value in cms.checker.serverInfo %}
		{% if key starts with 'License' or key starts with 'Trial' or key starts with 'Updates' or key starts with 'Licensed' or key starts with 'DNS' or key starts with 'Has JWT' or key starts with 'Allowed' or key starts with 'Testing' %}
		<tr>
			<td>{{ key }}</td>
			<td>
				{% if key == 'License Status' %}
					{% if value == 'Valid' %}
						<span class="success">{{ value }}</span>
					{% elseif value == 'Invalid' %}
						<span class="error">❌ {{ value }}</span>
					{% else %}
						<span class="warning">⚠️ {{ value }}</span>
					{% endif %}
				{% elseif key == 'Trial Active' and value == 'Yes' %}
					<span class="warning">⚠️ {{ value }}</span>
				{% elseif key == 'Updates Valid' %}
					{% if value == 'Yes' %}
						<span class="success">{{ value }}</span>
					{% else %}
						<span class="warning">⚠️ {{ value }}</span>
					{% endif %}
				{% elseif key == 'DNS Verified' %}
					{% if value == 'Yes' %}
						<span class="success">{{ value }}</span>
					{% else %}
						<span class="warning">⚠️ {{ value }}</span>
					{% endif %}
				{% elseif key == 'License Cache Valid' %}
					{% if value == 'Yes' %}
						<span class="success">{{ value }}</span>
					{% else %}
						<span class="warning">⚠️ {{ value }}</span>
					{% endif %}
				{% else %}
					{{ value }}
				{% endif %}
			</td>
		</tr>
		{% endif %}
		{% endfor %}
	</table>

	<h2>Server Info</h2>
	<table class="admin-table">
		<thead>
			<tr><th>Info</th><th>Value</th></tr>
		</thead>
		{% for key, value in cms.checker.serverInfo %}
		{% if not (key starts with 'License' or key starts with 'Trial' or key starts with 'Updates' or key starts with 'Licensed' or key starts with 'DNS' or key starts with 'Has JWT' or key starts with 'Allowed' or key starts with 'Testing') %}
		<tr>
			<td>{{ key }}</td>
			<td>{{ value }}</td>
		</tr>
		{% endif %}
		{% endfor %}
	</table>

	<h2>Permissions Check</h2>
	<table class="admin-table">
		<thead>
			<tr><th>Directory</th><th>Check</th></tr>
		</thead>
		{% for key, value in cms.checker.checkPermissions %}
		<tr>
			<td>{{ key }}</td>
			<td>{{ value ? "Passed" : '<span class="error">Failed: Needs Write Permissions</span>' }}</td>
		</tr>
		{% endfor %}
	</table>

	<h2>Required Software Check</h2>
	<table class="admin-table">
		<thead>
			<tr><th>Software</th><th>Check</th></tr>
		</thead>
		{% for key, value in cms.checker.checkRequiredSoftware %}
		<tr>
			<td>{{ key }}</td>
			<td>{{ value ? "Installed" : '<span class="error">Not Installed</span>' }}</td>
		</tr>
		{% endfor %}
	</table>

	<h2>Optional Software Check</h2>
	<table class="admin-table">
		<thead>
			<tr>
				<th>Extension</th>
				<th>Status</th>
				<th>Description</th>
				<th>Recommended For</th>
				<th>Performance Impact</th>
			</tr>
		</thead>
		{% for extension, details in cms.checker.getOptionalSoftwareDetails %}
		<tr>
			<td><strong>{{ extension | upper }}</strong></td>
			<td>
				{% if details.available %}
					<span class="success">✅ Installed</span>
				{% else %}
					<span class="warning">⚠️ Not Installed</span>
				{% endif %}
			</td>
			<td>{{ details.description }}</td>
			<td>
				{% if extension == 'opcache' and not details.available %}
					<strong style="color: #d63031;">{{ details.recommendation }}</strong>
				{% else %}
					{{ details.recommendation }}
				{% endif %}
			</td>
			<td>
				{% if extension == 'opcache' and not details.available %}
					<strong style="color: #00b894;">{{ details.performance_impact }}</strong>
				{% else %}
					{{ details.performance_impact }}
				{% endif %}
			</td>
		</tr>
		{% endfor %}
	</table>

	<h2>Total CMS Configuration</h2>
	<table class="admin-table">
		<thead>
			<tr><th>Config</th><th>Value</th></tr>
		</thead>
		{# Hide Sentry Config #}
		{% for key, value in cms.checker.getConfig | filter((v, k) => k != "sentry") %}
		<tr>
			<td>{{ key }}</td>
			{% if istype(value, "string") %}
				<td>{{ value }}</td>
			{% else %}
				<td><pre>{{ json_pretty(value) | ltrim('{') | rtrim('}') | replace({"\n    ":"\n", '"':'', ',':'', '\\/':'/'})}}</pre></td>
			{% endif %}
		</tr>
		{% endfor %}
	</table>

</section>