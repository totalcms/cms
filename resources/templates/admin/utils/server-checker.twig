<h1>{{ t('server.title') }}</h1>

<section class="dash-content-section server-checker">

	{% if not cms.admin.checker.bundleCheck %}
	<div class="bundle-error">
		<h2>{{ t('server.integrity_failed') }}</h2>
		<p>{{ t('server.integrity_desc') }}</p>
	</div>
	{% endif %}

	<h2>{{ t('server.license_info') }}</h2>
	<table class="admin-table">
		<thead>
			<tr><th>{{ t('server.license_item') }}</th><th>{{ t('label.value') }}</th></tr>
		</thead>
		{% for key, value in cms.admin.checker.serverInfo %}
		{% if key starts with 'License' or key starts with 'Trial' or key starts with 'Updates' or key starts with 'Licensed' or key starts with 'DNS' or key starts with 'Has JWT' or key starts with 'Allowed' or key starts with 'Testing' %}
		<tr>
			<td>{{ key }}</td>
			<td>
				{% if key == 'License Status' %}
					{% if value == 'Valid' %}
						<span class="success">{{ value }}</span>
					{% elseif value == 'Invalid' %}
						<span class="error">{{ value }}</span>
					{% else %}
						<span class="warning">{{ value }}</span>
					{% endif %}
				{% elseif key == 'Trial Active' and value == 'Yes' %}
					<span class="warning">{{ value }}</span>
				{% elseif key == 'Updates Valid' %}
					{% if value == 'Yes' %}
						<span class="success">{{ value }}</span>
					{% else %}
						<span class="warning">{{ value }}</span>
					{% endif %}
				{% elseif key == 'DNS Verified' %}
					{% if value == 'Yes' %}
						<span class="success">{{ value }}</span>
					{% else %}
						<span class="warning">{{ value }}</span>
					{% endif %}
				{% elseif key == 'License Cache Valid' %}
					{% if value == 'Yes' %}
						<span class="success">{{ value }}</span>
					{% else %}
						<span class="warning">{{ value }}</span>
					{% endif %}
				{% else %}
					{{ value }}
				{% endif %}
			</td>
		</tr>
		{% endif %}
		{% endfor %}
	</table>

	<h2>{{ t('server.server_info') }}</h2>
	<table class="admin-table">
		<thead>
			<tr><th>{{ t('label.info') }}</th><th>{{ t('label.value') }}</th></tr>
		</thead>
		{% for key, value in cms.admin.checker.serverInfo %}
		{% if not (key starts with 'License' or key starts with 'Trial' or key starts with 'Updates' or key starts with 'Licensed' or key starts with 'DNS' or key starts with 'Has JWT' or key starts with 'Allowed' or key starts with 'Testing') %}
		<tr>
			<td>{{ key }}</td>
			<td>{{ value }}</td>
		</tr>
		{% endif %}
		{% endfor %}
	</table>

	<h2>{{ t('server.permissions_check') }}</h2>
	<table class="admin-table">
		<thead>
			<tr><th>{{ t('server.directory') }}</th><th>{{ t('server.check') }}</th></tr>
		</thead>
		{% for key, value in cms.admin.checker.checkPermissions %}
		<tr>
			<td>{{ key }}</td>
			<td>{{ value ? t('label.passed') : '<span class="error">' ~ t('server.failed_permissions') ~ '</span>' }}</td>
		</tr>
		{% endfor %}
	</table>

	<h2>{{ t('server.required_software') }}</h2>
	<table class="admin-table">
		<thead>
			<tr><th>{{ t('server.software') }}</th><th>{{ t('server.check') }}</th></tr>
		</thead>
		{% for key, value in cms.admin.checker.checkRequiredSoftware %}
		<tr>
			<td>{{ key }}</td>
			<td>{{ value ? t('label.installed') : '<span class="error">' ~ t('label.not_installed') ~ '</span>' }}</td>
		</tr>
		{% endfor %}
	</table>

	<h2>{{ t('server.optional_software') }}</h2>
	<table class="admin-table">
		<thead>
			<tr>
				<th>{{ t('server.extension') }}</th>
				<th>{{ t('label.status') }}</th>
				<th>{{ t('label.description') }}</th>
				<th>{{ t('server.recommended_for') }}</th>
				<th>{{ t('server.performance_impact') }}</th>
			</tr>
		</thead>
		{% for extension, details in cms.admin.checker.getOptionalSoftwareDetails %}
		<tr>
			<td><strong>{{ extension | upper }}</strong></td>
			<td>
				{% if details.available %}
					<span class="success">{{ t('label.installed') }}</span>
				{% else %}
					<span class="warning">{{ t('label.not_installed') }}</span>
				{% endif %}
			</td>
			<td>{{ details.description }}</td>
			<td>
				{% if extension == 'opcache' and not details.available %}
					<strong style="color: #d63031;">{{ details.recommendation }}</strong>
				{% else %}
					{{ details.recommendation }}
				{% endif %}
			</td>
			<td>
				{% if extension == 'opcache' and not details.available %}
					<strong style="color: #00b894;">{{ details.performance_impact }}</strong>
				{% else %}
					{{ details.performance_impact }}
				{% endif %}
			</td>
		</tr>
		{% endfor %}
	</table>

	<h2>{{ t('server.config_title') }}</h2>
	<table class="admin-table">
		<thead>
			<tr><th>{{ t('server.config') }}</th><th>{{ t('label.value') }}</th></tr>
		</thead>
		{# Hide Sentry Config #}
		{% for key, value in cms.admin.checker.getConfig | filter((v, k) => k != "sentry") %}
		<tr>
			<td>{{ key }}</td>
			{% if istype(value, "string") %}
				<td>{{ value }}</td>
			{% else %}
				<td><pre>{{ json_pretty(value) | ltrim('{') | rtrim('}') | replace({"\n    ":"\n", '"':'', ',':'', '\\/':'/'})}}</pre></td>
			{% endif %}
		</tr>
		{% endfor %}
	</table>

</section>