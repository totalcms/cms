<h1>Cache Manager</h1>

<section class="dash-content-section">

	<div class="devmode-section">
		<h2>{{ t('cache.dev_mode') }}</h2>
		<p>{{ t('cache.dev_mode_desc') }}</p>

		<div class="devmode-controls" style="margin-top:2rem">
			{{ cms.form.devmode() }}
		</div>
	</div>

	<p>{{ t('cache.clear_content_desc') }}</p>

	<h2>{{ t('cache.clear_content') }}</h2>

	<p><strong>{{ t('cache.clear_content_btn') }}</strong> will clear filesystem cache, OPcache, APCu, Redis, and Memcached (if available).</p>
	{{ cms.form.simple("/cache", "", {
		method : "DELETE",
		label  : t('cache.clear_content_btn'),
	}) }}

	{% set cacheStats = cms.admin.cacheReporter.getCacheStats() %}
	{% set cacheConfig = cms.admin.cacheReporter.getOptimalCacheConfig() %}

	{% if not cacheStats.cache_enabled %}
		<div class="cache-disabled-notice">
			<h2>⚠️ {{ t('cache.status_disabled') }}</h2>
			<p>{{ t('cache.status_disabled_desc') }}</p>
			<p><strong>{{ t('label.note') }}:</strong> {{ t('cache.opcache_note') }}</p>
		</div>
	{% else %}
		<h3 style="margin-top:2rem">{{ t('cache.available_systems') }}</h3>
		<table class="admin-table">
			<thead>
				<tr>
					<th>{{ t('cache.type') }}</th>
					<th>{{ t('label.status') }}</th>
					<th>{{ t('cache.performance_data') }}</th>
					<th>{{ t('label.details') }}</th>
				</tr>
			</thead>
			<tbody>
				{% for backend, name in cacheStats.available_backends %}
				<tr>
					<td><strong>{{ name }}</strong></td>
					<td>
						{% set status = cacheStats.backend_status[backend] %}
						{% if status == 'active' %}
							<span class="success">✅ {{ t('label.active') }}</span>
						{% elseif status == 'available' %}
							<span class="warning">⚠️ {{ t('cache.available_not_enabled') }}</span>
						{% else %}
							<span class="error">❌ {{ t('label.not_installed') }}</span>
						{% endif %}
					</td>
					<td>
						{% if backend == 'filesystem' and cacheStats.services.filesystem.available %}
							{{ cacheStats.services.filesystem.size_mb }} MB ({{ cacheStats.services.filesystem.files }} files)
						{% elseif backend == 'opcache' and cacheStats.services.opcache.available %}
							{% if cacheStats.services.opcache.hit_rate > 0 %}
								{{ cacheStats.services.opcache.hit_rate }}% {{ t('cache.hit_rate') }}
							{% else %}
								{{ t('cache.warming_up') }}
							{% endif %}
						{% elseif backend == 'apcu' and cacheStats.services.apcu.available %}
							{% if cacheStats.services.apcu.hit_rate > 0 %}
								{{ cacheStats.services.apcu.hit_rate }}% {{ t('cache.hit_rate') }}, {{ cacheStats.services.apcu.entries_ours }} {{ t('cache.entries') }}
							{% else %}
								{{ t('cache.active_no_metrics') }}
							{% endif %}
						{% elseif backend == 'redis' and cacheStats.services.redis.available %}
							{% if cacheStats.services.redis.hit_rate > 0 %}
								{{ cacheStats.services.redis.hit_rate }}% {{ t('cache.hit_rate') }}, {{ cacheStats.services.redis.memory_usage }}
							{% else %}
								{{ t('cache.connected_no_metrics') }}
							{% endif %}
						{% elseif backend == 'memcached' and cacheStats.services.memcached.available %}
							{% if cacheStats.services.memcached.hit_rate > 0 %}
								{{ cacheStats.services.memcached.hit_rate }}% {{ t('cache.hit_rate') }}, {{ cacheStats.services.memcached.memory_usage }}
							{% else %}
								{{ t('cache.connected_no_metrics') }}
							{% endif %}
						{% else %}
							-
						{% endif %}
					</td>
					<td>
						{% if backend == 'filesystem' %}
							{{ t('cache.filesystem_desc') }}
						{% elseif backend == 'opcache' %}
							{{ t('cache.opcache_desc') }}
						{% elseif backend == 'apcu' %}
							{{ t('cache.apcu_desc') }}
						{% elseif backend == 'redis' %}
							{{ t('cache.redis_desc') }}
						{% elseif backend == 'memcached' %}
							{{ t('cache.memcached_desc') }}
						{% endif %}
					</td>
				</tr>
				{% endfor %}
			</tbody>
		</table>

		{% if cacheConfig.recommendations|length > 0 %}
		<h3>{{ t('cache.perf_recommendations') }}</h3>
		<div class="recommendations">
			{% for recommendation in cacheConfig.recommendations %}
				<div class="recommendation-item">
					{{ recommendation|raw }}
				</div>
			{% endfor %}
		</div>
		{% endif %}

		<h3>{{ t('cache.system_info') }}</h3>
		<ul>
			<li><strong>{{ t('cache.version') }}</strong>: {{ cacheStats.cache_version }}</li>
			<li><strong>{{ t('cache.dir_size') }}</strong>: {{ cms.admin.checker.cacheDirSize }}</li>
			<li><strong>{{ t('cache.total_space') }}</strong>: {{ cms.admin.checker.totalspace }}</li>
			<li><strong>{{ t('cache.free_space') }}</strong>: {{ cms.admin.checker.freespace }}</li>
		</ul>
	{% endif %}

</section>

<style>
.devmode-section {
	background: oklch(var(--totalform-nearwhite));
	border: 1px solid oklch(var(--totalform-border-color));
	border-radius: var(--totalform-radius);
	padding: 1.5rem;
	margin-bottom: 2rem;
}

.devmode-section h2 {
	margin-top: 0;
	color: oklch(var(--totalform-darkgray));
}

.devmode-controls .form-field {
	margin-bottom: 0;
}

.devmode-countdown-active {
	font-weight: bold;
	color: oklch(var(--totalform-success));
}

.cache-disabled-notice {
	background: #fff3cd;
	border: 1px solid #ffeaa7;
	border-radius: 4px;
	padding: 20px;
	margin: 20px 0;
	color: #856404;
}

.cache-disabled-notice h2 {
	margin-top: 0;
	color: #856404;
}

.recommendations {
	background: #f8f9fa;
	border: 1px solid #e9ecef;
	border-radius: 4px;
	padding: 15px;
	margin: 15px 0;
}

.recommendation-item {
	margin: 8px 0;
	padding: 5px 0;
	font-size: 14px;
}

.recommendation-item:not(:last-child) {
	border-bottom: 1px solid #e9ecef;
}

.success {
	color: #28a745;
	font-weight: bold;
}

.warning {
	/* color: #ffc107; */
	font-weight: bold;
}

.error {
	color: #dc3545;
	font-weight: bold;
}

</style>

