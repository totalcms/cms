<h1>{{ t('debugger.title') }}</h1>

<section class="dash-content-section twig-lint">
	<p>{{ t('debugger.desc') }}</p>

	{% set formFields %}
		{{ cms.form.field("text", "filepath", {
			label       : t('debugger.file_path'),
			placeholder : t('debugger.file_path_ph'),
			help        : t('debugger.file_path_help'),
			value       : postData.filepath | default(getData.filepath) | default(''),
			required    : true
		}) }}
	{% endset %}

	{{ cms.form.simple(url.path, formFields, {
		method : "POST",
		label  : t('debugger.check_btn'),
		ajax   : false
	}) }}

	{% if lintResults %}
	<div class="lint-results">
		{% if lintResults.success %}
			<div class="lint-success">
				<h3>{{ t('debugger.no_errors') }}</h3>
				<p>{{ t('debugger.no_errors_desc') }}</p>
			</div>
		{% else %}
			<div class="lint-error">
				<h3>{{ t('debugger.error_found') }}</h3>
				<p class="error-message">{{ lintResults.error.message }}</p>

				{% if lintResults.error.line > 0 %}
				<p class="error-location">
					<strong>{{ t('debugger.file') }}</strong> <code>{{ lintResults.file }}</code><br>
					<strong>{{ t('debugger.line') }}</strong> {{ lintResults.error.line }} of {{ lintResults.totalLines }} {{ t('debugger.total_lines') }}
				</p>
				{% endif %}

				{% if lintResults.error.context %}
				<h4>{{ t('debugger.context') }}</h4>
				<pre class="error-context"><code>{{ lintResults.error.context | e }}</code></pre>
				{% endif %}
			</div>
		{% endif %}
	</div>
	{% endif %}
</section>

<style>
.lint-results {
	margin-top : 4rem;
	max-width  : 800px;
}

.lint-success h3 {
	color: oklch(var(--totalform-success));
	margin: 0 0 0.5rem;
}

.lint-error h3 {
	color: oklch(var(--totalform-error));
	margin: 0 0 0.5rem;
}

.lint-error .error-message {
	font-weight: 500;
	color: oklch(var(--totalform-error));
	margin-bottom: 1rem;
}

.lint-error .error-location {
	margin-bottom: 1rem;
}

.lint-error .error-location code {
	background: oklch(var(--totalform-nearwhite));
	padding: 0.2rem 0.4rem;
	border-radius: 3px;
}

.lint-error h4 {
	margin: 1rem 0 0.5rem;
	font-size: 0.9rem;
	text-transform: uppercase;
	letter-spacing: 0.05em;
	color: oklch(var(--totalform-darkgray));
}

.error-context {
	background: oklch(var(--totalform-nearblack));
	color: oklch(var(--totalform-nearwhite));
	padding: 1rem;
	border-radius: var(--totalform-radius);
	overflow-x: auto;
	font-size: 0.85rem;
	line-height: 1.5;
}

.error-context code {
	font-family: "Fira Code", SFMono-Regular, "SF Mono", Menlo, Consolas, "Liberation Mono", monospace;
	white-space: pre;
}
</style>