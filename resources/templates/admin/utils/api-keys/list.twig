{# List API Keys Page #}
<h1>API Keys</h1>

<section class="dash-content-section">

	<p>API keys allow external services to access your Total CMS data. Each key can be limited to specific
	HTTP methods and API endpoints for security.</p>

	<div style="margin-block: 2rem; text-align: right;">
		<a href="utils/api-keys/new" class="dash-button">＋ Create API Key</a>
	</div>

	{% if apiKeys|length > 0 %}
		<table class="admin-table">
			<thead>
				<tr>
					<th>Name</th>
					<th>API Key</th>
					<th>HTTP Methods</th>
					<th>Endpoints</th>
					<th>Created</th>
					<th>Last Used</th>
					<th style="width: 100px;">Actions</th>
				</tr>
			</thead>
			<tbody>
				{% for apiKey in apiKeys %}
				<tr>
					<td><strong>{{ apiKey.name }}</strong></td>
					<td><code>{{ apiKey.getMaskedKey() }}</code></td>
					<td>{{ apiKey.scopes.methods|join(', ') }}</td>
					<td>
						{% if '*' in apiKey.scopes.paths %}
							<em>All endpoints</em>
						{% else %}
							{{ apiKey.scopes.paths|slice(0, 2)|join(', ') }}
							{% if apiKey.scopes.paths|length > 2 %}
								<span title="{{ apiKey.scopes.paths|join(', ') }}">... (+{{ apiKey.scopes.paths|length - 2 }} more)</span>
							{% endif %}
						{% endif %}
					</td>
					<td>{{ apiKey.created|date('Y-m-d H:i') }}</td>
					<td>
						{% if apiKey.lastUsed %}
							{{ apiKey.lastUsed|date('Y-m-d H:i') }}
						{% else %}
							<em>Never</em>
						{% endif %}
					</td>
					<td>
						<a class="cms-quick-action delete-action" data-method="DELETE"
						data-confirm="Are you sure you want to delete this API key?"
						href="{{ cms.api }}/apikeys/{{ apiKey.id }}" data-reload
						>Delete API Key</a>
					</td>
				</tr>
				{% endfor %}
			</tbody>
		</table>
	{% else %}
		<div class="empty-state">
			<p><em>No API keys created yet. Click "Create API Key" to get started.</em></p>
		</div>
	{% endif %}
</section>

<style>
.empty-state {
	text-align    : center;
	padding       : 3rem;
	background    : oklch(var(--totalform-nearwhite));
	border-radius : var(--totalform-radius);
	color         : oklch(var(--totalform-darkgray));
}
.delete-action {
    display         : flex;
    align-items     : center;
    text-decoration : none;
    color           : oklch(var(--totalform-text-color));
    padding         : .75rem 1rem;
    transition      : background-color .2s ease-in-out;
    min-width       : 200px;
}
.delete-action:before {
    content          : " ";
    display          : inline-block;
    width            : 1rem;
    height           : 1rem;
    background-color : currentColor;
    mask-image       : var(--icon-trash);
    margin-right     : .5rem;
    mask-size        : .8rem;
    mask-repeat      : no-repeat;
    mask-position    : center;
}
</style>
