{# List API Keys Page #}
<h1>API Keys</h1>

<section class="dash-content-section">

	<p>API keys allow external services to access your Total CMS data. Each key can be limited to specific
	HTTP methods and API endpoints for security.</p>

	<div style="margin-block: 2rem; text-align: right;">
		<a href="utils/api-keys/new" class="dash-button">＋ Create API Key</a>
	</div>

	{% if apiKeys|length > 0 %}
		<div class="api-keys-grid">
			{% for apiKey in apiKeys %}
			<article class="api-key-card">
				<header>
					<h3>{{ apiKey.name }}</h3>
					{{ cms.admin.quickActionButton('', 'apikeys/' ~ apiKey.id, {
						method: 'delete',
						confirm: 'Are you sure you want to delete this API key?',
						reload: true,
						class: 'delete-btn',
					}) }}
				</header>

				<div class="api-key-details">
					<div class="detail-row">
						<strong>API Key:</strong>
						<code>{{ apiKey.getMaskedKey() }}</code>
					</div>

					<div class="detail-row">
						<strong>HTTP Methods:</strong>
						<span class="methods">
							{% for method in apiKey.scopes.methods %}
								<span class="method-badge">{{ method }}</span>
							{% endfor %}
						</span>
					</div>

					<div class="detail-row">
						<strong>Endpoints:</strong>
						<span>
							{% if '*' in apiKey.scopes.paths %}
								<em>All endpoints (*)</em>
							{% else %}
								<div class="endpoint-list">
									{% for path in apiKey.scopes.paths %}
										<code>{{ path }}</code>
									{% endfor %}
								</div>
							{% endif %}
						</span>
					</div>

					<div class="detail-row">
						<strong>Created:</strong>
						<span>{{ apiKey.created|date('Y-m-d H:i') }}</span>
					</div>

					<div class="detail-row">
						<strong>Last Used:</strong>
						<span>
							{% if apiKey.lastUsed %}
								{{ apiKey.lastUsed|date('Y-m-d H:i') }}
							{% else %}
								<em>Never</em>
							{% endif %}
						</span>
					</div>
				</div>
			</article>
			{% endfor %}
		</div>
	{% else %}
		<div class="empty-state">
			<em>No API keys created yet. Click "Create API Key" to get started.</em>
		</div>
	{% endif %}
</section>

<style>
.empty-state {
	text-align    : center;
	padding       : 3rem;
	background    : oklch(var(--totalform-nearwhite));
	border-radius : var(--totalform-radius);
	color         : oklch(var(--totalform-darkgray));
}

.api-keys-grid {
	display   : grid;
	gap       : 1.5rem;
	grid-template-columns: repeat(auto-fill, minmax(400px, 1fr));
}

.api-key-card {
	background    : oklch(var(--totalform-nearwhite));
	border        : 1px solid oklch(var(--totalform-border-color));
	border-radius : var(--totalform-radius);
	padding       : 1.5rem;
	display       : flex;
	flex-direction: column;
	gap           : 1rem;
}

.api-key-card header {
	display         : flex;
	justify-content : space-between;
	align-items     : center;
	padding-bottom  : 1rem;
	border-bottom   : 1px solid oklch(var(--totalform-border-color));
}

.api-key-card h3 {
	margin     : 0;
	font-size  : 1.2rem;
	font-weight: 600;
}

.api-key-details {
	display        : flex;
	flex-direction : column;
	gap            : 0.75rem;
}

.detail-row {
	display               : grid;
	grid-template-columns : 120px 1fr;
	gap                   : 1rem;
	align-items           : start;
}

.detail-row strong {
	color       : oklch(var(--totalform-darkgray));
	font-size   : 0.9rem;
	font-weight : 500;
}

.detail-row code {
	font-size : 0.9rem;
}

.endpoint-list {
	display        : flex;
	flex-direction : column;
	gap            : 0.5rem;
}

.methods {
	display : flex;
	gap     : 0.5rem;
	flex-wrap: wrap;
}

.method-badge {
	background    : oklch(var(--totalform-accent) / 0.1);
	color         : oklch(var(--totalform-accent));
	padding       : 0.25rem 0.75rem;
	border-radius : 4px;
	font-size     : 0.85rem;
	font-weight   : 500;
}

.delete-btn {
	display         : flex;
	align-items     : center;
	gap             : 0.5rem;
	text-decoration : none;
	color           : oklch(var(--totalform-error));
	padding         : 0.5rem 1rem;
	border-radius   : var(--totalform-radius);
	font-size       : 0.9rem;
	font-weight     : 500;
	transition      : background-color 0.2s;
}

.delete-btn:hover {
	background : oklch(var(--totalform-error) / 0.1);
}

.delete-btn:before {
	content          : "";
	display          : inline-block;
	width            : 1rem;
	height           : 1rem;
	background-color : currentColor;
	mask-image       : var(--icon-trash);
	mask-size        : contain;
	mask-repeat      : no-repeat;
	mask-position    : center;
}
</style>
