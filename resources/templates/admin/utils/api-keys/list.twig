{# List API Keys Page #}
<h1>{{ t('api_keys.title') }}</h1>

<section class="dash-content-section">

	<p>{{ t('api_keys.desc') }} {{ t('api_keys.limit_desc') }}</p>

	<div style="margin-block: 2rem; text-align: right;">
		<a href="utils/api-keys/new" class="dash-button">＋ {{ t('api_keys.create_btn') }}</a>
	</div>

	{% if apiKeys|length > 0 %}
		<div class="dash-card-grid">
			{% for apiKey in apiKeys %}
			<article class="dash-card">
				<header>
					<h3>{{ apiKey.name }}</h3>
					<div class="dash-card-actions">
						{{ cms.admin.quickActionButton('', 'apikeys/' ~ apiKey.id, {
							method: 'delete',
							confirm: t('api_keys.confirm_delete'),
							reload: true,
							class: 'dash-card-action delete',
						}) }}
					</div>
				</header>

				<div class="dash-card-details">
					<div class="dash-card-detail" style="grid-template-columns:120px 1fr;">
						<strong>{{ t('api_keys.key_label') }}</strong>
						<code>{{ apiKey.getMaskedKey() }}</code>
					</div>

					<div class="dash-card-detail" style="grid-template-columns:120px 1fr;">
						<strong>{{ t('api_keys.http_methods') }}</strong>
						<div class="dash-badge-group">
							{% for method in apiKey.scopes.methods %}
								<span class="dash-badge accent">{{ method }}</span>
							{% endfor %}
						</div>
					</div>

					<div class="dash-card-detail" style="grid-template-columns:120px 1fr;">
						<strong>{{ t('api_keys.endpoints') }}</strong>
						<span>
							{% if '*' in apiKey.scopes.paths %}
								<em>{{ t('api_keys.all_endpoints') }}</em>
							{% else %}
								<div style="display:flex; flex-direction:column; gap:0.5rem;">
									{% for path in apiKey.scopes.paths %}
										<code>{{ path }}</code>
									{% endfor %}
								</div>
							{% endif %}
						</span>
					</div>

					<div class="dash-card-detail" style="grid-template-columns:120px 1fr;">
						<strong>{{ t('api_keys.created') }}</strong>
						<span>{{ apiKey.created|date('Y-m-d H:i') }}</span>
					</div>

					<div class="dash-card-detail" style="grid-template-columns:120px 1fr;">
						<strong>{{ t('api_keys.last_used') }}</strong>
						<span>
							{% if apiKey.lastUsed %}
								{{ apiKey.lastUsed|date('Y-m-d H:i') }}
							{% else %}
								<em>{{ t('label.never') }}</em>
							{% endif %}
						</span>
					</div>
				</div>
			</article>
			{% endfor %}
		</div>
	{% else %}
		<div class="dash-empty-state">
			<em>{{ t('api_keys.empty') }}</em>
		</div>
	{% endif %}
</section>
