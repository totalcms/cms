{# New API Key Form Page #}
<h1>New API Key</h1>

<section class="dash-content-section">
	<p>Create a new API key to allow external services to access your Total CMS data. You can limit access by HTTP methods and specific API endpoints.</p>

	{% set formFields %}
		{{ cms.form.field("text", "name", {
			label       : "Name",
			help        : "A name to help you identify this key (e.g., Service Integration, Mobile App, etc.)",
			placeholder : "e.g., ActivePieces Integration",
			required    : true,
		}) }}

		{{ cms.form.field("multicheckbox", "methods", {
			label    : "HTTP Methods",
			help     : "Select which HTTP methods this key can use",
			required : true,
			value    : ["GET"],
			options  : [
				{value: "GET", label: "GET (Read)"},
				{value: "POST", label: "POST (Create)"},
				{value: "PUT", label: "PUT (Update)"},
				{value: "PATCH", label: "PATCH (Partial Update)"},
				{value: "DELETE", label: "DELETE (Delete)"}
			]
		}) }}

		{{ cms.form.field("radio", "endpoint-type", {
			label    : "Allowed Endpoints",
			help     : "Choose which endpoints this key can access",
			required : true,
			value    : "all",
			options  : [
				{value: "all", label: "All endpoints (*)"},
				{value: "specific", label: "Specific endpoints"}
			]
		}) }}

		{% set collectionOptions = [] %}
		{% for collection in cms.collections() %}
			{% set collectionOptions = collectionOptions|merge([{value: "/collections/" ~ collection.id, label: collection.name}]) %}
		{% endfor %}

		{% set endpointOptions = [
			{value: "/schemas", label: "Schemas (Read-Only)"},
			{value: "/collections", label: "All Collections"}
		] %}
		{% set endpointOptions = endpointOptions|merge({"Choose Specific Collections": collectionOptions}) %}

		{{ cms.form.field("multicheckbox", "paths", {
			label    : "Select Endpoints",
			help     : "Check the endpoints this key should have access to",
			required : true,
			value    : [],
			options  : endpointOptions,
			settings : {
				fieldGrid: "200px",
				visibility : {
					watch : "endpoint-type",
					value : "specific"
				}
			}
		}) }}
	{% endset %}

	{{ cms.form.totalform("/apikeys", formFields, {
		class  : "apikeys-form",
		method : "POST",
		save   : "Create API Key",
	}) }}

</section>

{# Show Created Key Modal #}
<dialog id="show-apikey-modal" class="cms-modal small">
	<h2>API Key Created Successfully</h2>

	<div class="warning-box">
		<strong>⚠️ Save this key now!</strong>
		<p>This is the only time you'll see the full key. Copy it and store it securely.</p>
	</div>

	<form class="totalform">
		{{ cms.form.field("text", "generated-key", {
			label    : "API Key",
			class    : "api-key-display",
			readonly : true,
			icon     : false,
		}) }}
		<button type="button" class="dash-button cms-clip-button" data-clip="input[name='generated-key']">Copy to Clipboard</button>
	</form>

	<div class="form-inline-fields" style="text-align: right; margin-top: 2rem;">
		<a href="utils/api-keys" class="dash-button transparent">Done</a>
	</div>
</dialog>

<style>
.warning-box {
	background    : oklch(var(--totalform-warning));
	border-radius : var(--totalform-radius);
	padding       : 1rem;
}
#show-apikey-modal {
	gap           : 3rem;
	align-content : start;
	height        : fit-content;
}
</style>


<script>
document.addEventListener('DOMContentLoaded', function() {
	const form    = document.querySelector('.apikeys-form');
	const modalEl = document.getElementById('show-apikey-modal');

	// Listen for successful API key creation
	form.addEventListener('success', function(event) {
		// Get the API response from the event detail
		const data = event.detail;
		if (data.success && data.apiKey) {
			// Populate the generated key field
			const keyInput = document.querySelector('input[name="generated-key"]');
			if (keyInput) keyInput.value = data.apiKey.key;
			// Open the modal (Dialog class is already loaded in admin dashboard)
			setTimeout(() => {
				modalEl.dialog ? modalEl.dialog.open() : modalEl.showModal();
			}, 2500);
		}
	});
});
</script>