{# New API Key Form Page #}
<h1>{{ t('api_keys.new_title') }}</h1>

<section class="dash-content-section">
	<p>{{ t('api_keys.new_desc') }} {{ t('api_keys.limit_note') }}</p>

	{% set formFields %}
		{{ cms.form.field("text", "name", {
			label       : t('api_keys.name_label'),
			help        : t('api_keys.name_help'),
			placeholder : t('api_keys.name_ph'),
			required    : true,
		}) }}

		{{ cms.form.field("multicheckbox", "methods", {
			label    : t('api_keys.http_methods_label'),
			help     : t('api_keys.http_methods_help'),
			required : true,
			value    : ["GET"],
			options  : [
				{value: "GET", label: t('api_keys.method_get')},
				{value: "POST", label: t('api_keys.method_post')},
				{value: "PUT", label: t('api_keys.method_put')},
				{value: "PATCH", label: t('api_keys.method_patch')},
				{value: "DELETE", label: t('api_keys.method_delete')}
			]
		}) }}

		{{ cms.form.field("radio", "endpoint-type", {
			label    : t('api_keys.endpoints_label'),
			help     : t('api_keys.endpoints_help'),
			required : true,
			value    : "all",
			options  : [
				{value: "all", label: t('api_keys.all_endpoints_radio')},
				{value: "specific", label: t('api_keys.specific_endpoints')}
			]
		}) }}

		{% set collectionOptions = [] %}
		{% for collection in cms.collection.list() %}
			{% set collectionOptions = collectionOptions|merge([{value: "/collections/" ~ collection.id, label: collection.name}]) %}
		{% endfor %}

		{% set dataviewOptions = [] %}
		{% for view in cms.view.list() %}
			{% set dataviewOptions = dataviewOptions|merge([{value: "/dataviews/" ~ view.id ~ "/data", label: view.name}]) %}
		{% endfor %}

		{% set endpointOptions = [
			{value: "/schemas", label: t('api_keys.schemas_readonly')},
			{value: "/collections", label: t('api_keys.all_collections_ep')},
			{value: "/dataviews", label: t('api_keys.all_dataviews_ep')}
		] %}
		{% set endpointOptions = endpointOptions|merge({(t('api_keys.choose_collections')): collectionOptions}) %}
		{% set endpointOptions = endpointOptions|merge({(t('api_keys.choose_dataviews')): dataviewOptions}) %}

		{{ cms.form.field("multicheckbox", "paths", {
			label    : t('api_keys.select_endpoints'),
			help     : t('api_keys.select_endpoints_help'),
			required : true,
			value    : [],
			options  : endpointOptions,
			settings : {
				fieldGrid: "200px",
				visibility : {
					watch : "endpoint-type",
					value : "specific"
				}
			}
		}) }}
	{% endset %}

	{{ cms.form.totalform("/apikeys", formFields, {
		class  : "apikeys-form",
		method : "POST",
		save   : t('api_keys.create_submit'),
	}) }}

</section>

{# Show Created Key Modal #}
<dialog id="show-apikey-modal" class="cms-modal small">
	<h2>{{ t('api_keys.success_title') }}</h2>

	<div class="warning-box">
		<div>
			<strong>{{ t('api_keys.save_warning') }}</strong>
			<p>{{ t('api_keys.save_desc') }}</p>
		</div>
	</div>

	<form class="totalform">
		{{ cms.form.field("text", "generated-key", {
			label    : t('api_keys.key_modal_label'),
			class    : "api-key-display",
			readonly : true,
			icon     : false,
		}) }}
		<button type="button" class="dash-button cms-clip-button" data-clip="input[name='generated-key']">{{ t('btn.copy_clipboard') }}</button>
	</form>

	<div class="form-inline-fields" style="text-align: right; margin-top: 2rem;">
		<a href="utils/api-keys" class="dash-button transparent">{{ t('btn.done') }}</a>
	</div>
</dialog>

<style>
#show-apikey-modal {
	gap           : 3rem;
	align-content : start;
	height        : fit-content;
}
</style>


<script>
document.addEventListener('DOMContentLoaded', function() {
	const form    = document.querySelector('.apikeys-form');
	const modalEl = document.getElementById('show-apikey-modal');

	// Listen for successful API key creation
	form.addEventListener('success', function(event) {
		// Get the API response from the event detail
		const data = event.detail;
		if (data.success && data.apiKey) {
			// Populate the generated key field
			const keyInput = document.querySelector('input[name="generated-key"]');
			if (keyInput) keyInput.value = data.apiKey.key;
			// Open the modal (Dialog class is already loaded in admin dashboard)
			setTimeout(() => {
				modalEl.dialog ? modalEl.dialog.open() : modalEl.showModal();
			}, 2500);
		}
	});
});
</script>