{# New API Key Form Page #}
<h1>New API Key</h1>

<section class="dash-content-section">
	<p>Create a new API key to allow external services to access your Total CMS data. You can limit access by HTTP methods and specific API endpoints.</p>

	<form id="create-apikey-form" class="totalform help-box help-on-hover">
		{{ cms.form.field("text", "name", {
			label: "Name",
			help: "A descriptive name to help you identify this key (e.g., Zapier Integration, Mobile App, etc.)",
			placeholder: "e.g., ActivePieces Integration",
			required: true,
		}) }}

		{{ cms.form.field("multicheckbox", "methods", {
			label: "HTTP Methods",
			help: "Select which HTTP methods this key can use",
			required: true,
			value: ["GET"],
			options: [
				{value: "GET", label: "GET (Read)"},
				{value: "POST", label: "POST (Create)"},
				{value: "PUT", label: "PUT (Update)"},
				{value: "PATCH", label: "PATCH (Partial Update)"},
				{value: "DELETE", label: "DELETE (Delete)"}
			]
		}) }}

		{{ cms.form.field("radio", "endpoint-type", {
			label: "Allowed Endpoints",
			help: "Choose which endpoints this key can access",
			required: true,
			value: "all",
			options: [
				{value: "all", label: "All endpoints (*)"},
				{value: "specific", label: "Specific endpoints"}
			]
		}) }}

		<div id="specific-endpoints" style="display: none;">
			{% set collectionOptions = [] %}
			{% for collection in cms.collections() %}
				{% set collectionOptions = collectionOptions|merge([{value: "/collections/" ~ collection.id, label: collection.name}]) %}
			{% endfor %}

			{% set endpointOptions = [
				{value: "/collections", label: "All Collections"}
			] %}
			{% set endpointOptions = endpointOptions|merge({"Choose Specific Collections": collectionOptions}) %}
			{% set endpointOptions = endpointOptions|merge([
				{value: "/auth", label: "Authentication"},
				{value: "/users", label: "Users"},
				{value: "/settings", label: "Settings"},
				{value: "/templates", label: "Templates"},
				{value: "/schemas", label: "Schemas"}
			]) %}

			{{ cms.form.field("multicheckbox", "paths", {
				label: "Select Endpoints",
				help: "Check the endpoints this key should have access to",
				required: false,
				value: [],
				options: endpointOptions,
				settings: {
					fieldGrid: "200px",
				}
			}) }}
		</div>

		<div class="form-inline-fields">
			<button type="submit" class="dash-button">Create API Key</button>
		</div>
	</form>
</section>

{# Show Created Key Modal #}
<dialog id="show-apikey-modal" class="cms-modal">
	<section class="scroller">
		<h2>API Key Created Successfully</h2>
		<button type="button" class="close">×</button>

		<div class="warning-box">
			<strong>⚠️ Save this key now!</strong>
			<p>This is the only time you'll see the full key. Copy it and store it securely.</p>
		</div>

		{{ cms.form.field("text", "generated-key", {
			label: "API Key",
			readonly: true,
			class: "api-key-display",
		}) }}

		<button type="button" class="dash-button" id="copy-key-btn">Copy to Clipboard</button>

		<div class="form-inline-fields" style="margin-top: 2rem;">
			<a href="/admin/utils/api-keys" class="dash-button">Done</a>
		</div>
	</section>
</dialog>

<style>
