<h1>{{ t('import_wp.title') }}</h1>

{% set action = getData.action %}

<section class="dash-content-section">
	<div class="wp-import-description">
		<p>{{ t('import_wp.desc') }}</p>
	</div>

	{% set analyzeFields %}
		<div class="wp-file-field">
			<label for="wp-analyze-file">{{ t('import_wp.wxr_file') }}</label>
			<input type="file" id="wp-analyze-file" name="wordpress" accept=".xml" required />
			<p class="help">{{ t('import_wp.wxr_file_help') }}</p>
		</div>
	{% endset %}

	{{ cms.form.simple("/import/wordpress-analyze", analyzeFields, {
		method : "POST",
		label  : t('import_wp.analyze_btn'),
		class  : "wp-analyze-form"
	}) }}

	<div id="wp-analyze-result"></div>

	<div id="wp-import-section" style="display:none;">

		{% set importFields %}
			<div class="wp-file-field">
				<label for="wp-import-file">{{ t('import_wp.wxr_file') }}</label>
				<input type="file" id="wp-import-file" name="wordpress" accept=".xml" required />
				<p class="help">{{ t('import_wp.wxr_file_import_help') }}</p>
			</div>

			{{ cms.form.field("select", "collection", {
				label   : t('import_wp.target_collection'),
				help    : t('import_wp.select_collection'),
				options : cms.collection.list() | map(c => { value: c.id, label: c.name }) | sortBy("label"),
				value   : "blog"
			}) }}

			{{ cms.form.field("checkbox", "draft", {
				label : t('import_wp.import_as_drafts'),
				help  : t('import_wp.drafts_desc'),
				value : true
			}) }}
		{% endset %}

		{{ cms.form.simple("/import/wordpress", importFields, {
			method : "POST",
			label  : t('import_wp.import_btn'),
			class  : "wp-import-form"
		}) }}

		<div id="wp-import-result"></div>
		<div id="wp-post-preview"></div>
	</div>

	<script>
		const analyzeForm = document.querySelector('.wp-analyze-form');
		if (analyzeForm) {
			analyzeForm.addEventListener('simpleform:success', function(e) {
				const data = e.detail.data;
				const analyzeResult = document.getElementById('wp-analyze-result');

				if (!data.success) {
					analyzeResult.innerHTML =
						`<div class="message error">${data.message || '{{ t('import_wp.analysis_failed') }}'}</div>`;
					return;
				}

				const d = data.data;

				if (d.posts === 0) {
					analyzeResult.innerHTML = '<div class="message error">{{ t('import_wp.no_posts') }}</div>';
					return;
				}

				// Build analysis summary
				let infoHtml = '<div class="wp-feed-info">';
				infoHtml += `<p><strong>${d.posts} {{ t('import_wp.posts_found') }}</strong></p>`;
				if (d.dateRange.earliest && d.dateRange.latest) {
					infoHtml += `<p>{{ t('import_wp.date_range') }}: ${d.dateRange.earliest.substring(0, 10)} &mdash; ${d.dateRange.latest.substring(0, 10)}</p>`;
				}
				if (d.authors.length > 0) {
					infoHtml += `<p>{{ t('import_wp.authors') }}: ${d.authors.join(', ')}</p>`;
				}
				if (d.categories.length > 0) {
					infoHtml += `<p>{{ t('import_wp.categories') }}: ${d.categories.join(', ')}</p>`;
				}
				if (d.tags.length > 0) {
					infoHtml += `<p>{{ t('import_wp.tags') }}: ${d.tags.join(', ')}</p>`;
				}
				infoHtml += '</div>';
				analyzeResult.innerHTML = infoHtml;

				// Build sample preview
				let previewHtml = '<div class="wp-entry-preview"><h3>{{ t('import_wp.post_preview') }}</h3>';
				previewHtml += '<div class="wp-entry-list">';
				d.sample.forEach(function(post) {
					previewHtml += '<div class="wp-entry-item">';
					previewHtml += `<strong>${post.title || '{{ t('import_wp.untitled') }}'}</strong>`;
					const meta = [];
					if (post.date && post.date !== '0000-00-00 00:00:00') meta.push(post.date.substring(0, 10));
					if (post.author) meta.push(post.author);
					if (post.status) meta.push(post.status);
					if (post.category) meta.push(post.category);
					if (meta.length > 0) {
						previewHtml += `<div class="wp-entry-meta">${meta.join(' &middot; ')}</div>`;
					}
					previewHtml += '</div>';
				});
				if (d.posts > d.sample.length) {
					previewHtml += `<div class="wp-entry-item" style="text-align:center; color: oklch(var(--totalform-darkgray));">... and ${d.posts - d.sample.length} {{ t('import_wp.more_posts') }}</div>`;
				}
				previewHtml += '</div></div>';

				document.getElementById('wp-post-preview').innerHTML = previewHtml;

				// Show the import section
				document.getElementById('wp-import-section').style.display = 'block';

				// Hide the analyze form
				analyzeForm.style.display = 'none';
			});
		}

		const importForm = document.querySelector('.wp-import-form');
		if (importForm) {
			importForm.addEventListener('simpleform:success', function(e) {
				const data = e.detail.data;
				const msg = data?.message || '{{ t('import_wp.queued') }}';

				document.getElementById('wp-import-result').innerHTML =
					`<div class="message success">${msg}</div>` +
					'<p>{{ t('import_wp.queued') }}</p>';

				const preview = document.getElementById('wp-post-preview');
				if (preview) preview.style.display = 'none';

				this.style.display = 'none';
			});
		}
	</script>
</section>

<style>
.dash-content-section { max-width: 800px; }
.wp-import-description { margin-bottom: 1rem; }
.message { padding: 1rem; border-radius: var(--totalform-radius); margin: 1rem 0; }
.message.success { background-color: oklch(var(--totalform-success) / 0.1); border: 1px solid oklch(var(--totalform-success)); }
.message.error { background-color: oklch(var(--totalform-error) / 0.1); border: 1px solid oklch(var(--totalform-error)); }
.wp-feed-info { margin-top: 1rem; padding: 1rem; background: oklch(var(--totalform-nearwhite)); border-radius: var(--totalform-radius); }
.wp-feed-info p { margin: 0.25rem 0; }
.wp-entry-preview { margin-top: 1.5rem; }
.wp-entry-preview h3 { margin-bottom: 1rem; }
.wp-entry-list {
	max-height    : 400px;
	overflow-y    : auto;
	padding       : 1rem;
	border        : 1px solid oklch(var(--totalform-border-color));
	border-radius : var(--totalform-radius);
	background    : oklch(var(--totalform-nearwhite));
	font-size     : 0.85rem;
	line-height   : 1.5;
}
.wp-entry-item { padding: 0.75rem 0; border-bottom: 1px solid oklch(var(--totalform-border-color) / 0.5); }
.wp-entry-item:first-child { padding-top: 0; }
.wp-entry-item:last-child { border-bottom: none; padding-bottom: 0; }
.wp-entry-meta { font-size: 0.8rem; color: oklch(var(--totalform-darkgray)); margin-top: 0.25rem; }
.wp-file-field { margin-bottom: 1rem; }
.wp-file-field label { display: block; font-weight: 600; margin-bottom: 0.25rem; }
.wp-file-field .help { font-size: 0.8rem; color: oklch(var(--totalform-darkgray)); margin-top: 0.25rem; }
</style>
