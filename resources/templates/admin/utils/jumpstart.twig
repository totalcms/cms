{# Jumpstart Import/Export Utility #}

{% set action = getData.action %}

<section style="display:grid;align-content:start;gap:3rem">

	{% if action == "import" %}
		{# Import Section #}
		{% set jumpStartImporter = container.get('TotalCMS\\Domain\\JumpStart\\Service\\JumpStartImporter') %}
		{% set definitionPath = container.get('settings')['root'] ~ '/resources/jumpstart/example.json' %}

		{% if file_exists(definitionPath) %}
			{% set definition = file_get_contents(definitionPath) | json_decode %}
			{% set results = jumpStartImporter.importFromDefinition(definition) %}
			
			<div class="card">
				<div class="card-header">
					<h3>Jumpstart Import Results</h3>
					<p class="text-muted">{{ definition.name }} (v{{ definition.version }})</p>
				</div>
				
				<div class="card-body">
					{% if results.success %}
						<div class="alert alert-success">
							<i class="fas fa-check-circle"></i>
							<strong>Success!</strong> Jumpstart content has been imported.
						</div>
						
						<div class="row mb-4">
							<div class="col-md-2">
								<div class="stat-box">
									<div class="stat-value">{{ results.summary.schemas_created }}</div>
									<div class="stat-label">Schemas</div>
								</div>
							</div>
							<div class="col-md-2">
								<div class="stat-box">
									<div class="stat-value">{{ results.summary.collections_created }}</div>
									<div class="stat-label">Collections</div>
								</div>
							</div>
							<div class="col-md-2">
								<div class="stat-box">
									<div class="stat-value">{{ results.summary.objects_created }}</div>
									<div class="stat-label">Objects</div>
								</div>
							</div>
							<div class="col-md-3">
								<div class="stat-box">
									<div class="stat-value">{{ results.summary.factory_items_created }}</div>
									<div class="stat-label">Factory Items</div>
								</div>
							</div>
							<div class="col-md-3">
								<div class="stat-box">
									<div class="stat-value">{{ results.summary.total_errors }}</div>
									<div class="stat-label">Errors</div>
								</div>
							</div>
						</div>
						
						{% if results.results %}
							<h4>Generated Items</h4>
							<div class="table-responsive">
								<table class="table table-sm">
									<thead>
										<tr>
											<th>Type</th>
											<th>Action</th>
											<th>Item</th>
											<th>Details</th>
										</tr>
									</thead>
									<tbody>
										{% for result in results.results %}
											<tr>
												<td>
													<span class="badge badge-{{ result.type == 'schema' ? 'primary' : (result.type == 'collection' ? 'info' : (result.type == 'object' ? 'warning' : 'success')) }}">
														{{ result.type }}
													</span>
												</td>
												<td>{{ result.action }}</td>
												<td>
													{% if result.type == 'schema' %}
														<strong>{{ result.name }}</strong> ({{ result.id }})
													{% elseif result.type == 'collection' %}
														<strong>{{ result.name }}</strong> ({{ result.id }})
														{% if result.schema %}
															<small class="text-muted">Schema: {{ result.schema }}</small>
														{% endif %}
													{% elseif result.type == 'object' %}
														<strong>{{ result.collection }}</strong> / {{ result.id }}
													{% elseif result.type == 'factory' %}
														<strong>{{ result.collection }}</strong>
														{% if result.id %}
															/ {{ result.id }}
															<small class="text-muted">(factory generated)</small>
														{% else %}
															<small class="text-muted">({{ result.count }} items)</small>
														{% endif %}
													{% endif %}
												</td>
												<td>
													{% if result.type == 'factory' %}
														{% if result.id %}
															<small class="text-muted">Factory object with ID</small>
														{% else %}
															<small class="text-muted">Generated {{ result.count }} items</small>
														{% endif %}
													{% endif %}
												</td>
											</tr>
										{% endfor %}
									</tbody>
								</table>
							</div>
						{% endif %}
					{% else %}
						<div class="alert alert-danger">
							<i class="fas fa-exclamation-circle"></i>
							<strong>Jumpstart import failed!</strong> Please check the errors below.
						</div>
					{% endif %}
					
					{% if results.errors %}
						<h4>Errors</h4>
						<div class="alert alert-danger">
							<ul class="mb-0">
								{% for error in results.errors %}
									<li>
										<strong>{{ error.type|capitalize }}</strong>
										{% if error.id %}({{ error.id }}){% endif %}
										{% if error.collection %}in {{ error.collection }}{% endif %}:
										{{ error.error }}
									</li>
								{% endfor %}
							</ul>
						</div>
					{% endif %}
				</div>
				
				<div class="card-footer">
					<a href="{{ utils_url }}/jumpstart" class="btn btn-secondary">
						<i class="fas fa-arrow-left"></i> Back to Jumpstart
					</a>
				</div>
			</div>
		{% else %}
			<div class="alert alert-warning">
				<i class="fas fa-exclamation-triangle"></i>
				<strong>No jumpstart definition found!</strong>
				<p>The jumpstart definition file was not found at: <code>{{ definitionPath }}</code></p>
			</div>
			
			<a href="{{ utils_url }}/jumpstart" class="btn btn-secondary">
				<i class="fas fa-arrow-left"></i> Back to Jumpstart
			</a>
		{% endif %}

	{% elseif action == "export" %}
		{# Export Section #}
		{% set jumpStartExporter = container.get('TotalCMS\\Domain\\JumpStart\\Service\\JumpStartExporter') %}
		{% set jumpStartData = jumpStartExporter.exportCurrentData() %}
		
		<div class="card">
			<div class="card-header">
				<h3>Export Current CMS Data to Jumpstart</h3>
				<p class="text-muted">Generate a jumpstart definition from your current Total CMS data</p>
			</div>
			
			<div class="card-body">
				<div class="alert alert-info">
					<i class="fas fa-info-circle"></i>
					<strong>Export Summary:</strong>
					<ul class="mb-0 mt-2">
						<li><strong>{{ jumpStartData.schemas|length }}</strong> custom schemas</li>
						<li><strong>{{ jumpStartData.collections.default|length }}</strong> default collections</li>
						<li><strong>{{ jumpStartData.collections.custom|length }}</strong> custom collections</li>
						<li><strong>{{ jumpStartData.objects|length }}</strong> objects</li>
					</ul>
				</div>
				
				<h4>Jumpstart JSON Definition</h4>
				<div class="code-container">
					<textarea readonly class="form-control" rows="20" style="font-family: 'Fira Code', monospace; font-size: 0.875rem;">{{ jumpStartData.toJson() }}</textarea>
				</div>
				
				<div class="mt-3">
					<button type="button" class="btn btn-primary" onclick="copyToClipboard()">
						<i class="fas fa-copy"></i> Copy to Clipboard
					</button>
					<button type="button" class="btn btn-success" onclick="downloadJson()">
						<i class="fas fa-download"></i> Download as File
					</button>
				</div>
			</div>
			
			<div class="card-footer">
				<a href="{{ utils_url }}/jumpstart" class="btn btn-secondary">
					<i class="fas fa-arrow-left"></i> Back to Jumpstart
				</a>
			</div>
		</div>

	{% else %}
		{# Main Jumpstart Page #}
		<div>
			<h2>🚀 Jumpstart Content Management</h2>
			<p>Import demo content or export your current CMS data to jumpstart definitions.</p>
		</div>

		<section>
			<details class="cms-accordion">
				<summary>🚀 Import Jumpstart Content</summary>
				<div class="content" style="margin-bottom:2rem">
					<p>Import demo content from a jumpstart definition. This will create schemas, collections, and objects based on the definition file.</p>
					<p class="text-warning"><strong>Note:</strong> This feature is only available in preview environments.</p>
					
					{% if cms.env == 'preview' %}
						<a href="{{ utils_url }}/jumpstart?action=import" class="dash-button">
							<i class="fas fa-rocket"></i> Start Jumpstart Import
						</a>
					{% else %}
						<p class="text-muted">Jumpstart import is only available in preview environments.</p>
					{% endif %}
				</div>
			</details>

			<details class="cms-accordion">
				<summary>📤 Export Current Data to Jumpstart</summary>
				<div class="content" style="margin-bottom:2rem">
					<p>Export your current CMS data to a jumpstart definition. This creates a JSON file that can be used to recreate your current setup.</p>
					<ul>
						<li><strong>Custom schemas</strong> - All non-default schemas</li>
						<li><strong>Collections</strong> - Both default and custom collections</li>
						<li><strong>Objects</strong> - All objects from all collections</li>
						<li><strong>Factory definitions</strong> - Empty array (manually configure as needed)</li>
					</ul>
					
					<a href="{{ utils_url }}/jumpstart?action=export" class="dash-button">
						<i class="fas fa-file-export"></i> Export to Jumpstart
					</a>
				</div>
			</details>

			<details class="cms-accordion">
				<summary>📖 About Jumpstart</summary>
				<div class="content" style="margin-bottom:2rem">
					<p><strong>Jumpstart</strong> is Total CMS's content generation system that helps you quickly set up demo sites or migrate content between environments.</p>
					
					<h4>What can Jumpstart do?</h4>
					<ul>
						<li><strong>Create Custom Schemas</strong> - Define field structures for your content types</li>
						<li><strong>Set up Collections</strong> - Create both default and custom collections</li>
						<li><strong>Import Specific Objects</strong> - Add individual content items with known IDs</li>
						<li><strong>Generate Factory Content</strong> - Create realistic demo content using faker rules</li>
					</ul>
					
					<h4>Use Cases</h4>
					<ul>
						<li><strong>Demo Sites</strong> - Quickly populate a CMS with realistic content</li>
						<li><strong>Development</strong> - Create consistent test data across environments</li>
						<li><strong>Client Onboarding</strong> - Provide starter content for new projects</li>
						<li><strong>Content Migration</strong> - Move content between Total CMS installations</li>
					</ul>
				</div>
			</details>
		</section>
	{% endif %}

</section>

<script>
function copyToClipboard() {
	const textarea = document.querySelector('.code-container textarea');
	textarea.select();
	textarea.setSelectionRange(0, 99999);
	document.execCommand('copy');
	
	// Show feedback
	const button = event.target.closest('button');
	const originalText = button.innerHTML;
	button.innerHTML = '<i class="fas fa-check"></i> Copied!';
	button.disabled = true;
	
	setTimeout(() => {
		button.innerHTML = originalText;
		button.disabled = false;
	}, 2000);
}

function downloadJson() {
	const textarea = document.querySelector('.code-container textarea');
	const data = textarea.value;
	const blob = new Blob([data], { type: 'application/json' });
	const url = URL.createObjectURL(blob);
	
	const a = document.createElement('a');
	a.href = url;
	a.download = 'jumpstart-export.json';
	document.body.appendChild(a);
	a.click();
	document.body.removeChild(a);
	URL.revokeObjectURL(url);
}
</script>

<style>
	.stat-box {
		text-align: center;
		padding: 1.5rem;
		background: oklch(var(--totalform-nearwhite));
		border-radius: var(--totalform-radius);
		border: 1px solid oklch(var(--totalform-border-color));
	}
	
	.stat-value {
		font-size: 2rem;
		font-weight: 700;
		color: oklch(var(--totalform-accent));
	}
	
	.stat-label {
		font-size: 0.875rem;
		color: oklch(var(--totalform-darkgray));
		text-transform: uppercase;
		letter-spacing: 0.05em;
	}
	
	.badge {
		font-weight: 500;
		padding: 0.25rem 0.5rem;
	}
	
	.badge-primary {
		background-color: oklch(var(--totalform-accent));
		color: white;
	}
	
	.badge-info {
		background-color: oklch(var(--totalform-info));
		color: white;
	}
	
	.badge-success {
		background-color: oklch(var(--totalform-success));
		color: white;
	}
	
	.badge-warning {
		background-color: orange;
		color: white;
	}
	
	.code-container {
		position: relative;
		margin: 1rem 0;
	}
	
	.code-container textarea {
		background: #f8f9fa;
		border: 1px solid oklch(var(--totalform-border-color));
		font-size: 0.875rem;
		line-height: 1.4;
	}
	
	.cms-accordion {
		border: 1px solid oklch(var(--totalform-border-color));
		border-radius: var(--totalform-radius);
		margin-bottom: 1rem;
	}
	
	.cms-accordion summary {
		padding: 1rem;
		background: oklch(var(--totalform-nearwhite));
		cursor: pointer;
		font-weight: 600;
		border-radius: var(--totalform-radius);
	}
	
	.cms-accordion .content {
		padding: 1rem;
	}
	
	.alert {
		padding: 1rem;
		border-radius: var(--totalform-radius);
		margin-bottom: 1rem;
	}
	
	.alert-success {
		background-color: oklch(var(--totalform-success) / 0.1);
		border: 1px solid oklch(var(--totalform-success));
		color: oklch(var(--totalform-success));
	}
	
	.alert-danger {
		background-color: #dc3545;
		border: 1px solid #dc3545;
		color: white;
	}
	
	.alert-warning {
		background-color: #ffc107;
		border: 1px solid #ffc107;
		color: #212529;
	}
	
	.alert-info {
		background-color: oklch(var(--totalform-info) / 0.1);
		border: 1px solid oklch(var(--totalform-info));
		color: oklch(var(--totalform-info));
	}
</style>