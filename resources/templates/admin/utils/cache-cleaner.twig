<h1>Cache Cleaner</h1>

<section class="dash-content-section">
	<p>This tool manages all cache systems in Total CMS. Clearing cache will remove cached templates,
	compiled code, and other temporary data to ensure you see the latest changes.</p>

	<h2>Cache Management</h2>

	<p><strong>Clear All Caches</strong> will clear filesystem cache, OPcache, Redis, and Memcached (if available).</p>
	{{ cms.form.simple("/cache", "", {
		method : "DELETE",
		label  : "Clear All Caches",
	}) }}

	{% set cacheStats = cms.cacheManager.getCacheStats() %}
	{% set cacheConfig = cms.cacheManager.getOptimalCacheConfig() %}

	{% if not cacheStats.cache_enabled %}
	<div class="cache-disabled-notice">
		<h2>⚠️ Cache Status: Disabled (Development Mode)</h2>
		<p>Twig template caching is currently disabled. This is normal for development but should be enabled in production for better performance.</p>
		<p><strong>Note:</strong> OPcache may still be active for PHP bytecode acceleration.</p>
	</div>
	{% endif %}

	<h2>Available Cache Systems</h2>
	<table class="admin-table">
		<thead>
			<tr>
				<th>Cache Type</th>
				<th>Status</th>
				<th>Performance Data</th>
				<th>Details</th>
			</tr>
		</thead>
		<tbody>
			{% for backend, name in cacheStats.available_backends %}
			<tr>
				<td><strong>{{ name }}</strong></td>
				<td>
					{% if backend in cacheStats|keys %}
						<span class="success">✅ Active</span>
					{% else %}
						<span class="warning">⚠️ Available</span>
					{% endif %}
				</td>
				<td>
					{% if backend == 'filesystem' and cacheStats.filesystem.exists %}
						{{ cacheStats.filesystem.size_mb }} MB ({{ cacheStats.filesystem.files }} files)
					{% elseif backend == 'opcache' and cacheStats.opcache.available %}
						{% if cacheStats.opcache.hit_rate > 0 %}
							{{ cacheStats.opcache.hit_rate }}% hit rate
						{% else %}
							Enabled, warming up
						{% endif %}
					{% elseif backend == 'redis' and cacheStats.redis.available %}
						{% if cacheStats.redis.hit_rate > 0 %}
							{{ cacheStats.redis.hit_rate }}% hit rate, {{ cacheStats.redis.memory_usage }}
						{% else %}
							Connected, no metrics yet
						{% endif %}
					{% elseif backend == 'memcached' and cacheStats.memcached.available %}
						{% if cacheStats.memcached.hit_rate > 0 %}
							{{ cacheStats.memcached.hit_rate }}% hit rate, {{ cacheStats.memcached.memory_usage }}
						{% else %}
							Connected, no metrics yet
						{% endif %}
					{% else %}
						-
					{% endif %}
				</td>
				<td>
					{% if backend == 'filesystem' %}
						Twig compiled templates and metadata
					{% elseif backend == 'opcache' %}
						PHP bytecode cache (2-5x performance boost)
					{% elseif backend == 'redis' %}
						High-speed in-memory cache for template metadata
					{% elseif backend == 'memcached' %}
						Distributed memory cache for template data
					{% endif %}
				</td>
			</tr>
			{% endfor %}
		</tbody>
	</table>

	{% if cacheConfig.recommendations|length > 0 %}
	<h2>Performance Recommendations</h2>
	<div class="recommendations">
		{% for recommendation in cacheConfig.recommendations %}
			<div class="recommendation-item">
				{{ recommendation|raw }}
			</div>
		{% endfor %}
	</div>
	{% endif %}

	<h2>System Information</h2>
	<ul>
		<li><strong>Cache Version</strong>: {{ cacheStats.cache_version }}</li>
		<li><strong>Cache Dir Size</strong>: {{ cms.checker.cacheDirSize }}</li>
		<li><strong>Total Space</strong>: {{ cms.checker.totalspace }}</li>
		<li><strong>Free Space</strong>: {{ cms.checker.freespace }}</li>
	</ul>

</section>

<style>
.cache-disabled-notice {
	background: #fff3cd;
	border: 1px solid #ffeaa7;
	border-radius: 4px;
	padding: 20px;
	margin: 20px 0;
	color: #856404;
}

.cache-disabled-notice h2 {
	margin-top: 0;
	color: #856404;
}

.recommendations {
	background: #f8f9fa;
	border: 1px solid #e9ecef;
	border-radius: 4px;
	padding: 15px;
	margin: 15px 0;
}

.recommendation-item {
	margin: 8px 0;
	padding: 5px 0;
	font-size: 14px;
}

.recommendation-item:not(:last-child) {
	border-bottom: 1px solid #e9ecef;
}

.success {
	color: #28a745;
	font-weight: bold;
}

.warning {
	color: #ffc107;
	font-weight: bold;
}
</style>