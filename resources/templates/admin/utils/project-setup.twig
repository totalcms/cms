<h1>{{ t('setup.actions_title') }}</h1>

{% set action = getData.action %}



<section class="dash-content-section">
	{% if action == "default-collections" %}
		<section>
			<h2>{{ t('setup.default_collections') }}</h2>
			{% include "admin/utils/actions/default-collections.twig" %}
		</section>
	{% else %}
		<section>
			<h2>{{ t('setup.default_collections') }}</h2>
			<p>{{ t('setup.default_collections_desc') }}</p>
		</section>
		<a class="dash-button" href="utils/project-setup?action=default-collections">{{ t('setup.default_collections_btn') }}</a>
	{% endif %}
</section>

<section class="dash-content-section">
	{% if cms.env == "preview" or cms.env == "dev" %}
		{% if action == "jumpstart-demo" %}
		<section>
			<h2>{{ t('setup.jumpstart_demo') }}</h2>
			{% include "admin/utils/actions/jumpstart-demo.twig" %}
		</section>
		{% else %}
		<section>
			<h2>{{ t('setup.jumpstart_demo') }}</h2>
			<p style="margin-bottom: 1rem;">{{ t('setup.jumpstart_demo_desc') }}</p>
			{{ cms.form.simple("/import/jumpstart?demo=true", '', {
				method : "POST",
				label  : t('setup.jumpstart_demo_btn'),
				class  : "jumpstart-demo",
			}) }}
		</section>
		{% endif %}
	{% else %}
	<section>
		<h2>{{ t('setup.jumpstart_data') }}</h2>
		<p>{{ t('setup.jumpstart_data_desc') }}</p>
	</section>
	<a class="dash-button transparent" href="utils/jumpstart">{{ t('setup.jumpstart_open') }}</a>
	{% endif %}
</section>


{% if totalcms1DetectionData is defined and totalcms1DetectionData %}
	{% set cmsDataPath = totalcms1DetectionData.path %}
	{% set cmsDataSource = totalcms1DetectionData.source %}
{% endif %}

{% if cmsDataPath %}
<section class="dash-content-section">
	<h2>{{ t('setup.v1_import_title') }}</h2>

	{% if action == "totalcms-one-import" %}
		<div id="import-status">
			<p>{{ t('setup.v1_import_starting') }}</p>
		</div>
		<p>{{ t('setup.v1_import_queued') }}
			<a href="utils/jobqueue">Job Queue Manager</a>.</p>
		<script>
			(async function() {
				try {
					const response = await fetch('{{ cms.api }}/import/totalcms-one', {
						method: 'POST',
						headers: {
							'Content-Type': 'application/json',
							'X-CSRF-Token': '{{ csrf_token() }}'
						},
						body: JSON.stringify({
							path: '{{ cmsDataPath }}'
						})
					});
					const data = await response.json();
					const statusEl = document.getElementById('import-status');

					if (data.success) {
						statusEl.innerHTML = `<div class="message success">${data.message}</div>`;
					} else {
						statusEl.innerHTML = `<div class="message error">${data.message}</div>`;
					}
				} catch (error) {
					document.getElementById('import-status').innerHTML =
						`<div class="message error">Import failed: ${error.message}</div>`;
				}
			})();
		</script>
	{% else %}
		<div>
		<p>{{ t('setup.v1_import_detected') }} <code>{{ cmsDataPath }}</code></p>
		<p>{{ t('setup.v1_import_categories') }}</p>
		<p><strong>{{ t('label.note') }}:</strong> {{ t('setup.v1_import_note') }}</p>
		</div>
		<a class="dash-button" href="utils/project-setup?action=totalcms-one-import">{{ t('setup.v1_import_btn') }}</a>
	{% endif %}
</section>
{% endif %}

<section class="dash-content-section">
	<h2>{{ t('setup.other_imports_title') }}</h2>
	<p>{{ t('setup.other_imports_desc') }}</p>

	<div class="supported-tools">
		<div class="tool-item">
			<h3>RSS Feeds</h3>
			<p>Import content from any RSS feed.</p>
			<a class="dash-button transparent" href="utils/import-rss">Import from RSS</a>
		</div>
		<div class="tool-item">
			<h3>WordPress</h3>
			<p>Import content from WordPress.</p>
			<a class="dash-button transparent" href="utils/import-wordpress">Import from WordPress</a>
		</div>
		<div class="tool-item">
			<h3>Alloy</h3>
			<p>Import content from Alloy CMS.</p>
			<a class="dash-button transparent" href="utils/import-alloy">Import from Alloy</a>
		</div>
</section>

<style>
.dash-content-section:not(:first-child) { padding-top: 2rem; }
.dash-main-content { align-content: start; }
.supported-tools {
	margin-top : 1rem;
	display    : grid;
	gap        : 1rem;
}
.tool-item {
	display       : grid;
	gap           : 0.75rem;
	border        : 1px solid oklch(var(--totalform-border-color));
	border-radius : var(--totalform-radius);
	padding       : 1rem;
}
</style>