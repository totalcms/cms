<h1>{{ t('import_alloy.title') }}</h1>

{% set action = getData.action %}

<section class="dash-content-section">
	<div class="alloy-import-description">
		<p>{{ t('import_alloy.desc') }}</p>

		<div class="cms-twig-info" style="margin-top: 1rem;">
			<h4>{{ t('import_alloy.what_gets_imported') }}</h4>
			<ul>
				<li>{{ t('import_alloy.blog_posts') }}</li>
				<li>{{ t('import_alloy.embeds') }}</li>
				<li>{{ t('import_alloy.droplets') }}</li>
			</ul>
			<p>{{ t('import_alloy.no_delete') }}</p>
		</div>

		<div class="cms-twig-info" style="margin-top: 1rem;">
			<h4>{{ t('import_alloy.markdown_title') }}</h4>
			<p>{{ t('import_alloy.markdown_desc') }}</p>
		</div>
	</div>

	<form class="totalform" method="post" action="utils/import-alloy?action=alloy-import-analyze" id="alloy-import-form">
		{{ csrf_field() }}

		<div class="form-field text-field" data-type="text">
			<label for="field-blog">{{ t('import_alloy.blog_folder') }}</label>
			<div class="form-group">
				<input type="text" id="field-blog" name="blog" value="{{ postData.blog ?? 'posts' }}" required>
				<div class="form-group-icon"></div>
			</div>
			<p class="help">{{ t('import_alloy.blog_folder_help') }}</p>
		</div>

		<div class="form-field text-field" data-type="text">
			<label for="field-image-uploads">{{ t('import_alloy.image_folder') }}</label>
			<div class="form-group">
				<input type="text" id="field-image-uploads" name="image_uploads" value="{{ postData.image_uploads ?? 'image-uploads' }}" required>
				<div class="form-group-icon"></div>
			</div>
			<p class="help">{{ t('import_alloy.image_folder_help') }}</p>
		</div>

		<div class="form-field text-field" data-type="text">
			<label for="field-embeds">{{ t('import_alloy.embeds_folder') }}</label>
			<div class="form-group">
				<input type="text" id="field-embeds" name="embeds" value="{{ postData.embeds ?? 'embeds' }}" required>
				<div class="form-group-icon"></div>
			</div>
			<p class="help">{{ t('import_alloy.embeds_folder_help') }}</p>
		</div>

		<div class="form-field text-field" data-type="text">
			<label for="field-droplets">{{ t('import_alloy.droplets_folder') }}</label>
			<div class="form-group">
				<input type="text" id="field-droplets" name="droplets" value="{{ postData.droplets ?? 'droplets' }}" required>
				<div class="form-group-icon"></div>
			</div>
			<p class="help">{{ t('import_alloy.droplets_folder_help') }}</p>
		</div>

		<button class="dash-button" type="submit">{{ t('import_alloy.analyze_btn') }}</button>
	</form>

	<script>
		document.getElementById('alloy-import-form').addEventListener('submit', function(e) {
			e.preventDefault(); // Prevent default form submission

			// Get form data
			const formData = new FormData(this);

			// Show loading state
			const submitButton = this.querySelector('button[type="submit"]');
			const originalText = submitButton.textContent;
			submitButton.textContent = 'Analyzing...';
			submitButton.disabled = true;

			// Make API call
			fetch('{{ cms.api }}/import/alloy-analyze', {
				method: 'POST',
				headers: {
					'X-CSRF-Token': '{{ csrf_token() }}'
				},
				body: formData
			})
			.then(response => response.json())
			.then(data => {
				if (data.success) {
					// Check if any data was found
					const totalItems = (data.data.blogs?.length || 0) + (data.data.embeds?.length || 0) + (data.data.droplets?.length || 0);

					if (totalItems === 0) {
						// No data found - show message and link back to form
						let html = '<div class="message error">{{ t('import_alloy.no_data') }}</div>';
						html += '<p>{{ t('import_alloy.no_data_desc') }}</p>';
						html += '<p style="margin-top: 1rem;"><a class="dash-button transparent" href="utils/import-alloy">{{ t('btn.try_again') }}</a></p>';

						// Replace form with no data message
						document.querySelector('.dash-content-section').innerHTML = '<h2>{{ t('import_alloy.title') }}</h2>' + html;
					} else {
						// Build results HTML
						let html = '<div class="message success">{{ t('import_alloy.analysis_success') }}</div>';
						html += '<h3>{{ t('import_alloy.found_data') }}</h3>';
						html += '<ul>';
						if (data.data.blogs && data.data.blogs.length > 0) {
							html += `<li><strong>Blog Posts:</strong> ${data.data.blogs.length} {{ t('import_alloy.posts_found') }}</li>`;
						}
						if (data.data.embeds && data.data.embeds.length > 0) {
							html += `<li><strong>Embeds:</strong> ${data.data.embeds.length} {{ t('import_alloy.embeds_found') }}</li>`;
						}
						if (data.data.droplets && data.data.droplets.length > 0) {
							html += `<li><strong>Droplets:</strong> ${data.data.droplets.length} {{ t('import_alloy.droplets_found') }}</li>`;
						}
						html += '</ul>';
						html += '<p style="margin-top: 1rem;"><button class="dash-button" onclick="startImport()">{{ t('import_alloy.import_all_btn') }}</button></p>';

						// Replace form with results
						document.querySelector('.dash-content-section').innerHTML = '<h2>{{ t('import_alloy.title') }}</h2>' + html;

						// Store form data for import
						window.alloyFormData = formData;
					}
				} else {
					alert('Analysis failed: ' + data.message);
					// Reset button
					submitButton.textContent = originalText;
					submitButton.disabled = false;
				}
			})
			.catch(error => {
				alert('Analysis failed: ' + error.message);
				// Reset button
				submitButton.textContent = originalText;
				submitButton.disabled = false;
			});
		});

		function startImport() {
			if (!window.alloyFormData) {
				alert('Form data not available. Please try again.');
				return;
			}

			document.querySelector('.dash-content-section').innerHTML = '<h2>{{ t('import_alloy.title') }}</h2><p>{{ t('import_alloy.import_starting') }}</p>';

			fetch('{{ cms.api }}/import/alloy', {
				method: 'POST',
				headers: {
					'X-CSRF-Token': '{{ csrf_token() }}'
				},
				body: window.alloyFormData
			})
			.then(response => response.json())
			.then(data => {
				if (data.success) {
					document.querySelector('.dash-content-section').innerHTML =
						'<h2>{{ t('import_alloy.title') }}</h2>' +
						`<div class="message success">${data.message}</div>` +
						'<p>{{ t('import_alloy.import_queued') }}</p>';
				} else {
					document.querySelector('.dash-content-section').innerHTML =
						'<h2>{{ t('import_alloy.title') }}</h2>' +
						`<div class="message error">${data.message}</div>`;
				}
			})
			.catch(error => {
				document.querySelector('.dash-content-section').innerHTML =
					'<h2>{{ t('import_alloy.title') }}</h2>' +
					`<div class="message error">{{ t('import_alloy.import_failed') }} ${error.message}</div>`;
			});
		}
	</script>

</section>

<style>
.dash-content-section { max-width: 800px; }
.alloy-import-description { margin-bottom: 1rem; }
.cms-twig-info ul { margin-left: 1.5rem; }
.message { padding: 1rem; border-radius: var(--totalform-radius); margin: 1rem 0; }
.message.success { background-color: oklch(var(--totalform-success) / 0.1); border: 1px solid oklch(var(--totalform-success)); }
.message.error { background-color: oklch(var(--totalform-error) / 0.1); border: 1px solid oklch(var(--totalform-error)); }
</style>