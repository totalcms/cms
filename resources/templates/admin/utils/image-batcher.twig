{% extends "admin-layout.twig" %}

{% block head %}
	<link rel="stylesheet" href="{{ cms.api }}/assets/imageworks-builder.css"/>
	<style>
		.wizard-steps {
			display: flex;
			margin-bottom: 2rem;
			border-bottom: 1px solid oklch(var(--totalform-border-color));
		}
		.wizard-step {
			flex: 1;
			padding: 1rem;
			text-align: center;
			background: oklch(var(--totalform-nearwhite));
			border-right: 1px solid oklch(var(--totalform-border-color));
			color: oklch(var(--totalform-darkgray));
		}
		.wizard-step:last-child {
			border-right: none;
		}
		.wizard-step.active {
			background: oklch(var(--totalform-darkgray));
			color: oklch(var(--totalform-purewhite));
		}
		.wizard-step.completed {
			background: oklch(var(--totalform-gray));
			color: oklch(var(--totalform-purewhite));
		}
		.wizard-actions {
			margin-top: 2rem;
		}
		.batch-preview {
			display: grid;
			grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
			gap: 1rem;
			margin-top: 2rem;
		}
		.batch-item {
			border: 1px solid oklch(var(--totalform-border-color));
			border-radius: var(--totalform-radius);
			padding: 1rem;
			text-align: center;
		}
		.batch-item img {
			max-width: 100%;
			height: auto;
			border-radius: var(--totalform-radius);
		}
		.progress-bar {
			width: 100%;
			height: 20px;
			background: oklch(var(--totalform-nearwhite));
			border-radius: 10px;
			overflow: hidden;
			margin: 1rem 0;
		}
		.progress-fill {
			height: 100%;
			background: oklch(var(--totalform-accent));
			width: 0%;
			transition: width 0.3s ease;
		}
		.macro-example, .macro-display {
			background: oklch(var(--totalform-nearwhite));
			border: 1px solid oklch(var(--totalform-border-color));
			border-radius: var(--totalform-radius);
			padding: 1rem 0;
			margin: 1rem 0;
		}
		.macro-example code, .macro-display code {
			display: block;
			background: oklch(var(--totalform-icon-bg));
			padding: 0.5rem;
			border-radius: var(--totalform-radius);
			font-family: monospace;
			word-break: break-all;
		}
		#macro-example {
			max-width     : 100%;
			height        : auto;
			margin-top    : 1rem;
			border-radius : var(--totalform-radius);
		}
	</style>
{% endblock %}

{% block content %}

{% set currentStep = 1 %}
{% set selectedCollection = postData.collection ?? null %}
{% set selectedProperty = postData.property ?? null %}
{% set imageworksMacro = postData.imageworks_macro ?? null %}

{# Handle back button clicks #}
{% if postData.step == 'back' %}
	{% if imageworksMacro %}
		{% set imageworksMacro = null %}
		{% set currentStep = 3 %}
	{% elseif selectedProperty %}
		{% set selectedProperty = null %}
		{% set currentStep = 2 %}
	{% elseif selectedCollection %}
		{% set selectedCollection = null %}
		{% set currentStep = 1 %}
	{% endif %}
{% else %}
	{# Normal step progression #}
	{% if selectedCollection %}
		{% set currentStep = 2 %}
	{% endif %}

	{% if selectedCollection and selectedProperty %}
		{% set currentStep = 3 %}
	{% endif %}

	{% if postData.step == 'process' and selectedCollection and selectedProperty and imageworksMacro %}
		{% set currentStep = 4 %}
	{% endif %}
{% endif %}

<main class="admin-layout container">
	<h1>Batch Image Processor</h1>
	<p>Process multiple images with ImageWorks settings across collections and properties.</p>

	<!-- Wizard Steps Indicator -->
	<div class="wizard-steps">
		<div class="wizard-step {{ currentStep == 1 ? 'active' : (currentStep > 1 ? 'completed' : '') }}">
			<strong>1. Select Collection</strong>
		</div>
		<div class="wizard-step {{ currentStep == 2 ? 'active' : (currentStep > 2 ? 'completed' : '') }}">
			<strong>2. Select Property</strong>
		</div>
		<div class="wizard-step {{ currentStep == 3 ? 'active' : (currentStep > 3 ? 'completed' : '') }}">
			<strong>3. Configure ImageWorks</strong>
		</div>
		<div class="wizard-step {{ currentStep == 4 ? 'active' : '' }}">
			<strong>4. Batch Process</strong>
		</div>
	</div>

	{% if currentStep == 1 %}
		<!-- Step 1: Collection Selection -->
		<section>
			<h2>Step 1: Select Collection</h2>
			<p>Choose the collection containing the images you want to process.</p>

			{% set step1Fields %}
				{{ cms.form.field("select", "collection", {
					placeholder : "Select a Collection",
					label       : "Collection",
					help        : "Select the collection that contains the images you want to process.",
					class       : "no-change-listener",
					options     : cms.collections() | map(c => { value: c.id, label: c.name }) | sortBy("label"),
				}) }}
			{% endset %}

			{{ cms.form.simple(url.path, step1Fields, {
				method : "POST",
				label  : "Next Step",
				ajax   : false,
			}) }}
		</section>

	{% elseif currentStep == 2 %}
		<!-- Step 2: Property Selection -->
		<section>
			<h2>Step 2: Select Property</h2>
			<p>Choose which property contains the images in the <strong>{{ selectedCollection }}</strong> collection.</p>

			{% set schema = cms.schemaForCollection(selectedCollection) %}
			{% set propertyOptions = [] %}
			{% set imageFields = ['image', 'gallery'] %}

			{# Collect properties that are images or galleries #}
			{% for propertyName, propertyDef in schema.properties %}
				{% if propertyDef.field is defined %}
					{% if propertyDef.field in imageFields  %}
						{% set propertyOptions = propertyOptions|merge([{
							value: propertyName,
							label: propertyName ~ ' (' ~propertyDef.field ~ ')'
						}]) %}
					{% endif %}
				{% endif %}
			{% endfor %}

			{% set step2Fields %}
				{{ cms.form.field("hidden", "collection", { value: selectedCollection }) }}
				{{ cms.form.field("select", "property", {
					placeholder : "Select a Property",
					label       : "Property",
					help        : "Select the property that contains the images you want to process.",
					class       : "no-change-listener",
					options     : propertyOptions,
				}) }}
			{% endset %}

			<div class="wizard-actions">
				{{ cms.form.simple(url.path, step2Fields, {
					method : "POST",
					label  : "Next Step",
					ajax   : false,
				}) }}
			</div>
		</section>

	{% elseif currentStep == 3 %}
		<!-- Step 3: ImageWorks Macro Input -->
		<section>
			<h2>Step 3: ImageWorks Macro</h2>
			<p>Paste an ImageWorks macro to define the settings that will be applied to all images in
			<strong>{{ selectedCollection }}.{{ selectedProperty }}</strong>. You can use the link
			linking tool that is available on any image and gallery form field.</p>

			{% set step3Fields %}
				{{ cms.form.field("hidden", "collection", { value: selectedCollection }) }}
				{{ cms.form.field("hidden", "property", { value: selectedProperty }) }}
				{{ cms.form.field("hidden", "step", { value: "process" }) }}

				{{ cms.form.field("textarea", "imageworks_macro", {
					label : "ImageWorks Macro",
					help  : "Paste your ImageWorks macro here.",
					value : postData.imageworks_macro ?? "{{ cms.imagePath('example', {w:400, h:400, fit:'crop'}) }}",
					rows  : 4,
					class : "no-change-listener",
				}) }}
			{% endset %}

			<div class="wizard-actions">
				{{ cms.form.simple(url.path, step3Fields, {
					method: "POST",
					label: "Start Batch Processing",
					ajax: false,
				}) }}
			</div>
		</section>

	{% elseif currentStep == 4 %}
		<!-- Step 4: Batch Processing -->
		<section>
			<h2>Step 4: Batch Processing</h2>
			<p>Processing images in <strong>{{ selectedCollection }}.{{ selectedProperty }}</strong> with the following ImageWorks macro:</p>

			<div class="macro-display">
				<code>{{ imageworksMacro }}</code>
			</div>

			<img src="{{ include(template_from_string(imageworksMacro)) }}" alt="Macro Example" id="macro-example">

			<div class="progress-container">
				<div class="progress-bar">
					<div class="progress-fill" id="progress-fill"></div>
				</div>
				<p id="progress-text">Preparing batch process...</p>
			</div>

			<div class="batch-preview" id="batch-preview"></div>

			<div class="wizard-actions">
				<button type="button" id="restart-batch" class="button dash-button" style="display: none;">Start New Batch</button>
			</div>
		</section>

		<script>
		// Store the batch processing data
		window.batchData = {
			collection : '{{ selectedCollection }}',
			property   : '{{ selectedProperty }}',
			example    : document.getElementById('macro-example').src,
			apiUrl     : '{{ cms.api }}'
		};
		</script>
		<script type="module" src="{{ cms.api }}/assets/image-batcher.js"></script>
	{% endif %}

	<!-- Data lists and modals from imageworks.twig -->
	<datalist id="border-options">
		<option value="10,ffffff,overlay"></option>
		<option value="15,palette,expand"></option>
		<option value="15,palette3,shrink"></option>
	</datalist>

	<datalist id="fit-options">
		<option value="contain"></option>
		<option value="max"></option>
		<option value="fill"></option>
		<option value="fill-max"></option>
		<option value="stretch"></option>
		<option value="crop"></option>
		<option value="crop-top"></option>
		<option value="crop-bottom"></option>
		<option value="crop-left"></option>
		<option value="crop-right"></option>
		<option value="crop-top-left"></option>
		<option value="crop-top-right"></option>
		<option value="crop-bottom-left"></option>
		<option value="crop-bottom-right"></option>
		<option value="crop-50-50"></option>
		<option value="crop-25-75-1.5"></option>
		<option value="crop-focalpoint"></option>
		<option value="crop-focalpoint-1.5"></option>
	</datalist>

</main>
{% endblock %}
