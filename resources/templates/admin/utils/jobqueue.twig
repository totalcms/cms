
<h1>{{ t('jobqueue.title') }}</h1>

<section style="display:grid;align-content:start;gap:1rem">

	{{ cms.form.jobqueueStats() }}

	<p>{{ t('jobqueue.clear_desc')|raw }}</p>

	{{ cms.form.clearqueue({
		label      : t('jobqueue.clear_btn'),
	}) }}

	<section style="margin-top:3rem;padding-left:0" class="doc-content">
		<h4 style="">{{ t('jobqueue.scheduled_title') }}</h4>

		<p>{{ t('jobqueue.command_desc') }}</p>
		<p><em>{{ t('jobqueue.php_path_note') }} {{ t('jobqueue.server_note') }}</em></p>

		<pre class="jobqueue-command"><code id="jobqueue-command-text">{{ cms.admin.processJobQueueCommand() }}</code></pre>
		<button type="button" class="cms-clip-button dash-button transparent" data-clip="#jobqueue-command-text">{{ t('btn.copy_command') }}</button>
	</section>

	{{ cms.admin.jobQueuePendingInfo() }}
	{{ cms.admin.jobQueueFailedInfo() }}

</section>

<style>
.jobqueue-command {
	width         : 100%;
	max-width     : 100%;
	overflow-x    : auto;
	white-space   : nowrap;
	background    : oklch(var(--totalform-nearwhite));
	border        : 1px solid oklch(var(--totalform-border-color));
	border-radius : var(--totalform-radius);
	padding       : 1rem;
	font-size     : 0.9em;
	box-sizing    : border-box;
}

.jobqueue-command code {
	white-space : nowrap;
	display     : block;
}

.jobqueue-command + .cms-clip-button {
	margin-top: 0.5rem;
}

.jobqueue-table-wrapper {
	max-height: 400px;
	max-width: 100%;
	overflow: auto;
	border: 1px solid oklch(var(--totalform-border-color));
	border-radius: var(--totalform-radius);
}

.jobqueue-preview {
	width: 100%;
	min-width: 800px;
	font-size: 0.9em;
	border-collapse: collapse;
}

.jobqueue-preview thead {
	position: sticky;
	top: 0;
	background: oklch(var(--totalform-nearwhite));
	z-index: 10;
}

.jobqueue-preview th,
.jobqueue-preview td {
	padding: 0.75rem 1rem;
	text-align: left;
	border-bottom: 1px solid oklch(var(--totalform-border-color));
	white-space: nowrap;
	overflow: hidden;
	text-overflow: ellipsis;
}

.jobqueue-preview th {
	font-weight: 600;
	border-bottom: 2px solid oklch(var(--totalform-border-color));
	background: oklch(var(--totalform-icon-bg));
}

.jobqueue-preview.pending-jobs tbody tr:hover {
	background-color: oklch(var(--totalform-success) / 0.05);
}

.jobqueue-preview.failed-jobs tbody tr:hover {
	background-color: oklch(var(--totalform-error) / 0.05);
}

.jobqueue-preview-section {
	margin-top: 2rem;
}

.jobqueue-preview-section:first-of-type {
	margin-top: 3rem;
}

.jobqueue-preview-section h3 {
	margin-top: 0;
	margin-bottom: 1rem;
}
</style>

