<h1>{{ t('image_cache.title') }}</h1>

<section class="dash-content-section">

	<p>{{ t('image_cache.desc') }} {{ t('image_cache.clear_warning') }}</p>

	<h2>{{ t('image_cache.clear_collection') }}</h2>

	{% set formfields %}
		{{ cms.form.field("select", "collection", {
			placeholder : t('image_cache.select_collection'),
			label       : t('label.collection'),
			class       : "no-change-listener",
			options     : cms.collection.list() | map(c => { value : c.id, label : c.name } ) | sortBy("label"),
		}) }}
	{% endset %}

	{{ cms.form.simple("/cache/images", formfields, {
		method  : "DELETE",
		label   : t('image_cache.clear_collection'),
		refresh : true,
	}) }}

	{% set forceRefresh = getData.refreshStats is defined %}
	{% set imageCacheStats = cms.admin.imageCacheService.getAllCollectionImageCacheStats(forceRefresh) %}
	{% if imageCacheStats|length > 0 %}
		<h3 style="margin-top:2rem">{{ t('image_cache.stats_title') }}</h3>
		<table class="admin-table">
			<thead>
				<tr>
					<th>{{ t('label.collection') }}</th>
					<th>{{ t('image_cache.cached_files') }}</th>
					<th>{{ t('image_cache.total_size') }}</th>
				</tr>
			</thead>
			<tbody>
				{% for stats in imageCacheStats %}
				<tr>
					<td><strong>{{ stats.collection }}</strong></td>
					<td>{{ stats.cached_files }}</td>
					<td>{{ stats.total_size_mb }} MB</td>
				</tr>
				{% endfor %}
			</tbody>
		</table>

		<div style="text-align:right;">
			<a href="utils/image-cache?refreshStats=1">↻ {{ t('image_cache.refresh') }}</a>
		</div>
	{% else %}
		<p style="margin-top:2rem"><em>{{ t('image_cache.empty') }}</em></p>
	{% endif %}

</section>
