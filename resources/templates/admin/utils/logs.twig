<h1>Log Analyzer</h1>

<section class="dash-content-section log-analyzer">

	<p>Total CMS has several different log files that it writes to depending on the task
		being performed. This page allows you to view the contents of these log files and
		analyze the errors that have been logged. You can select the log file you want to
		view from the dropdown below.</p>

	<p>Please note that not all errors are critical. Some errors are logged as a way to
		track the progress of a task or to provide additional information about what is
		happening.</p>

	{% set logfiles = cms.admin.logAnalyzer.logfiles() %}

	{% if logfiles | length == 0 %}
		<p class="no-logs">There are no log files available to view.
		The developer of this app must be a stud! 😎</p>
	{% endif %}

	{% set activelog = getData.logfile | default(cms.admin.logAnalyzer.defaultLogfile()) %}

	<form id="log-analyzer" class="totalform" data-disabled>
		<div class="form-field select-field">
			<label for="logfile">Select Logfile</label>
			<div style="display: flex; gap: 0.5rem; align-items: center;">
				<select name="logfile" id="logfile">
					{% for log,path in logfiles %}
						<option value="{{ log }}" {% if activelog == log %}selected{% endif %}>{{ log }}</option>
					{% endfor %}
				</select>
				<a id="log-download" href="utils/logs/download?logfile={{ activelog }}" class="btn btn-small" title="Download log file">Download</a>
			</div>
		</div>
	</form>
	<script>
	document.getElementById('logfile').addEventListener('change', function(e) {
		document.getElementById('log-download').href = 'utils/logs/download?logfile=' + encodeURIComponent(this.value);
		document.getElementById('log-analyzer').submit();
	});
	</script>


	{% set analysis = cms.admin.logAnalyzer.analyze(activelog) %}
	{# {% set total = 0 %}
	{% for error, value in analysis %}
		{% set total = total + value.count %}
	{% endfor %} #}

	<h2>Log Analysis <small>Found {{ analysis | length }} Issues</small></h2>

	<div class="log-analysis-container" style="max-height: 600px; overflow-y: auto; border: 1px solid oklch(var(--totalform-border-color)); border-radius: var(--totalform-radius);">
		<table class="admin-table" data-sort>
			<thead style="position: sticky; top: 0; background: oklch(var(--totalform-nearwhite)); z-index: 10;">
				<tr><th data-sort="number">Count</th><th>Logged Error</th></tr>
			</thead>
			<tbody>
				{% for error, value in analysis %}
				<tr>
					<td data-sort="{{ value.count }}">{{ value.count }}</td>
					<td>{{ error }}</td>
				</tr>
				{% endfor %}
			</tbody>
		</table>
	</div>

	<h2>Log Contents</h2>
	<div class="log-contents" style="max-height: 500px; overflow-y: auto; border: 1px solid oklch(var(--totalform-border-color)); border-radius: var(--totalform-radius); background: oklch(var(--totalform-nearwhite));">
<pre style="margin: 0; padding: 1rem; white-space: pre-wrap; word-wrap: break-word;">{% for line in cms.admin.logAnalyzer.logfile(activelog) %}{{ line | trim | escape }}
{% endfor %}</pre>
	</div>


</section>

