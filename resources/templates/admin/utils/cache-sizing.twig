<h1>{{ t('cache_sizing.title') }}</h1>

<section class="dash-content-section">

	<p>{{ t('cache_sizing.desc') }}</p>

	{% set sizing = cms.admin.cacheSizingAdvisor.getSizingAnalysis() %}

		{# Data Summary #}
		<div class="sizing-stats-grid">
			<div class="sizing-stat">
				<div class="sizing-stat-value">{{ sizing.scan.total_objects_human }}</div>
				<div class="sizing-stat-label">{{ t('cache_sizing.total_objects') }}</div>
			</div>
			<div class="sizing-stat">
				<div class="sizing-stat-value">{{ sizing.scan.collection_count }}</div>
				<div class="sizing-stat-label">{{ t('cache_sizing.collections') }}</div>
			</div>
			<div class="sizing-stat">
				<div class="sizing-stat-value">{{ sizing.scan.total_bytes_human }}</div>
				<div class="sizing-stat-label">{{ t('cache_sizing.total_data_size') }}</div>
			</div>
			<div class="sizing-stat">
				<div class="sizing-stat-value">{{ sizing.recommendations.estimated_entries_human }}</div>
				<div class="sizing-stat-label">{{ t('cache_sizing.estimated_entries') }}</div>
			</div>
		</div>

		{# Filesystem-only Warning #}
		{% if sizing.recommendations.filesystem_only_warning is defined %}
			<div class="sizing-warning">
				<strong>⚠️ {{ t('cache_sizing.no_memory_cache') }}</strong>
				<p>{{ sizing.recommendations.filesystem_only_warning }}</p>
			</div>
		{% endif %}

		{# Memory Recommendations #}
		<h3>{{ t('cache_sizing.memory_recs') }}</h3>
		<p>{{ t('cache_sizing.memory_desc') }}</p>
		<div class="sizing-stats-grid">
			{% for key, backend in sizing.recommendations.backends %}
				<div class="sizing-backend-card">
					<h5>{{ backend.name }}</h5>
					{% if backend.available %}
						<span class="success">✅ {{ t('label.active') }}</span>
					{% elseif backend.installed %}
						<span class="warning">⚠️ {{ t('label.installed') }}</span>
					{% else %}
						<span class="error">❌ {{ t('label.not_installed') }}</span>
					{% endif %}
					<div class="sizing-backend-detail">
						<strong>{{ t('label.recommended') }}:</strong> {{ backend.recommended_allocation }}
						<small>({{ backend.recommended_human }})</small>
					</div>
					{% if backend.current_allocated_human is defined and backend.current_allocated_human != 'N/A' %}
						<div class="sizing-backend-detail">
							<strong>{{ t('label.current') }}:</strong> {{ backend.current_allocated_human }}
							{% if backend.sufficient is same as(true) %}
								<span class="success">✅ {{ t('label.sufficient') }}</span>
							{% elseif backend.sufficient is same as(false) %}
								<span class="error">❌ {{ t('label.insufficient') }}</span>
							{% endif %}
						</div>
					{% endif %}
				</div>
			{% endfor %}
		</div>

		{# Configuration Examples #}
		<h3>{{ t('cache_sizing.config_examples') }}</h3>
		{% for key, example in sizing.config_examples %}
			<div class="sizing-config-block">
				<h5>{{ example.name }}</h5>
				<p class="sizing-config-note">{{ example.note }}</p>
				<p><small><strong>File:</strong> <code>{{ example.file }}</code></small></p>
				<pre class="sizing-config-code">{{ example.config }}</pre>
			</div>
		{% endfor %}

		{# Per-Collection Breakdown #}
		{% if sizing.scan.collections|length > 0 %}
			<h3>{{ t('cache_sizing.per_collection') }}</h3>
			<table class="admin-table">
				<thead>
					<tr>
						<th>{{ t('label.collection') }}</th>
						<th>{{ t('label.schema') }}</th>
						<th>{{ t('label.objects') }}</th>
						<th>{{ t('cache_sizing.object_data') }}</th>
						<th>{{ t('cache_sizing.index_size') }}</th>
						<th>{{ t('cache_sizing.avg_object') }}</th>
						<th>{{ t('cache_sizing.largest_object') }}</th>
					</tr>
				</thead>
				<tbody>
					{% for col in sizing.scan.collections %}
					<tr>
						<td><strong>{{ col.collection_name }}</strong></td>
						<td>{{ col.schema }}</td>
						<td>{{ col.object_count }}</td>
						<td>{{ col.object_bytes_human }}</td>
						<td>{{ col.index_bytes_human }}</td>
						<td>{{ col.avg_object_bytes_human }}</td>
						<td>{{ col.largest_object_bytes_human }}</td>
					</tr>
					{% endfor %}
				</tbody>
			</table>
		{% endif %}

		<div style="text-align:right; margin-top:1rem;">
			<a href="utils/cache-sizing">↻ {{ t('cache_sizing.refresh') }}</a>
		</div>

</section>

<style>
.sizing-stats-grid {
	display: grid;
	grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
	gap: 1rem;
	margin: 1rem 0;
}

.sizing-stat {
	background: oklch(var(--totalform-nearwhite));
	border: 1px solid oklch(var(--totalform-border-color));
	border-radius: var(--totalform-radius);
	padding: 1rem;
	text-align: center;
}

.sizing-stat-value {
	font-size: 1.5rem;
	font-weight: bold;
	color: oklch(var(--totalform-accent));
}

.sizing-stat-label {
	font-size: 0.85rem;
	color: oklch(var(--totalform-darkgray));
	margin-top: 0.25rem;
}

.sizing-warning {
	background: #fff3cd;
	border: 1px solid #ffeaa7;
	border-radius: var(--totalform-radius);
	padding: 1rem 1.5rem;
	margin: 1rem 0;
	color: #856404;
}

.sizing-warning p {
	margin: 0.5rem 0 0;
}

.sizing-backend-card {
	background: oklch(var(--totalform-nearwhite));
	border: 1px solid oklch(var(--totalform-border-color));
	border-radius: var(--totalform-radius);
	padding: 1rem;
}

.sizing-backend-card h5 {
	margin: 0 0 0.5rem;
	color: oklch(var(--totalform-darkgray));
}

.sizing-backend-detail {
	margin-top: 0.5rem;
	font-size: 0.9rem;
}

.sizing-config-block {
	background: oklch(var(--totalform-nearwhite));
	border: 1px solid oklch(var(--totalform-border-color));
	border-radius: var(--totalform-radius);
	padding: 1rem 1.5rem;
	margin: 1rem 0;
}

.sizing-config-block h5 {
	margin: 0 0 0.5rem;
	color: oklch(var(--totalform-darkgray));
}

.sizing-config-note {
	font-size: 0.9rem;
	margin: 0 0 0.5rem;
}

.sizing-config-code {
	background: oklch(var(--totalform-icon-bg));
	border: 1px solid oklch(var(--totalform-border-color));
	border-radius: var(--totalform-radius);
	padding: 1rem;
	font-family: monospace;
	font-size: 0.85rem;
	white-space: pre-wrap;
	user-select: all;
	overflow-x: auto;
}

.success {
	color: #28a745;
	font-weight: bold;
}

.warning {
	font-weight: bold;
}

.error {
	color: #dc3545;
	font-weight: bold;
}
</style>
