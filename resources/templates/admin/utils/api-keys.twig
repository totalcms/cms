{% if subAction == 'new' %}
	{# New API Key Form Page #}
	<h1><a href="/admin/utils/api-keys">API Keys</a> / <span>new</span></h1>

	<section class="dash-content-section">
		<p>Create a new API key to allow external services to access your Total CMS data. You can limit access by HTTP methods and specific API endpoints.</p>

		<form id="create-apikey-form" class="totalform help-box help-on-hover">
			{{ cms.form.field("text", "name", {
				label: "Name",
				help: "A descriptive name to help you identify this key (e.g., Zapier Integration, Mobile App, etc.)",
				placeholder: "e.g., Zapier Integration",
				required: true,
			}) }}

			<div class="form-field help-box help-on-hover">
				<label>HTTP Methods <span class="required">*</span></label>
				<div class="checkbox-group">
					<label><input type="checkbox" name="methods[]" value="GET" checked> GET (Read)</label>
					<label><input type="checkbox" name="methods[]" value="POST"> POST (Create)</label>
					<label><input type="checkbox" name="methods[]" value="PUT"> PUT (Update)</label>
					<label><input type="checkbox" name="methods[]" value="PATCH"> PATCH (Partial Update)</label>
					<label><input type="checkbox" name="methods[]" value="DELETE"> DELETE (Delete)</label>
				</div>
				<p class="help">Select which HTTP methods this key can use</p>
			</div>

			<div class="form-field help-box help-on-hover">
				<label>Allowed Endpoints <span class="required">*</span></label>
				<div class="radio-group">
					<label><input type="radio" name="endpoint-type" value="all" checked> All endpoints (*)</label>
					<label><input type="radio" name="endpoint-type" value="specific"> Specific endpoints</label>
				</div>
				<p class="help">Choose which endpoints this key can access</p>
			</div>

			<div id="specific-endpoints" class="form-field help-box help-on-hover" style="display: none;">
				<label>Select Endpoints</label>
				<div class="checkbox-group">
					<label><input type="checkbox" name="paths[]" value="/api/collections/*"> All Collections</label>
					{% for collection in cms.collections() %}
					<label style="margin-left: 20px;">
						<input type="checkbox" name="paths[]" value="/api/collections/{{ collection.id }}/*">
						{{ collection.name }}
					</label>
					{% endfor %}
					<label><input type="checkbox" name="paths[]" value="/api/auth/*"> Authentication</label>
					<label><input type="checkbox" name="paths[]" value="/api/users/*"> Users</label>
					<label><input type="checkbox" name="paths[]" value="/api/settings/*"> Settings</label>
				</div>
				<p class="help">Check the endpoints this key should have access to</p>
			</div>

			<div class="form-inline-fields">
				<a href="/admin/utils/api-keys" class="dash-button dash-button-secondary">Cancel</a>
				<button type="submit" class="dash-button">Create API Key</button>
			</div>
		</form>
	</section>

	{# Show Created Key Modal #}
	<dialog id="show-apikey-modal" class="cms-modal">
		<section class="scroller">
			<h2>API Key Created Successfully</h2>
			<button type="button" class="close">×</button>

			<div class="warning-box">
				<strong>⚠️ Save this key now!</strong>
				<p>This is the only time you'll see the full key. Copy it and store it securely.</p>
			</div>

			{{ cms.form.field("text", "generated-key", {
				label: "API Key",
				readonly: true,
				class: "api-key-display",
			}) }}

			<button type="button" class="dash-button" id="copy-key-btn">Copy to Clipboard</button>

			<div class="form-inline-fields" style="margin-top: 2rem;">
				<a href="/admin/utils/api-keys" class="dash-button">Done</a>
			</div>
		</section>
	</dialog>

	<style>
	.warning-box {
		background: #fff3cd;
		border: 1px solid #ffeaa7;
		border-radius: var(--totalform-radius);
		padding: 1rem;
		margin-bottom: 1.5rem;
		color: #856404;
	}

	.warning-box p {
		margin: 0.5rem 0 0 0;
	}

	.api-key-display input {
		font-family: monospace;
		background: oklch(var(--totalform-nearwhite));
	}

	.required {
		color: oklch(var(--totalform-danger));
	}

	.checkbox-group label,
	.radio-group label {
		display: block;
		margin: 0.5rem 0;
		cursor: pointer;
	}

	.checkbox-group input[type="checkbox"],
	.radio-group input[type="radio"] {
		margin-right: 0.5rem;
	}

	.dash-button-secondary {
		background: oklch(var(--totalform-nearwhite));
		color: oklch(var(--totalform-darkgray));
		text-decoration: none;
		display: inline-block;
	}

	.dash-button-secondary:hover {
		background: oklch(var(--totalform-border-color));
	}

	.cms-modal section.scroller {
		max-width: 600px;
		width: 90vw;
		max-height: 90vh;
		overflow-y: auto;
		padding: 2rem;
	}

	.cms-modal h2 {
		margin-top: 0;
		margin-bottom: 1.5rem;
	}

	.cms-modal .close {
		position: absolute;
		top: 1rem;
		right: 1rem;
		background: none;
		border: none;
		font-size: 2rem;
		line-height: 1;
		cursor: pointer;
		padding: 0;
		width: 30px;
		height: 30px;
		color: oklch(var(--totalform-darkgray));
	}

	.cms-modal .close:hover {
		color: oklch(var(--totalform-accent));
	}
	</style>

	<script>
	// Toggle specific endpoints visibility
	document.addEventListener('DOMContentLoaded', function() {
		document.querySelectorAll('input[name="endpoint-type"]').forEach(radio => {
			radio.addEventListener('change', function() {
				const specificEndpoints = document.getElementById('specific-endpoints');
				if (this.value === 'specific') {
					specificEndpoints.style.display = 'block';
				} else {
					specificEndpoints.style.display = 'none';
					// Uncheck all specific endpoints
					document.querySelectorAll('#specific-endpoints input[type="checkbox"]').forEach(cb => {
						cb.checked = false;
					});
				}
			});
		});
	});

	// Create API key form submission
	document.addEventListener('DOMContentLoaded', function() {
		document.getElementById('create-apikey-form').addEventListener('submit', async function(e) {
		e.preventDefault();

		const formData = new FormData(this);
		const name = formData.get('name');
		const methods = formData.getAll('methods[]');
		const endpointType = formData.get('endpoint-type');

		let paths = [];
		if (endpointType === 'all') {
			paths = ['*'];
		} else {
			paths = formData.getAll('paths[]');
		}

		if (methods.length === 0) {
			alert('Please select at least one HTTP method');
			return;
		}

		if (paths.length === 0) {
			alert('Please select at least one endpoint or choose "All endpoints"');
			return;
		}

		try {
			const response = await fetch('/apikeys', {
				method: 'POST',
				headers: {
					'Content-Type': 'application/json',
				},
				body: JSON.stringify({
					name: name,
					methods: methods,
					paths: paths
				})
			});

			const data = await response.json();

			if (data.success) {
				// Show the generated key
				document.querySelector('input[name="generated-key"]').value = data.apiKey.key;

				// Get the dialog and open it
				const modalEl = document.getElementById('show-apikey-modal');
				if (modalEl && modalEl.dialog) {
					modalEl.dialog.open();
				} else {
					// Fallback to native showModal if Dialog class not initialized
					modalEl.showModal();
				}
			} else {
				alert('Error: ' + data.message);
			}
		} catch (error) {
			alert('Error creating API key: ' + error.message);
		}
		});
	});

	// Copy key to clipboard
	document.addEventListener('DOMContentLoaded', function() {
		document.getElementById('copy-key-btn').addEventListener('click', function() {
			const keyInput = document.querySelector('input[name="generated-key"]');
			keyInput.select();
			navigator.clipboard.writeText(keyInput.value).then(() => {
				const originalText = this.textContent;
				this.textContent = 'Copied!';
				setTimeout(() => {
					this.textContent = originalText;
				}, 2000);
			});
		});
	});
	</script>

	<script type="module">
	import Dialog from '{{ cms.api }}/assets/dialog.js';

	const showKeyDialog = new Dialog(document.getElementById('show-apikey-modal'));
	</script>

{% else %}
	{# List API Keys Page #}
	<h1>API Keys</h1>

	<section class="dash-content-section">

		<p>API keys allow external services to access your Total CMS data. Each key can be limited to specific HTTP methods and API endpoints for security.</p>

		<div style="margin: 2rem 0; text-align: right;">
			<a href="/admin/utils/api-keys/new" class="dash-button">
				<svg width="14" height="14" viewBox="0 0 14 14" fill="none" style="vertical-align: middle; margin-right: 5px;">
					<path d="M7 1V13M1 7H13" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
				</svg>
				Create API Key
			</a>
		</div>

		{% if apiKeys|length > 0 %}
			<table class="admin-table">
				<thead>
					<tr>
						<th>Name</th>
						<th>API Key</th>
						<th>HTTP Methods</th>
						<th>Endpoints</th>
						<th>Created</th>
						<th>Last Used</th>
						<th style="width: 100px;">Actions</th>
					</tr>
				</thead>
				<tbody>
					{% for apiKey in apiKeys %}
					<tr>
						<td><strong>{{ apiKey.name }}</strong></td>
						<td><code>{{ apiKey.getMaskedKey() }}</code></td>
						<td>{{ apiKey.scopes.methods|join(', ') }}</td>
						<td>
							{% if '*' in apiKey.scopes.paths %}
								<em>All endpoints</em>
							{% else %}
								{{ apiKey.scopes.paths|slice(0, 2)|join(', ') }}
								{% if apiKey.scopes.paths|length > 2 %}
									<span title="{{ apiKey.scopes.paths|join(', ') }}">... (+{{ apiKey.scopes.paths|length - 2 }} more)</span>
								{% endif %}
							{% endif %}
						</td>
						<td>{{ apiKey.created|date('Y-m-d H:i') }}</td>
						<td>
							{% if apiKey.lastUsed %}
								{{ apiKey.lastUsed|date('Y-m-d H:i') }}
							{% else %}
								<em>Never</em>
							{% endif %}
						</td>
						<td>
							<button type="button" class="dash-button dash-button-small dash-button-danger delete-apikey-btn" data-id="{{ apiKey.id }}" data-name="{{ apiKey.name }}">
								Delete
							</button>
						</td>
					</tr>
					{% endfor %}
				</tbody>
			</table>
		{% else %}
			<div class="empty-state">
				<p><em>No API keys created yet. Click "Create API Key" to get started.</em></p>
			</div>
		{% endif %}

	</section>

	<style>
	.empty-state {
		text-align: center;
		padding: 3rem;
		background: oklch(var(--totalform-nearwhite));
		border-radius: var(--totalform-radius);
		color: oklch(var(--totalform-darkgray));
	}

	.dash-button-danger {
		background: oklch(var(--totalform-danger));
	}

	.dash-button-danger:hover {
		background: oklch(var(--totalform-danger) / 0.8);
	}

	.dash-button-small {
		padding: 0.4rem 0.8rem;
		font-size: 0.85rem;
	}
	</style>

	<script>
	// Delete API key
	document.querySelectorAll('.delete-apikey-btn').forEach(btn => {
		btn.addEventListener('click', async function() {
			const id = this.dataset.id;
			const name = this.dataset.name;

			if (!confirm(`Are you sure you want to delete the API key "${name}"? This action cannot be undone.`)) {
				return;
			}

			try {
				const response = await fetch(`/apikeys/${id}`, {
					method: 'DELETE'
				});

				const data = await response.json();

				if (data.success) {
					window.location.reload();
				} else {
					alert('Error: ' + data.message);
				}
			} catch (error) {
				alert('Error deleting API key: ' + error.message);
			}
		});
	});
	</script>
{% endif %}
