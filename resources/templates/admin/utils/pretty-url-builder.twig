<h1>{{ t('pretty_url.title') }}</h1>

<section class="dash-content-section">

	<p>{{ t('pretty_url.desc') }}</p>

	<form id="pretty-url-builder"
		class="totalform"
		action="{{ cms.dashboard }}/utils/pretty-url-builder"
		method="POST"
		data-disabled>
		<div>
			<label for="collection">{{ t('label.collection') }}</label>
			<select name="collection" id="collection">
				<option value="">{{ t('pretty_url.select_collection') }}</option>
				{% for collection in sortByKey(cms.collection.list(), "id") %}
					<option value="{{ collection.id }}"
						{% if postData.collection == collection.id %}selected{% endif %}>
						{{ collection.name }}
					</option>
				{% endfor %}
			</select>
			<label for="path" style="margin-top:1rem">{{ t('pretty_url.path_label') }}</label>
			<input type="text" name="path" value="{{ postData.path }}" placeholder="{{ t('pretty_url.path_ph') }}"/>
		</div>
		<button class="cms-button" type="submit">{{ t('pretty_url.generate_btn') }}</button>
	</form>

	{% if postData.path and postData.collection %}

		{% if str_ends_with(postData.path, 'php') %}
			<div class="doc-content pretty-url-results">
				{% set collectionData = cms.collection.get(postData.collection) %}

				<h2>{{ t('pretty_url.rules_title', {'{collection}': collectionData.name}) }}</h2>

				<section>
				<h3>{{ t('pretty_url.save_path', {'{collection}': collectionData.name}) }}</h3>
				<p>{{ t('pretty_url.edit_desc') }}
				<a href="collections/{{ postData.collection }}/edit" target="_blank">{{ t('pretty_url.edit_now') }} ↗</a></p>
				<pre></code>{{ cms.collection.prettyUrl(postData.path) }}</code></pre>
				</section>

				{% if collectionData.url is empty %}
				<p class="cms-error">{{ t('pretty_url.no_url_saved') }}</p>
				{% endif %}

				<section>
				<h3>{{ t('pretty_url.apache_title') }}</h3>
				<p>{{ t('pretty_url.apache_desc') }}</p>
				<pre></code>{{ cms.admin.apacheRule(postData.path, collectionData.name) }}</code></pre>
				</section>

				<section>
				<h3>{{ t('pretty_url.nginx_title') }}</h3>
				<p>{{ t('pretty_url.nginx_desc') }}</p>
				<pre></code>{{ cms.admin.nginxRule(postData.path, collectionData.name) }}</code></pre>
				</section>

			</div>
		{% else %}
			<p class="error">{{ t('pretty_url.invalid_path') }} <strong>{{ postData.path }}</strong></p>
		{% endif %}

	{% endif %}


</section>