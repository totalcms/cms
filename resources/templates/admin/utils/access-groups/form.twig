{# Access Group Form Page #}
<h1>{% if isEdit %}{{ t('access_groups.edit_title') }}{% else %}{{ t('access_groups.new_title') }}{% endif %}</h1>

<section class="dash-content-section">
	<p>{{ t('access_groups.form_desc') }} {{ t('access_groups.perm_merge') }}</p>

	{% set formFields %}
		{{ cms.form.field("id", "id", {
			label       : t('access_groups.group_id'),
			help        : t('access_groups.group_id_help'),
			placeholder : t('access_groups.group_id_ph'),
			required    : true,
			value       : group ? group.id : '',
			readonly    : isEdit,
			pattern     : "[a-z0-9-]+",
		}) }}

		{{ cms.form.field("textarea", "description", {
			label       : t('access_groups.description'),
			help        : t('access_groups.description_help'),
			placeholder : t('access_groups.description_ph'),
			value       : group ? group.description : '',
			rows        : 3,
		}) }}

		<div class="permission-section">
			<h3>{{ t('access_groups.obj_permissions') }}</h3>

			{{ cms.form.field("multicheckbox", "collections-operations", {
				label    : t('access_groups.obj_operations'),
				value    : group ? group.permissions.collections.operations : ["read"],
				options  : [
					{value: "create", label: t('access_groups.op_create')},
					{value: "read", label: t('access_groups.op_read')},
					{value: "update", label: t('access_groups.op_update')},
					{value: "delete", label: t('access_groups.op_delete')}
				],
				settings : {
					fieldGrid: "150px"
				}
			}) }}

			{{ cms.form.field("multicheckbox", "collections-all", {
				label    : t('access_groups.collection_access'),
				value    : group ? (group.permissions.collections.all ? ["all"] : []) : ["all"],
				options  : [
					{value: "all", label: t('access_groups.all_obj_collections')}
				]
			}) }}

			{% set collectionOptions = [] %}
			{% for collection in collections | sort((a, b) => a.name|lower <=> b.name|lower) %}
				{% set collectionOptions = collectionOptions|merge([{
					value: collection.id,
					label: collection.name
				}]) %}
			{% endfor %}

			{{ cms.form.field("multicheckbox", "collections-allowed", {
				label    : t('access_groups.specific_collections'),
				help     : t('access_groups.select_collections'),
				value    : group ? group.permissions.collections.allowed : [],
				options  : collectionOptions,
				settings : {
					fieldColumns: "150px",
					visibility : {
						watch    : "collections-all",
						value    : "all",
						operator : "not_in"
					}
				}
			}) }}
		</div>

		<div class="permission-section">
			<h3>{{ t('access_groups.meta_permissions') }}</h3>

			{{ cms.form.field("multicheckbox", "collectionsMeta-operations", {
				label    : t('access_groups.meta_operations'),
				value    : group ? group.permissions.collectionsMeta.operations : ["read"],
				options  : [
					{value: "create", label: t('access_groups.op_create')},
					{value: "read", label: t('access_groups.op_read')},
					{value: "update", label: t('access_groups.op_update')},
					{value: "delete", label: t('access_groups.op_delete')}
				],
				settings : {
					fieldGrid: "150px"
				}
			}) }}

			{{ cms.form.field("multicheckbox", "collectionsMeta-all", {
				label    : t('access_groups.meta_access'),
				value    : group ? (group.permissions.collectionsMeta.all ? ["all"] : []) : ["all"],
				options  : [
					{value: "all", label: t('access_groups.all_collections_meta')}
				]
			}) }}

			{{ cms.form.field("multicheckbox", "collectionsMeta-allowed", {
				label    : t('access_groups.specific_collections'),
				help     : t('access_groups.select_meta'),
				value    : group ? group.permissions.collectionsMeta.allowed : [],
				options  : collectionOptions,
				settings : {
					fieldColumns: "150px",
					visibility : {
						watch    : "collectionsMeta-all",
						value    : "all",
						operator : "not_in"
					}
				}
			}) }}
		</div>

		<div class="permission-section">
			<h3>{{ t('access_groups.schema_permissions') }}</h3>

			{{ cms.form.field("multicheckbox", "schemas-operations", {
				label    : t('access_groups.schema_operations'),
				value    : group ? group.permissions.schemas.operations : ["read"],
				options  : [
					{value: "create", label: t('access_groups.op_create')},
					{value: "read", label: t('access_groups.op_read')},
					{value: "update", label: t('access_groups.op_update')},
					{value: "delete", label: t('access_groups.op_delete')}
				],
				settings : {
					fieldGrid: "150px"
				}
			}) }}

			{{ cms.form.field("multicheckbox", "schemas-all", {
				label    : t('access_groups.schema_access'),
				value    : group ? (group.permissions.schemas.all ? ["all"] : []) : ["all"],
				options  : [
					{value: "all", label: t('access_groups.all_schemas')}
				]
			}) }}

			{% set schemaOptions = [] %}
			{% for schema in schemas %}
				{% set schemaOptions = schemaOptions|merge([{
					value: schema.id,
					label: schema.id
				}]) %}
			{% endfor %}

			{{ cms.form.field("multicheckbox", "schemas-allowed", {
				label    : t('access_groups.specific_schemas'),
				help     : t('access_groups.select_schemas'),
				value    : group ? group.permissions.schemas.allowed : [],
				options  : schemaOptions,
				settings : {
					fieldGrid: "150px",
					visibility : {
						watch    : "schemas-all",
						value    : "all",
						operator : "not_in"
					}
				}
			}) }}
		</div>

		<div class="permission-section">
			<h3>{{ t('access_groups.other_permissions') }}</h3>

			{{ cms.form.field("multicheckbox", "permissions-simple", {
				label    : t('access_groups.dashboard_features'),
				help     : t('access_groups.select_features'),
				value    : group ? (
					(group.permissions.templates ? ["templates"] : [])|merge(
						group.permissions.mailer ? ["mailer"] : []
					)|merge(
						group.permissions.playground ? ["playground"] : []
					)|merge(
						group.permissions.dataviews ? ["dataviews"] : []
					)|merge(
						group.permissions.docs ? ["docs"] : []
					)
				) : ["docs", "mailer", "templates", "playground", "dataviews"],
				options  : [
					{value: "docs", label: t('access_groups.feature_docs')},
					{value: "mailer", label: t('access_groups.feature_mailer')},
					{value: "templates", label: t('access_groups.feature_templates')},
					{value: "playground", label: t('access_groups.feature_playground')},
					{value: "dataviews", label: t('access_groups.feature_dataviews')},
				],
				settings : {
					fieldColumns: "150px"
				}
			}) }}

			{{ cms.form.field("multicheckbox", "utils-all", {
				label    : t('access_groups.utils_access'),
				value    : group ? (group.permissions.utils.all ? ["all"] : []) : ["all"],
				options  : [
					{value: "all", label: t('access_groups.all_utils')}
				]
			}) }}

			{{ cms.form.field("multicheckbox", "utils-allowed", {
				label    : t('access_groups.specific_utils'),
				help     : t('access_groups.select_utils'),
				value    : group ? group.permissions.utils.allowed : [],
				options  : [
					{value: "cache", label: t('access_groups.util_cache')},
					{value: "collection-report", label: t('access_groups.util_collection_report')},
					{value: "image-batcher", label: t('access_groups.util_image_batcher')},
					{value: "import", label: t('access_groups.util_import')},
					{value: "jobqueue", label: t('access_groups.util_jobqueue')},
					{value: "jumpstart", label: t('access_groups.util_jumpstart')},
					{value: "license", label: t('access_groups.util_license')},
					{value: "log-analyzer", label: t('access_groups.util_logs')},
					{value: "orphan-scanner", label: t('access_groups.util_orphan_scanner')},
					{value: "pretty-url", label: t('access_groups.util_pretty_url')},
					{value: "project-setup", label: t('access_groups.util_setup')},
					{value: "server-checker", label: t('access_groups.util_server')},
					{value: "twig-debugger", label: t('access_groups.util_debugger')}
				],
				settings : {
					fieldColumns: "150px",
					visibility : {
						watch : "utils-all",
						value : "all",
						operator: "not_in"
					}
				}
			}) }}

		</div>
	{% endset %}

	{% set apiRoute = isEdit ? "/access-groups/" ~ group.id : "/access-groups" %}
	{{ cms.form.totalform(apiRoute, formFields, {
		class  : "access-groups-form",
		method : isEdit ? "PUT" : "POST",
		save   : isEdit ? t('access_groups.update_submit') : t('access_groups.create_submit'),
		newActions: [
			{
				action: "redirect",
				link: "utils/access-groups"
			}
		],
		editActions: [
			{
				action: "redirect",
				link: "utils/access-groups"
			}
		]
	}) }}

</section>

<style>
.help-text {
	color         : oklch(var(--totalform-darkgray));
	font-size     : 0.9rem;
	margin-top    : -0.5rem;
	margin-bottom : 1rem;
}
h3 {
	margin-block : 2rem 1rem;
}
.multicheckbox-field {
	margin-block-start : 1rem;
	margin-inline-start : 1rem;
}
.permission-section {
	background    : oklch(var(--totalform-nearwhite) / 0.5);
	border        : 1px solid oklch(var(--totalform-border-color));
	border-radius : var(--totalform-radius);
	padding       : 1.5rem;
	margin-block  : 1rem;
}
.permission-section:first-of-type {
	margin-top : 0;
}
.permission-section h3 {
	margin-block-start : 0;
}
</style>

<script>
document.addEventListener('DOMContentLoaded', function() {
	// Handle checkbox cascading for "All" options
	const form = document.querySelector('.access-groups-form');

	// When "All Collections" is checked, optionally check all collections
	const collectionsAll = form.querySelector('input[name="collections-all[]"][value="all"]');
	if (collectionsAll) {
		collectionsAll.addEventListener('change', function() {
			// The visibility setting will handle showing/hiding the specific collections
		});
	}

	// When "All Schemas" is checked
	const schemasAll = form.querySelector('input[name="schemas-all[]"][value="all"]');
	if (schemasAll) {
		schemasAll.addEventListener('change', function() {
			// The visibility setting will handle showing/hiding the specific schemas
		});
	}

	// When "All Utils" is checked
	const utilsAll = form.querySelector('input[name="utils-all[]"][value="all"]');
	if (utilsAll) {
		utilsAll.addEventListener('change', function() {
			// The visibility setting will handle showing/hiding the specific utils
		});
	}

	// When "All Settings" is checked
	const settingsAll = form.querySelector('input[name="settings-all[]"][value="all"]');
	if (settingsAll) {
		settingsAll.addEventListener('change', function() {
			// The visibility setting will handle showing/hiding the specific settings
		});
	}

	// Parse permissions-simple back into individual fields for saving
	form.addEventListener('submit', function(e) {
		const permissionsSimple = Array.from(form.querySelectorAll('input[name="permissions-simple[]"]:checked'))
			.map(cb => cb.value);

		// Create hidden inputs for each simple permission
		['templates', 'mailer', 'playground', 'dataviews', 'docs'].forEach(function(perm) {
			const existingInput = form.querySelector(`input[name="${perm}"]`);
			if (existingInput) {
				existingInput.remove();
			}

			if (permissionsSimple.includes(perm)) {
				const input = document.createElement('input');
				input.type = 'hidden';
				input.name = perm;
				input.value = perm;
				form.appendChild(input);
			}
		});
	});
});
</script>
