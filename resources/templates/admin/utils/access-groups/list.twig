{# List Access Groups Page #}
<h1>{{ t('access_groups.title') }}</h1>

<section class="dash-content-section">

	<p>{{ t('access_groups.desc') }} {{ t('access_groups.perm_merge') }}</p>

	<div style="margin-block: 2rem; text-align: right;">
		<a href="utils/access-groups/new" class="dash-button">＋ {{ t('access_groups.create_btn') }}</a>
	</div>

	{% if groups|length > 0 %}
		<div class="dash-card-grid" style="grid-template-columns:repeat(auto-fill, minmax(450px, 1fr));">
			{% for group in groups %}
			<article class="dash-card{% if group.id in ['admin', 'default'] %} accent{% endif %}">
				<header>
					<h3>{{ group.id }}</h3>
					{% if group.id == 'admin' %}
						<span class="dash-badge accent">{{ t('label.built_in') }}</span>
					{% elseif group.id == 'default' %}
						<div class="dash-card-actions">
							<a href="utils/access-groups/{{ group.id }}"
							   class="dash-card-action edit"
							   title="{{ t('btn.edit') }}">{{ t('btn.edit') }}</a>
							<span class="dash-badge accent">{{ t('label.built_in') }}</span>
						</div>
					{% else %}
						<div class="dash-card-actions">
							<a href="utils/access-groups/{{ group.id }}"
							   class="dash-card-action edit"
							   title="{{ t('btn.edit') }}">{{ t('btn.edit') }}</a>
							{{ cms.admin.quickActionButton('', 'access-groups/' ~ group.id, {
								method: 'delete',
								confirm: t('access_groups.confirm_delete'),
								reload: true,
								class: 'dash-card-action delete',
							}) }}
						</div>
					{% endif %}
				</header>

				{% if group.description %}
				<div class="dash-card-description">
					<p>{{ group.description }}</p>
				</div>
				{% endif %}

				<div class="dash-card-details">
					<div class="dash-card-detail">
						<strong>{{ t('access_groups.objects') }}</strong>
						<span>
							{% if group.permissions.collections.all %}
								<em>{{ t('access_groups.all_collections') }}</em>
								<div class="dash-badge-group">
									{% for operation in group.permissions.collections.operations %}
										<span class="dash-badge accent sm">{{ operation | upper }}</span>
									{% endfor %}
								</div>
							{% elseif group.permissions.collections.allowed|length > 0 %}
								{{ group.permissions.collections.allowed|join(', ') }}
								<div class="dash-badge-group">
									{% for operation in group.permissions.collections.operations %}
										<span class="dash-badge accent sm">{{ operation | upper }}</span>
									{% endfor %}
								</div>
							{% else %}
								<em>{{ t('label.none') }}</em>
							{% endif %}
						</span>
					</div>

					<div class="dash-card-detail">
						<strong>{{ t('access_groups.collections') }}</strong>
						<span>
							{% if group.permissions.collectionsMeta.all %}
								<em>{{ t('access_groups.all_collections') }}</em>
								<div class="dash-badge-group">
									{% for operation in group.permissions.collectionsMeta.operations %}
										<span class="dash-badge accent sm">{{ operation | upper }}</span>
									{% endfor %}
								</div>
							{% elseif group.permissions.collectionsMeta.allowed|length > 0 %}
								{{ group.permissions.collectionsMeta.allowed|join(', ') }}
								<div class="dash-badge-group">
									{% for operation in group.permissions.collectionsMeta.operations %}
										<span class="dash-badge accent sm">{{ operation | upper }}</span>
									{% endfor %}
								</div>
							{% else %}
								<em>{{ t('label.none') }}</em>
							{% endif %}
						</span>
					</div>

					<div class="dash-card-detail">
						<strong>{{ t('access_groups.schemas') }}</strong>
						<span>
							{% if group.permissions.schemas.all %}
								<em>{{ t('access_groups.all_schemas') }}</em>
								<div class="dash-badge-group">
									{% for operation in group.permissions.schemas.operations %}
										<span class="dash-badge accent sm">{{ operation | upper }}</span>
									{% endfor %}
								</div>
							{% elseif group.permissions.schemas.allowed|length > 0 %}
								{{ group.permissions.schemas.allowed|join(', ') }}
								<div class="dash-badge-group">
									{% for operation in group.permissions.schemas.operations %}
										<span class="dash-badge accent sm">{{ operation | upper }}</span>
									{% endfor %}
								</div>
							{% else %}
								<em>{{ t('label.none') }}</em>
							{% endif %}
						</span>
					</div>

					<div class="dash-card-detail">
						<strong>{{ t('access_groups.other_access') }}</strong>
						<div class="dash-badge-group">
							{% if group.permissions.templates %}<span class="dash-badge success">{{ t('access_groups.feature_templates') }}</span>{% endif %}
							{% if group.permissions.mailer %}<span class="dash-badge success">{{ t('access_groups.feature_mailer') }}</span>{% endif %}
							{% if group.permissions.playground %}<span class="dash-badge success">{{ t('access_groups.feature_playground') }}</span>{% endif %}
							{% if group.permissions.dataviews %}<span class="dash-badge success">{{ t('access_groups.feature_dataviews') }}</span>{% endif %}
							{% if group.permissions.docs %}<span class="dash-badge success">{{ t('access_groups.feature_docs') }}</span>{% endif %}

							{% if group.permissions.utils.all %}
								<span class="dash-badge success">{{ t('access_groups.all_utils') }}</span>
							{% elseif group.permissions.utils.allowed|length > 0 %}
								{% for util in group.permissions.utils.allowed %}
									<span class="dash-badge success">{{ util | capitalize }}</span>
								{% endfor %}
							{% endif %}
						</div>
					</div>

				</div>
			</article>
			{% endfor %}
		</div>
	{% else %}
		<div class="dash-empty-state">
			<em>{{ t('access_groups.empty') }}</em>
		</div>
	{% endif %}
</section>
