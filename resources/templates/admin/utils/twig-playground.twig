<h1>Twig Playground</h1>

<section class="dash-content-section">
	<p>This will allow you to learn twig faster and run it against the data inside of the CMS.</p>

	<form id="twig-playground"
		class="totalform"
		action="{{ cms.api }}/admin/utils/twig-playground"
		method="POST"
		data-disabled>

		<div class="editor-container">
			<label for="twig">Type your Twig Here</label>
			<textarea id="twig-editor" name="twig">{{ postData.twig }}</textarea>
		</div>
		<button class="cms-button" type="submit">Render Twig</button>

	</form>

	{% if results %}
	<section class="playground-results">
		<h2>Results</h2>

		<div class="result-section">
			<h3>Rendered HTML</h3>
			<div class="rendered-output">
				{{ results|raw }}
			</div>
		</div>

		<div class="result-section">
			<h3>HTML</h3>
			<textarea id="html-output" style="display: none;">{{ results }}</textarea>
		</div>

	</section>
	{% endif %}
</section>

<style>
/* Playground-specific styling */
.playground-results {
	margin-top: 2rem;
}

.result-section {
	margin-bottom: 2rem;
}

.result-section h3 {
	margin-bottom: 0.5rem;
	color: oklch(var(--totalform-nearblack));
}

/* Auto-resize functionality for editors */
.editor-container .CodeMirror-scroll {
	overflow: visible !important;
}

.editor-container .CodeMirror-scrollbar-filler,
.editor-container .CodeMirror-gutter-filler {
	display: none;
}

.html-output-editor .CodeMirror {
	height: auto;
	min-height: 100px;
}

.html-output-editor .CodeMirror-scroll {
	overflow: visible !important;
}

.html-output-editor .CodeMirror-scrollbar-filler,
.html-output-editor .CodeMirror-gutter-filler {
	display: none;
}

.rendered-output {
	border: 1px solid oklch(var(--totalform-border-color));
	padding: 1rem;
	background-color: oklch(var(--totalform-purewhite));
	border-radius: var(--totalform-radius);
}

/* These classes are applied automatically by the JavaScript */
</style>

<script type="module">
// Wait for TotalCMSCodeMirror to be available
document.addEventListener('DOMContentLoaded', function() {
	// Small delay to ensure the module is loaded
	setTimeout(initializeTwigPlayground, 100);
});

function initializeTwigPlayground() {
	if (!window.TotalCMSCodeMirror) {
		console.warn('TotalCMSCodeMirror not loaded yet, retrying...');
		setTimeout(initializeTwigPlayground, 100);
		return;
	}

	const textarea = document.getElementById('twig-editor');
	const localStorageKey = 'twig-playground-code';
	const form = document.getElementById('twig-playground');

	// Create Twig editor using our new API
	const editor = TotalCMSCodeMirror.createTwigEditor(textarea, {
		theme: 'elegant',
		autofocus: true,
		viewportMargin: Infinity, // Auto-expand
		indentUnit: 2,
		tabSize: 2,
		extraKeys: {
			'Ctrl-Enter': function() {
				form.requestSubmit();
			},
			'Cmd-Enter': function() {
				form.requestSubmit();
			}
		}
	});

	// Add the twig-editor class to the CodeMirror wrapper for custom styling
	editor.getWrapperElement().classList.add('twig-editor');

	// Function to resize editor to content
	function resizeEditor() {
		const lineHeight = editor.defaultTextHeight();
		const lineCount = Math.max(editor.lineCount(), 10); // Minimum 10 lines
		const totalHeight = (lineCount * lineHeight) + 20; // Add some padding
		editor.setSize(null, totalHeight);
	}

	// Ensure editor has proper height after full initialization
	setTimeout(() => {
		resizeEditor();
		// Also ensure minimum height via CSS if lineHeight calculation fails
		const wrapper = editor.getWrapperElement();
		const currentHeight = wrapper.offsetHeight;
		if (currentHeight < 250) { // Fallback minimum height
			editor.setSize(null, 250);
		}
	}, 100);

	// Resize on content change
	editor.on('changes', function() {
		setTimeout(resizeEditor, 0);
	});

	// Load saved content from localStorage
	const savedContent = TotalCMSCodeMirror.loadFromStorage(localStorageKey);
	if (savedContent && !textarea.value) {
		editor.setValue(savedContent);
	} else if (!textarea.value || textarea.value.trim() === '') {
		// If empty, add 9 empty lines to show line numbers 1-10
		editor.setValue('\n\n\n\n\n\n\n\n\n');
		editor.setCursor(0, 0); // Position cursor at start
	}

	// Save content to localStorage on change
	editor.on('change', function() {
		TotalCMSCodeMirror.saveToStorage(localStorageKey, editor.getValue());
	});

	// Update the textarea before form submission
	form.addEventListener('submit', function() {
		textarea.value = editor.getValue();
	});

	// Initialize HTML output editor if results exist
	const htmlOutput = document.getElementById('html-output');
	if (htmlOutput && htmlOutput.value.trim()) {
		// Format the HTML using our bundled beautifier
		const formattedHtml = TotalCMSCodeMirror.formatHtml(htmlOutput.value);

		// Replace the textarea with a div for the editor
		const outputContainer = document.createElement('div');
		outputContainer.className = 'html-output-container';
		htmlOutput.parentElement.replaceChild(outputContainer, htmlOutput);

		// Create HTML output editor using our new API
		const outputEditor = window.CodeMirror(outputContainer, {
			value: formattedHtml,
			mode: 'htmlmixed',
			theme: 'elegant',
			lineNumbers: true,
			lineWrapping: true,
			readOnly: true,
			foldGutter: true,
			gutters: ["CodeMirror-linenumbers", "CodeMirror-foldgutter"],
			matchBrackets: true,
			autoCloseTags: true
		});

		// Add custom classes
		outputContainer.classList.add('html-output-editor');
		outputEditor.getWrapperElement().classList.add('html-output-editor');

		// Set height to content height to avoid scrollbars
		const lineHeight = outputEditor.defaultTextHeight();
		const lineCount = outputEditor.lineCount();
		const totalHeight = Math.max((lineCount * lineHeight) + 40, 200); // Minimum height

		outputEditor.setSize(null, totalHeight);

		// Force refresh after a moment
		setTimeout(() => {
			outputEditor.refresh();
		}, 100);
	}
}
</script>

