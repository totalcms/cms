{% import 'dashboard-widgets.twig' as dashboard %}

{# Edition simulation warning #}
{% if cms.edition.isSimulating %}
<div class="simulation-warning">
	<span class="icon-warn"></span>
	You are simulating <strong>{{ cms.edition.current | capitalize }}</strong> edition.
	<a href="settings/license">Disable simulation</a>
</div>
{% endif %}

{# Get dashboard data #}
{% set stats = cms.admin.dashboardStats() %}
{% set collections = cms.admin.dashboardRecentCollections() %}
{# This is sloooooow #}
{# {% set recentObjects = cms.admin.dashboardRecentObjects() %} #}
{% set emptyCollections = cms.admin.dashboardEmptyCollections() %}
{% set systemStatus = cms.admin.dashboardSystemStatus() %}
{% set inaccessibleCollections = cms.admin.inaccessibleCollections() %}


{% if stats.collections <= 2 %}
	{# Show new user welcome if no user collections exist (accounts for system collections: auth, mailer) #}
	{{ dashboard.newUserWelcome() }}
{% else %}
	{# Display welcome message #}
	{{ include(cms.edition.can('whitelabel_templates')
		? ['whitelabel/admin-welcome.twig', 'admin-welcome.twig', 'admin-welcome-message.twig']
		: cms.edition.can('templates')
		? ['admin-welcome.twig', 'admin-welcome-message.twig']
		: ['admin-welcome-message.twig']
	, ignore_missing = true) }}

	{# Display quick stats #}
	{{ dashboard.statsCard(stats) }}

	{# Display quick actions #}
	{{ dashboard.quickActions() }}

	{# Main content area - two column layout #}
	<div class="dashboard-grid">
		<div class="dashboard-main">
			{# Collections overview table #}
			{{ dashboard.collectionsTable(collections) }}

			{# Inaccessible collections alert (edition downgrade) #}
			{{ dashboard.inaccessibleCollectionsAlert(inaccessibleCollections) }}

			{# Empty collections alert #}
			{{ dashboard.emptyCollectionsAlert(emptyCollections) }}
		</div>

		<div class="dashboard-sidebar">
			{# Development mode toggle #}
			{% if cms.auth.isAdmin() %}
				{{ dashboard.devModeToggle() }}
			{% endif %}

			{# Recent activity - disabled until optimized #}
			{# {{ dashboard.recentActivity() }} #}

			{# System status #}
			{% if cms.auth.isAdmin() %}
				{{ dashboard.systemStatus(systemStatus) }}
			{% endif %}
		</div>
	</div>
{% endif %}
