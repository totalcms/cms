{% import 'dashboard-widgets.twig' as dashboard %}

{# Get dashboard data #}
{% set stats = cms.dashboardStats() %}
{% set collections = cms.dashboardRecentCollections() %}
{# This is sloooooow #}
{# {% set recentObjects = cms.dashboardRecentObjects() %} #}
{% set emptyCollections = cms.dashboardEmptyCollections() %}
{% set systemStatus = cms.dashboardSystemStatus() %}


{% if stats.collections <= 3 %}
	{# Show new user welcome if no user collections exist (accounts for system collections: auth, playground, mailer) #}
	{{ dashboard.newUserWelcome() }}
{% else %}
	{# Display welcome message #}
	{{ include([
		'whitelabel/admin-welcome.twig',
		'admin-welcome.twig',
		'admin-welcome-message.twig'
	], ignore_missing = true) }}

	{# Display quick stats #}
	{{ dashboard.statsCard(stats) }}

	{# Display quick actions #}
	{{ dashboard.quickActions() }}

	{# Main content area - two column layout #}
	<div class="dashboard-grid">
		<div class="dashboard-main">
			{# Collections overview table #}
			{{ dashboard.collectionsTable(collections) }}

			{# Empty collections alert #}
			{{ dashboard.emptyCollectionsAlert(emptyCollections) }}
		</div>

		<div class="dashboard-sidebar">
			{# Recent activity #}
			{{ dashboard.recentActivity() }}

			{# System status #}
			{% if cms.isAdmin() %}
				{{ dashboard.systemStatus(systemStatus) }}
			{% endif %}
		</div>
	</div>
{% endif %}
