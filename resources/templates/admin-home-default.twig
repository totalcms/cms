{% import 'dashboard-widgets.twig' as dashboard %}

{# Get dashboard data #}
{% set stats = cms.dashboardStats() %}
{% set collections = cms.dashboardRecentCollections() %}
{# This is sloooooow #}
{# {% set recentObjects = cms.dashboardRecentObjects() %} #}
{% set emptyCollections = cms.dashboardEmptyCollections() %}
{% set systemStatus = cms.dashboardSystemStatus() %}


{% if stats.collections == 0 %}
	{# Show new user welcome if no collections exist #}
	{{ dashboard.newUserWelcome() }}
{% else %}
	{# Display welcome message #}
	{{ dashboard.welcomeMessage() }}

	{# Display quick stats #}
	{{ dashboard.statsCard(stats) }}

	{# Display quick actions #}
	{{ dashboard.quickActions() }}

	{# Main content area - two column layout #}
	<div class="dashboard-grid">
		<div class="dashboard-main">
			{# Collections overview table #}
			{{ dashboard.collectionsTable(collections) }}

			{# Empty collections alert #}
			{{ dashboard.emptyCollectionsAlert(emptyCollections) }}
		</div>

		<div class="dashboard-sidebar">
			{# Recent activity #}
			{{ dashboard.recentActivity() }}

			{# System status #}
			{% if cms.isAdmin() %}
				{{ dashboard.systemStatus(systemStatus) }}
			{% endif %}
		</div>
	</div>

	{# Custom dashboard override instructions #}
	<div class="dashboard-section dashboard-help">
		<details>
			<summary>Customize Your Dashboard</summary>
			<div class="help-content">
				<p>You can customize this dashboard by creating your own <code>admin-home.twig</code> template in <code>tcms-data/templates/</code>.</p>

				<h4>Available Dashboard Widgets:</h4>
				<ul>
					<li><code>{% verbatim %}{{ dashboard.statsCard(cms.dashboardStats()) }}{% endverbatim %}</code> - Quick statistics</li>
					<li><code>{% verbatim %}{{ dashboard.quickActions() }}{% endverbatim %}</code> - Quick action buttons</li>
					<li><code>{% verbatim %}{{ dashboard.collectionsTable(cms.dashboardCollections()) }}{% endverbatim %}</code> - Collections table</li>
					<li><code>{% verbatim %}{{ dashboard.recentActivity(cms.dashboardRecentObjects()) }}{% endverbatim %}</code> - Recent activity</li>
					<li><code>{% verbatim %}{{ dashboard.emptyCollectionsAlert(cms.dashboardEmptyCollections()) }}{% endverbatim %}</code> - Empty collections alert</li>
					<li><code>{% verbatim %}{{ dashboard.systemStatus(cms.dashboardSystemStatus()) }}{% endverbatim %}</code> - System information</li>
				</ul>

				<h4>Example Custom Dashboard:</h4>
				<pre><code>{% verbatim %}{% import 'dashboard-widgets.twig' as dashboard %}

	{{ dashboard.welcomeMessage('Admin') }}
	{{ dashboard.statsCard(cms.dashboardStats()) }}
	{{ dashboard.quickActions() }}

	{# Your custom content here #}
	<h2>My Custom Section</h2>
	<p>Add your own content!</p>{% endverbatim %}</code></pre>

				<p>See the <a href="docs">documentation</a> for more details.</p>
			</div>
		</details>
	</div>
{% endif %}
