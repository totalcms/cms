<!doctype html>
<html lang="en">
<head>
	<meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
	<meta name="robots" content="noindex, nofollow">
	<title>{% block title %}Total CMS{% endblock %}</title>

    <base href="{{ cms.api }}/admin/">
	<link rel="stylesheet" href="{{ cms.api }}/assets/dashboard.css"/>
	<link rel="stylesheet" href="{{ cms.api }}/assets/admin.css"/>
	<link rel="stylesheet" href="{{ cms.api }}/assets/content.css"/>

	{% set accentColor = cms.config('dashboard', 'accent') %}
	{% if accentColor %}
	<style>:root{--totalform-accent:{{ accentColor | hexToColor | oklch(100, false) }};}</style>
	{% endif %}

	{% block head %}{% endblock %}
	{{ include('whitelabel/admin-head.twig', ignore_missing = true) }}
</head>
<body>
    {% block content %}{% endblock %}

	<script type="module" src="{{ cms.api }}/assets/admin.js"></script>

	{% block bodyBelow %}{% endblock %}
	{{ include('whitelabel/admin-body-below.twig', ignore_missing = true) }}
</body>
</html>
