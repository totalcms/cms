{#
	Dashboard Widget Macros
	Reusable components for building admin dashboard pages
#}

{# Stats Card - Quick overview statistics #}
{% macro statsCard(stats) %}
<div class="dashboard-stats">
	<div class="stat-card">
		<div class="stat-icon icon-collections"></div>
		<div class="stat-content">
			<div class="stat-value">{{ stats.collections }}</div>
			<div class="stat-label">{{ t('dashboard.stat_collections') }}</div>
		</div>
	</div>

	<div class="stat-card">
		<div class="stat-icon icon-objects"></div>
		<div class="stat-content">
			<div class="stat-value">{{ stats.totalObjects | number_format(0, '.', ',') }}</div>
			<div class="stat-label">{{ t('dashboard.stat_objects') }}</div>
		</div>
	</div>

	<div class="stat-card">
		<div class="stat-icon icon-schema"></div>
		<div class="stat-content">
			<div class="stat-value">{{ stats.schemas }}</div>
			<div class="stat-label">{{ t('dashboard.stat_schemas') }}</div>
		</div>
	</div>

	<div class="stat-card">
		<div class="stat-icon icon-puzzle"></div>
		<div class="stat-content">
			<div class="stat-value">{{ stats.templates }}</div>
			<div class="stat-label">{{ t('dashboard.stat_templates') }}</div>
		</div>
	</div>

	<div class="stat-card">
		<div class="stat-icon icon-terminal"></div>
		<div class="stat-content">
			<div class="stat-value">{{ stats.totalJobs }}</div>
			<div class="stat-label">{{ t('dashboard.stat_queued_jobs') }}</div>
		</div>
	</div>
</div>
{% endmacro %}

{# Quick Actions - Common tasks #}
{% macro quickActions() %}
<div class="dashboard-section">
	<h2>{{ t('dashboard.quick_actions') }}</h2>
	<div class="quick-actions">
		<a href="collections/new" class="action-button">
			<span class="action-icon icon-collections"></span>
			<span class="action-text">{{ t('dashboard.new_collection') }}</span>
		</a>

		<a href="schemas/new" class="action-button">
			<span class="action-icon icon-schema"></span>
			<span class="action-text">{{ t('dashboard.new_schema') }}</span>
		</a>

		<a href="templates/new" class="action-button">
			<span class="action-icon icon-puzzle"></span>
			<span class="action-text">{{ t('dashboard.new_template') }}</span>
		</a>

		{% if cms.auth.isAdmin() %}
		<a href="utils/logs" class="action-button">
			<span class="action-icon icon-warn"></span>
			<span class="action-text">{{ t('dashboard.log_analyzer') }}</span>
		</a>

		<a href="utils/jobqueue" class="action-button">
			<span class="action-icon icon-terminal"></span>
			<span class="action-text">{{ t('dashboard.job_queue_manager') }}</span>
		</a>

		<a href="utils/cache-manager" class="action-button">
			<span class="action-icon icon-clean-o"></span>
			<span class="action-text">{{ t('dashboard.cache_manager') }}</span>
		</a>
		{% endif %}
	</div>
</div>
{% endmacro %}

{# Collections Overview Table #}
{% macro collectionsTable(collections) %}
<div class="dashboard-section">
	<h2>{{ t('dashboard.recent_collections') }}</h2>
	{% if collections|length > 0 %}
	<div class="collections-table">
		<table>
			<thead>
				<tr>
					<th>{{ t('dashboard.col_collection') }}</th>
					<th>{{ t('dashboard.col_schema') }}</th>
					<th>{{ t('dashboard.col_objects') }}</th>
					<th class="actions-column">{{ t('dashboard.col_actions') }}</th>
				</tr>
			</thead>
			<tbody>
				{% for collection in collections %}
				<tr>
					<td>
						<div class="collection-name">
							<span class="collection-icon schema-{{ collection.schema }}"></span>
							<a href="{{ collection.viewUrl }}">{{ collection.name }}</a>
						</div>
					</td>
					<td class="schema-cell">
						<a href="schemas/{{ collection.schema }}" class="schema-link">
							<code>{{ collection.schema }}</code>
						</a>
					</td>
					<td>
						<span class="object-count {% if collection.objectCount == 0 %}empty{% endif %}">
							{{ collection.objectCount }}
						</span>
					</td>
					<td class="actions-column">
						<div class="table-actions">
							<a href="{{ collection.addUrl }}" class="btn-small btn-icon" title="{{ t('dashboard.add_new_title', {'{name}': collection.name}) }}">
								<span class="btn-icon-svg icon-add"></span>
								{{ t('dashboard.add') }}
							</a>
							<a href="{{ collection.viewUrl }}" class="btn-small btn-icon" title="{{ t('dashboard.view_all_title', {'{name}': collection.name}) }}">
								<span class="btn-icon-svg icon-view"></span>
								{{ t('dashboard.view') }}
							</a>
						</div>
					</td>
				</tr>
				{% endfor %}
			</tbody>
		</table>
	</div>
	{% else %}
	<div class="empty-state">
		<p>{{ t('dashboard.no_collections') | raw }}</p>
	</div>
	{% endif %}
</div>
{% endmacro %}

{# Development Mode Toggle #}
{% macro devModeToggle() %}
<div class="dashboard-section devmode-widget">
	<h2>{{ t('dashboard.dev_mode') }}</h2>
	<div class="devmode-controls">
		{{ cms.form.devmode() }}
	</div>
</div>
{% endmacro %}

{# Recent Activity #}
{% macro recentActivity(recentObjects) %}
<div class="dashboard-section">
	<h2>{{ t('dashboard.recent_activity') }}</h2>
	{% if recentObjects|length > 0 %}
	<div class="recent-activity-list">
		{% for object in recentObjects %}
		<div class="activity-item">
			<div class="activity-icon schema-{{ object.schema }}"></div>
			<div class="activity-content">
				<div class="activity-title">
					<a href="{{ object.editUrl }}">{{ object.displayName }}</a>
				</div>
				<div class="activity-meta">
					<span class="collection-name">{{ object.collectionName }}</span>
					<span class="activity-time">{{ object.timestamp|date('M j, Y g:i A') }}</span>
				</div>
			</div>
		</div>
		{% endfor %}
	</div>
	{% else %}
	<div class="empty-state">
		<p>{{ t('dashboard.no_activity') }}</p>
	</div>
	{% endif %}
</div>
{% endmacro %}

{# Empty Collections Alert #}
{% macro emptyCollectionsAlert(emptyCollections) %}
{% if emptyCollections|length > 0 %}
<div class="dashboard-section empty-collections-section">
	<h2>{{ t('dashboard.empty_collections') }}</h2>
	<p>{{ t('dashboard.empty_collections_desc') }}</p>
	<ul class="empty-collections-list">
		{% for collection in emptyCollections %}
		<li>
			<span class="collection-icon schema-{{ collection.schema }}"></span>
			<span class="collection-name">{{ collection.name }}</span>
			<a href="{{ collection.addUrl }}" class="btn-small btn-icon">
				<span class="btn-icon-svg icon-add"></span>
				Add
			</a>
		</li>
		{% endfor %}
	</ul>
</div>
{% endif %}
{% endmacro %}

{# System Status #}
{% macro systemStatus(status) %}
<div class="dashboard-section">
	<h2>{{ t('dashboard.system_info') }}</h2>
	<div class="system-status">
		<div class="status-grid">
			<div class="status-item">
				<span class="status-label">{{ t('dashboard.version') }}</span>
				<span class="status-value">{{ cms.version }}{% if cms.version.date %} <span class="version-date">({{ cms.version.date }})</span>{% endif %}</span>
			</div>

			<div class="status-item">
				<span class="status-label">{{ t('dashboard.php_version') }}</span>
				<span class="status-value">{{ status.phpVersion }}</span>
			</div>

			<div class="status-item">
				<span class="status-label">{{ t('dashboard.environment') }}</span>
				<span class="status-value status-badge status-{{ status.environment }}">{{ status.environment | upper }}</span>
			</div>

			<div class="status-item">
				<span class="status-label">{{ t('dashboard.memory_limit') }}</span>
				<span class="status-value">{{ status.memoryLimit }}</span>
			</div>

			<div class="status-item">
				<span class="status-label">{{ t('dashboard.cache_backends') }}</span>
				<span class="status-value">
					{% if status.cacheBackends|length > 0 %}
						{{ status.cacheBackends|join(', ') }}
					{% else %}
						{{ t('dashboard.none') }}
					{% endif %}
				</span>
			</div>

			<div class="status-item">
				<span class="status-label">{{ t('dashboard.license') }}</span>
				<span class="status-value">
					<span class="status-badge status-{{ status.license.severity }}" title="{{ status.license.message }}">
						{{ status.license.message }}
						{% if status.license.daysRemaining is not null %}
							({{ t('dashboard.days', {'{count}': status.license.daysRemaining}) }})
						{% endif %}
					</span>
				</span>
			</div>
		</div>

		<div class="status-actions">
			<a href="utils/server-checker" class="btn-small btn-icon">
				<span class="btn-icon-svg icon-health"></span>
				{{ t('dashboard.server_checker') }}
			</a>
		</div>
	</div>
</div>
{% endmacro %}

{# Inaccessible Collections Alert - Shows when edition downgrade blocks collections #}
{% macro inaccessibleCollectionsAlert(inaccessibleCollections) %}
{% if inaccessibleCollections|length > 0 %}
<div class="dashboard-section inaccessible-collections-alert">
	<h2>{{ t('dashboard.collections_unavailable') }}</h2>
	<p class="alert-warning-text">
		<span class="icon-warn"></span>
		{{ t('dashboard.collections_unavailable_desc', {'{count}': inaccessibleCollections|length}) }}
	</p>
	<ul class="inaccessible-collections-list">
		{% for collection in inaccessibleCollections %}
		<li>
			<span class="collection-icon schema-{{ collection.schema }}"></span>
			<span class="collection-name">{{ collection.label ?? collection.id }}</span>
			<span class="collection-schema-badge">{{ collection.schema }}</span>
		</li>
		{% endfor %}
	</ul>
	<a href="utils/license-manager" class="dash-button">
		{{ t('dashboard.upgrade_access') }}
	</a>
</div>
{% endif %}
{% endmacro %}

{# New User Welcome - Shows when no collections exist #}
{% macro newUserWelcome() %}
<div class="dashboard-new-user-welcome">
	<h1>{{ t('dashboard.welcome_new') }} 👋</h1>
	<p>{{ t('dashboard.welcome_new_desc') }}</p>

	<div class="getting-started-options">
		<a href="utils/project-setup" class="getting-started-card">
			<div class="card-icon icon-flag"></div>
			<h3>{{ t('dashboard.project_setup') }}</h3>
			<p>{{ t('dashboard.project_setup_desc') }}</p>
			<span class="card-action">{{ t('dashboard.get_started') }} →</span>
		</a>

		<a href="collections/new" class="getting-started-card">
			<div class="card-icon icon-collections"></div>
			<h3>{{ t('dashboard.create_first') }}</h3>
			<p>{{ t('dashboard.create_first_desc') }}</p>
			<span class="card-action">{{ t('dashboard.create_collection') }} →</span>
		</a>

		<a href="docs" class="getting-started-card">
			<div class="card-icon icon-docs"></div>
			<h3>{{ t('dashboard.read_docs') }}</h3>
			<p>{{ t('dashboard.read_docs_desc') }}</p>
			<span class="card-action">{{ t('dashboard.view_docs') }} →</span>
		</a>
	</div>
</div>
{% endmacro %}
