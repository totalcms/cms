{# Blog Grid Item Template #}
{% if object.image %}
    <div class="cms-image">
		<a href="{{ cms.objectUrl(collection|default("blog"), object.id) }}" title="{{ object.title }}" class="link-container">
        {{ cms.imageFromData(object.image, object.id, {}, {collection: collection|default("blog")}) }}
		</a>
    </div>
{% endif %}

<div class="cms-content">
	<a href="{{ cms.objectUrl(collection|default("blog"), object.id) }}" title="{{ object.title }}" class="link-container">
		<h3 class="cms-title">{{ object.title }}</h3>
	</a>

	{% if object.date %}
		{{ cms.grid.meta(cms.grid.date(object.date, 'relative')) }}
	{% endif %}

	{% if object.summary %}
		{{ cms.grid.excerpt(object.summary, 150) }}
	{% endif %}

	{% if object.tags %}
		{{ cms.grid.tags(object.tags) }}
	{% endif %}
</div>