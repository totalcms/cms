<!DOCTYPE html>
<html lang="en">
<head>
	<meta charset="UTF-8">
	<meta name="viewport" content="width=device-width, initial-scale=1.0">
	<title>Verify Your Email</title>
	<style>
		/* Total CMS Email Styling - Flat Design Matching Dashboard */
		body {
			font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
			line-height: 1.6;
			color: #2b2b2b; /* nearblack */
			background-color: #ffffff;
			margin: 0;
			padding: 0;
		}
		.email-container {
			max-width: 600px;
			margin: 0 auto;
			padding: 32px 0;
		}
		.email-header {
			padding: 0 20px;
		}
		.email-header h1 {
			margin: 0;
			font-size: 22px;
			font-weight: 600;
			letter-spacing: -0.01em;
		}
		.email-body {
			padding: 32px 20px;
			background-color: #ffffff;
		}
		.email-body p {
			margin: 0 0 16px 0;
			font-size: 15px;
			color: #2b2b2b; /* nearblack */
		}
		.email-body .greeting {
			font-size: 16px;
			font-weight: 600;
			margin-bottom: 20px;
			color: #575757; /* darkgray */
		}
		.verify-button {
			display: inline-block;
			background-color: #5a9be5; /* blue accent */
			color: #ffffff;
			text-decoration: none;
			padding: 12px 28px;
			border-radius: 5px; /* totalform-radius */
			font-weight: 600;
			font-size: 15px;
			margin: 20px 0;
			text-align: center;
			border: 1px solid #4a8bd5;
		}
		.verify-button:hover {
			background-color: #4a8bd5;
		}
		.button-container {
			text-align: center;
			margin: 24px 0;
		}
		.expiry-notice {
			background-color: #fffaec; /* light yellow background */
			border: 1px solid #e8c96f; /* yellow border */
			border-radius: 5px;
			padding: 14px 16px;
			margin: 20px 0;
			font-size: 14px;
			color: #575757; /* darkgray */
		}
		.expiry-notice strong {
			color: #2b2b2b; /* nearblack */
		}
		.alternative-link {
			background-color: #f7f7f7; /* nearwhite */
			border: 1px solid #dedede; /* lightgray */
			padding: 14px 16px;
			border-radius: 5px;
			margin: 20px 0;
			word-break: break-all;
		}
		.alternative-link p {
			margin: 0 0 8px 0;
			font-size: 13px;
			color: #575757; /* darkgray */
		}
		.alternative-link code {
			font-size: 12px;
			color: #2b2b2b; /* nearblack */
			background-color: #ffffff;
			padding: 8px 10px;
			display: block;
			border-radius: 5px;
			border: 1px solid #dedede; /* lightgray */
			font-family: 'SF Mono', Monaco, 'Courier New', monospace;
		}
		.email-footer {
			background-color: #f7f7f7; /* nearwhite */
			padding: 24px 20px;
			text-align: center;
			font-size: 13px;
			border-radius: 5px;
			color: #575757; /* darkgray */
		}
		.security-notice {
			margin-top: 28px;
			padding-top: 20px;
			border-top: 1px solid #dedede; /* lightgray */
			font-size: 14px;
			color: #575757; /* darkgray */
		}
		.security-notice strong {
			color: #2b2b2b; /* nearblack */
		}
	</style>
</head>
<body>
	<div class="email-container">
		<div class="email-header">
			<h1>Verify Your Email</h1>
		</div>

		<div class="email-body">
			<p class="greeting">Hello{% if name %} {{ name }}{% endif %},</p>

			<p>
				Thanks for signing up. Click the button below to verify your email and activate your account:
			</p>

			<div class="button-container">
				<a href="{{ verifyUrl }}" class="verify-button">Verify Email</a>
			</div>

			<div class="expiry-notice">
				<strong>⏰ This link will expire in {{ expiryMinutes }} minutes</strong> for security reasons.
			</div>

			<div class="alternative-link">
				<p>If the button doesn't work, copy and paste this link into your browser:</p>
				<code>{{ verifyUrl }}</code>
			</div>

			<div class="security-notice">
				<p>
					<strong>Didn't sign up?</strong><br>
					If you didn't create an account, you can safely ignore this email.
					No further action is required and the account will remain inactive.
				</p>
			</div>
		</div>

		<div class="email-footer">
			<p>This is an automated message from Total CMS.</p>
		</div>
	</div>
</body>
</html>
