<style>
{% verbatim %}
	/* Container Layouts */
	.tcms-blog-post {
		width: 100%;
	}

	.blog-post-centered {
		max-width: 800px;
		margin-left: auto;
		margin-right: auto;
	}

	.blog-post-narrow {
		max-width: 600px;
		margin-left: auto;
		margin-right: auto;
	}

	.blog-post-full-width {
		max-width: 100%;
	}

	/* Hero Image */
	.blog-hero {
		position: relative;
		aspect-ratio: 16 / 9;
		overflow: hidden;
		margin-bottom: 2rem;
	}

	.blog-hero-image {
		width: 100%;
		height: 100%;
		object-fit: cover;
	}

	/* Featured Badge */
	.blog-featured-badge {
		position: absolute;
		top: 1rem;
		right: 1rem;
		background: rgba(0, 0, 0, 0.8);
		color: white;
		padding: 0.5rem 1rem;
		border-radius: 0.25rem;
		font-size: 0.875rem;
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 0.05em;
	}

	/* Header */
	.blog-header {
		margin-bottom: 2rem;
	}

	.blog-title {
		margin: 0 0 1rem 0;
		font-size: 2.5rem;
		line-height: 1.2;
	}

	/* Meta */
	.blog-meta {
		display: flex;
		flex-wrap: wrap;
		gap: 1rem;
		margin-bottom: 1rem;
		color: #666;
		font-size: 0.9rem;
	}

	/* Taxonomy (Categories & Tags) */
	.blog-taxonomy {
		display: flex;
		flex-wrap: wrap;
		gap: 1rem;
		margin-top: 1rem;
	}

	.blog-categories,
	.blog-tags {
		display: flex;
		flex-wrap: wrap;
		gap: 0.5rem;
	}

	/* Category & Tag Badges */
	.blog-category-badge,
	.blog-tag-badge {
		display: inline-block;
		padding: 0.25rem 0.75rem;
		border-radius: 0.25rem;
		font-size: 0.875rem;
		background: #f0f0f0;
		color: #333;
	}

	/* Category & Tag Links */
	.blog-category-link,
	.blog-tag-link {
		display: inline-block;
		padding: 0.25rem 0.75rem;
		border-radius: 0.25rem;
		font-size: 0.875rem;
		text-decoration: none;
		background: #f0f0f0;
		color: #333;
		transition: background 0.2s ease;
	}

	.blog-category-link:hover,
	.blog-tag-link:hover {
		background: #e0e0e0;
	}

	/* Summary */
	.blog-summary {
		font-size: 1.25rem;
		line-height: 1.6;
		color: #555;
		margin: 1.5rem 0;
		padding-top: 1rem;
		border-top: 1px solid #e0e0e0;
	}

	/* Content Sections */
	.blog-content,
	.blog-extra {
		margin-bottom: 2rem;
		line-height: 1.7;
	}

	/* Media Embed */
	.blog-media {
		margin: 2rem 0;
	}

	/* Gallery */
	.blog-gallery {
		margin: 2rem 0;
	}

	/* Footer */
	.blog-footer {
		margin-top: 3rem;
		padding-top: 2rem;
		border-top: 1px solid #e0e0e0;
		color: #666;
		font-size: 0.875rem;
	}

	/* Responsive */
	@media (max-width: 768px) {
		.blog-title {
			font-size: 2rem;
		}

		.blog-summary {
			font-size: 1.1rem;
		}

		.blog-featured-badge {
			top: 0.5rem;
			right: 0.5rem;
			padding: 0.375rem 0.75rem;
			font-size: 0.75rem;
		}
	}
{% endverbatim %}
</style>
