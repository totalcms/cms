{
  "factory": [
    {
      "count": 5,
      "data": {
        "image": "imageBlur",
        "tags": "tags(1, 5)"
      },
      "collection": "blog"
    },
    {
      "id": "name",
      "data": {
        "text": "name"
      },
      "collection": "text"
    }
  ],
  "schemas": [
    {
      "fields": [
        {
          "label": "Author Name",
          "name": "author",
          "required": true,
          "type": "text"
        },
        {
          "label": "Company",
          "name": "company",
          "type": "text"
        },
        {
          "label": "Testimonial Text",
          "name": "content",
          "required": true,
          "type": "textarea"
        },
        {
          "label": "Rating (1-5)",
          "options": {
            "max": 5,
            "min": 1
          },
          "name": "rating",
          "type": "number"
        },
        {
          "label": "Avatar",
          "name": "avatar",
          "type": "image"
        }
      ],
      "id": "testimonial",
      "description": "Customer testimonials",
      "name": "Testimonial"
    },
    {
      "fields": [
        {
          "label": "Product Name",
          "name": "name",
          "required": true,
          "type": "text"
        },
        {
          "label": "Description",
          "name": "description",
          "type": "markdown"
        },
        {
          "label": "Price",
          "options": {
            "min": 0,
            "step": 0.01
          },
          "name": "price",
          "type": "number"
        },
        {
          "label": "Product Images",
          "options": {
            "itemType": "image"
          },
          "name": "images",
          "type": "array"
        },
        {
          "label": "In Stock",
          "default": true,
          "name": "inStock",
          "type": "toggle"
        }
      ],
      "id": "product",
      "description": "Product catalog",
      "name": "Product"
    }
  ],
  "collections": {
    "default": [
      "blog",
      "image",
      "gallery",
      "text",
      "navigation"
    ],
    "custom": [
      {
        "id": "testimonials",
        "name": "Customer Testimonials",
        "schemaId": "testimonial"
      },
      {
        "id": "products",
        "name": "Product Catalog",
        "schemaId": "product"
      }
    ]
  },
  "version": "1.0.0",
  "description": "Jumpstart your Total CMS project with demo content including schemas, collections, and sample data",
  "objects": [
    {
      "id": "homepage-hero",
      "data": {
        "text": "This is a demo site created with Total CMS Jumpstart. Explore our blog, products, and more!"
      },
      "collection": "text"
    }
  ],
  "name": "Total CMS Jumpstart Demo"
}