  "schemas": [
    {
      "formgrid": "id\nname\nimage\ndescription\nprice\ntags",
      "id": "products",
      "$id": "https://www.totalcms.co/schemas/products.json",
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "properties": {
        "price": {
          "factory": "randomFloat(2, 10, 100)",
          "settings": {
            "min": 1,
            "step": 0.01
          },
          "type": "number",
          "field": "number"
